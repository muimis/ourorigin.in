---
import BaseLayout from '../components/BaseLayout.astro';
import TheThreshold from '../components/TheThreshold.astro';
import TheManifesto from '../components/TheManifesto.astro';
import TheYieldList from '../components/TheYieldList.astro';
import TheHorizonLog from '../components/TheHorizonLog.astro';
import TheIndexLedger from '../components/TheIndexLedger.astro';
import TheObservationsList from '../components/TheObservationsList.astro';
---

<BaseLayout
  title="OurOrigin — The Absolute Truth of the Soil"
  description="OurOrigin sources spices and natural ingredients from the Western Ghats — Nilgiris, Idukki, Wayanad, and beyond. Traceable to the person who harvested them."
  canonicalPath="/"
  ogTitle="OurOrigin — The Absolute Truth of the Soil"
  ogDescription="Spices and ingredients from the Western Ghats. Traceable to the person who harvested them."
  navVariant="light"
  showFooter={true}
  bodyClass="homepage-body"
>
    <main>
        <!-- Chapter 01: Hero Gate -->
        <TheThreshold />

        <!-- Chapter 02: Ethos & Manifesto -->
        <TheManifesto />

        <!-- Chapter 03: Yields Grouped by Sourcing Collectives -->
        <TheYieldList />

        <!-- Chapter 04: Sun Curing Log -->
        <TheHorizonLog />

        <!-- Chapter 05: Sourcing Ledger Database Index -->
        <TheIndexLedger />

        <!-- Chapter 06: Curated Field Observation Records -->
        <TheObservationsList />
    </main>
</BaseLayout>

<style is:global>
    body.homepage-body {
        background-color: #010201 !important;
        overflow-x: hidden !important;
        width: 100%;
    }
</style>

<style>
    main {
        position: relative;
        width: 100%;
        background-color: var(--color-forest-deep);
    }
</style>
