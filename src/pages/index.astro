---
import BaseLayout from '../components/BaseLayout.astro';
import HeroStorefront from '../components/HeroStorefront.astro';
import ProductGrid from '../components/ProductGrid.astro';
---

<BaseLayout
  title="OurOrigin — From the Western Ghats"
  description="OurOrigin sources spices and natural ingredients from the Western Ghats — Nilgiris, Idukki, Wayanad, and beyond. Traceable to the person who harvested them."
  canonicalPath="/"
  ogTitle="OurOrigin — From the Western Ghats"
  ogDescription="Spices and ingredients from the Western Ghats. Traceable to the person who harvested them."
  navVariant="dark"
  showFooter={true}
>
    <main>
        <HeroStorefront />
        <ProductGrid />
    </main>

    <script>
        // Smooth scroll for the CTA anchor link
        document.querySelector('.cta-primary')?.addEventListener('click', (e) => {
            e.preventDefault();
            const target = document.getElementById('yields');
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    </script>
</BaseLayout>

<style>
    main {
        position: relative;
        width: 100%;
        overflow-x: hidden;
    }
</style>
