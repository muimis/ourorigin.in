---
import '../styles/tokens.css';
import TheThreshold from '../components/TheThreshold.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OurOrigin</title>
    
    <meta name="description" content="OurOrigin sources spices and natural ingredients from the Western Ghats — Nilgiris, Idukki, Wayanad, and beyond. From the Source.">
    <link rel="canonical" href="https://ourorigin.in/">
    
    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="OurOrigin — From the Western Ghats">
    <meta property="og:description" content="Five origins. Twelve yields. The absolute truth of the earth.">
    <meta property="og:url" content="https://ourorigin.in/">
    <meta property="og:image" content="https://ourorigin.in/og-image.jpg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="OurOrigin">
    
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="OurOrigin — From the Western Ghats">
    
    <!-- Google Fonts with display=swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&family=Cormorant+Garamond:wght@300;400;500&family=DM+Mono:ital,wght@0,300;0,400;0,500&display=swap" rel="stylesheet">
</head>
<body class="theme-default">
    <main>
        <!-- The Presentation: Phase 1 -->
        <TheThreshold />
    </main>
</body>
</html>

<style>
    body {
        margin: 0;
        padding: 0;
        background-color: #010201; /* Deep abyssal black */
        color: var(--color-warm-cream);
        font-family: var(--font-mono);
        overflow: hidden; /* No scrolling on the Threshold */
    }
</style>
