---
import '../styles/tokens.css';
import LivingMatrix from '../components/LivingMatrix.astro';
import Carousel from '../components/Carousel.astro';
import Ledger from '../components/Ledger.astro';
import LaunchScreen from '../components/LaunchScreen.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OurOrigin | The Living Matrix</title>
    <!-- Google Fonts with display=swap as explicitly requested -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&family=Cormorant+Garamond:wght@300;400;500&family=DM+Mono:ital,wght@0,300;0,400;0,500&display=swap" rel="stylesheet">
    <style>
        body, html {
            margin: 0;
            padding: 0;
            background-color: var(--color-forest-deep);
            color: var(--color-warm-cream);
        }
    </style>
</head>
<body>
    <LaunchScreen />
    <LivingMatrix />
    <Carousel />
    <Ledger />
</body>
</html>
