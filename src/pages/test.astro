---
import '../styles/tokens.css';
import OriginMark from '../components/OriginMark.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Direction 01: Test Page</title>
    <!-- Google Fonts with display=swap as explicitly requested -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&family=Cormorant+Garamond:wght@300;400;500&family=DM+Mono:ital,wght@0,300;0,400;0,500&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: var(--color-warm-cream);
            padding: 2rem;
            min-height: 100vh;
        }

        .dark-mode {
            background-color: var(--color-forest-deep);
            color: var(--color-warm-cream);
        }

        h1 { font-family: var(--font-institutional); }
        h2 { font-family: var(--font-narrative); }
        p { font-family: var(--font-evidence); }

        .swatch-container {
            display: flex;
            gap: 1rem;
            margin: 2rem 0;
        }

        .swatch {
            width: 80px;
            height: 80px;
            border-radius: 4px;
            border: 1px solid rgba(0,0,0,0.1);
        }

        .swatch.forest { background-color: var(--color-forest-deep); }
        .swatch.cream { background-color: var(--color-warm-cream); }
        .swatch.gold { background-color: var(--color-gold); }

        .mark-container {
            margin: 3rem 0;
            display: flex;
            gap: 3rem;
            align-items: center;
        }

        .controls {
            margin-bottom: 2rem;
        }
    </style>
</head>
<body class="dark-mode">

    <div class="controls">
        <button id="play-anim">Play Origin Mark Entrance</button>
    </div>

    <h1>Cinzel: The Institutional Font</h1>
    <h2>Cormorant Garamond: The Narrative Font</h2>
    <p>DM Mono: The Evidence Font</p>

    <div class="swatch-container">
        <div class="swatch forest" title="Forest Deep"></div>
        <div class="swatch cream" title="Warm Cream"></div>
        <div class="swatch gold" title="Gold"></div>
    </div>

    <h2>Origin Mark Variants (Size: 100px)</h2>
    <div class="mark-container">
        <!-- Primary Variant (Cream on Forest) -->
        <OriginMark size={100} variant="primary" id="mark-primary-100" />
        
        <!-- Reversed Variant (Forest on Cream) -->
        <!-- Placed in a light box to see it -->
        <div style="background: var(--color-warm-cream); padding: 1rem;">
            <OriginMark size={100} variant="reversed" id="mark-reversed-100" />
        </div>
        
        <!-- Gold Variant -->
        <OriginMark size={100} variant="gold" id="mark-gold-100" />
    </div>

    <h2>Origin Mark Variants (Size: 250px)</h2>
    <div class="mark-container">
        <OriginMark size={250} variant="primary" id="mark-primary-250" />
        
        <div style="background: var(--color-warm-cream); padding: 1rem;">
            <OriginMark size={250} variant="reversed" id="mark-reversed-250" />
        </div>
        
        <OriginMark size={250} variant="gold" id="mark-gold-250" />
    </div>

    <script>
        document.getElementById('play-anim').addEventListener('click', () => {
            // Dispatch a custom event that the OriginMark components listen for
            document.dispatchEvent(new CustomEvent('play-origin-mark-entrance'));
        });
    </script>
</body>
</html>
