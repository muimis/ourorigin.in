---
import '../styles/tokens.css';
import GlobalNav from '../components/GlobalNav.astro';
import AllYieldsPanel from '../components/AllYieldsPanel.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Why this exists. — OurOrigin</title>
    
    <meta name="description" content="OurOrigin exists because the people and places behind real products deserve to be seen, not kept in the background of a marketing story.">
    <link rel="canonical" href="https://ourorigin.in/why">
    <meta property="og:title" content="Why this exists. | OurOrigin">
    <meta property="og:description" content="A small business sourcing from the Western Ghats. We show you the origin and let you reach your own conclusions.">
    <meta property="og:url" content="https://ourorigin.in/why">
    <meta property="og:image" content="https://ourorigin.in/og-image.jpg">

    <!-- Google Fonts with display=swap as explicitly requested -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&family=Cormorant+Garamond:wght@300;400;500&family=DM+Mono:ital,wght@0,300;0,400;0,500&display=swap" rel="stylesheet">
    <style>
        body, html {
            margin: 0;
            padding: 0;
            background-color: var(--color-forest-deep);
            color: var(--color-warm-cream);
            height: 100%;
        }
        .page-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20vh 5vw;
            display: flex;
            flex-direction: column;
            gap: 2rem;
            opacity: 0;
            animation: cinematicFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @keyframes cinematicFade {
            0% { opacity: 0; transform: translateY(15px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        h1 {
            font-family: 'Cinzel', serif;
            font-size: 24px;
            margin: 0 0 2rem 0;
            font-weight: 400;
        }
        p {
            font-family: 'Cormorant Garamond', serif;
            font-size: 20px;
            line-height: 1.6;
            margin: 0 0 1.5rem 0;
            opacity: 0.9;
        }
        .nav-link {
            font-family: 'DM Mono', monospace;
            color: var(--color-warm-cream);
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-top: 4rem;
            display: inline-block;
            border-bottom: 1px solid rgba(244, 241, 235, 0.3);
            padding-bottom: 0.2rem;
            transition: border-color 0.3s ease;
            align-self: flex-start;
        }
        .nav-link:hover {
            border-bottom-color: var(--color-warm-cream);
        }
        .fssai-footer {
            margin-top: auto;
            padding-top: 4rem;
            font-family: 'DM Mono', monospace;
            font-size: 0.75rem;
            color: var(--color-warm-cream);
            opacity: 0.4;
            text-align: left;
        }
    </style>
</head>
<body>
    <GlobalNav />
    <AllYieldsPanel />
    <main id="main-content" class="page-container">
<h1 class="sr-only">Why this exists. — OurOrigin</h1>

<section class="why-content">

  <p class="why-heading">WHY THIS EXISTS.</p>
  <!-- Cinzel, 14px, letter-spacing 0.35em, cream at 80% -->

  <div class="why-body">

    <p>A farmer walks 12 kilometres into the forest to reach a vine. He picks what is ripe and leaves the rest — what the animals took, what the season hasn't finished. He carries back only what was given willingly.</p>

    <p>The product in this packet is the evidence of that decision.</p>

    <p>OurOrigin exists to make that decision visible — to connect it directly to the person who uses what it produced. No campaign. No intermediary. The origin is here, if you want to see it.</p>

    <p>The buyer who sees it, and pays for what it actually cost to make it, is not a customer of OurOrigin. They are part of it.</p>

  </div>

  <p class="why-closing">FROM THE SOURCE.</p>
  <!-- Cinzel, 12px, letter-spacing 0.3em, gold, centred -->

  <p class="why-fssai">FSSAI Reg. No. 21326135000354</p>
  <!-- DM Mono, 9px, cream at 25% -->

  <a href="/" class="why-return">← Return to the origins</a>
  <!-- Cormorant Garamond, 13px, cream at 50% -->

</section>
    </main>
</body>
</html>
