---
// src/pages/horizon.astro
import BaseLayout from '../components/BaseLayout.astro';
import OriginMark from '../components/OriginMark.astro';

const upcomingCrops = [
  {
    title: 'Winter Curing Vanilla',
    specimenRecord: 'IDK-VN-2026 · CURING PHASE',
    location: 'Idukki, Western Ghats',
    altitude: '1,200m',
    soilBase: 'Forest Loam & Granite Transition',
    status: 'Wool Wrap Curing',
    observation: 'The pods are wrapped in wool blankets for 48 hours to sweat, then laid on wooden racks in the shade. The aroma builds in the dark. It cannot be rushed.',
    timeline: 'HARVEST: JAN 2026 · CURING: FEB–SEP · DISPATCH: OCT 2026',
    bgImage: '/assets/origins/idukki-canopy.webp'
  },
  {
    title: 'Silver Needle Tea',
    specimenRecord: 'NIL-SNT-2026 · WITHERING PHASE',
    location: 'Nilgiris, Western Ghats',
    altitude: '2,600m',
    soilBase: 'Acidic Mountain Clay',
    status: 'Sun Withering',
    observation: 'Plucked in the early morning frost when the buds are still closed. Withered under direct highland sun for exactly twelve hours to preserve the silver down.',
    timeline: 'HARVEST: NOV 2026 · WITHERING: NOV · DISPATCH: DEC 2026',
    bgImage: '/assets/origins/nilgiris-canopy.webp'
  },
  {
    title: 'Wild Celery Seed',
    specimenRecord: 'WYD-WCS-2026 · MATURATION',
    location: 'Wayanad, Western Ghats',
    altitude: '1,100m',
    soilBase: 'Laterite Volcanic Clay',
    status: 'Root Curing',
    observation: 'Harvested from wild streams in the high valley. Dried slowly in shade with roots intact to lock in the intense pinene oils before threshing.',
    timeline: 'HARVEST: DEC 2026 · CURING: DEC–JAN · DISPATCH: JAN 2027',
    bgImage: '/assets/origins/wayanad-canopy.webp'
  },
  {
    title: 'Sun-Dried Galangal Root',
    specimenRecord: 'TVM-GAL-2027 · DRYING PHASE',
    location: 'Thiruvananthapuram, Coast',
    altitude: '10m',
    soilBase: 'Silicified Coastal Sand',
    status: 'Shade Drying',
    observation: 'Sourced from the low dunes. Sliced thin within hours of extraction and dried under palm thatch to protect the sharp zingerone compounds.',
    timeline: 'HARVEST: JAN 2027 · DRYING: JAN–FEB · DISPATCH: FEB 2027',
    bgImage: '/assets/origins/thiruvananthapuram-canopy.webp'
  }
];
---

<BaseLayout
  title="Horizon: Future Harvests & Curing logs — OurOrigin"
  description="Upcoming ingredients curing in the shade or maturing in the forest. The OurOrigin timeline of upcoming harvests."
  canonicalPath="/horizon"
  ogTitle="Horizon: Future Harvests & Curing logs | OurOrigin"
  ogDescription="Maturation tracking and curing telemetry for upcoming seasonal harvests."
  navVariant="light"
  showFooter={true}
>
  <main id="main-content" class="horizon-page-container">
    <div class="horizon-header">
      <span class="horizon-tag">[ MATURATION & CURING LOGS ]</span>
      <h1 class="horizon-title">The Horizon</h1>
      <p class="horizon-subtitle">SPECIMEN PREPARATIONS UNDERWAY ACROSS SELECTED PROVENANCES</p>
    </div>

    <div class="crops-stream">
      {upcomingCrops.map((crop) => (
        <section class="crop-section">
          <!-- Background image with wash for high visual production value -->
          <div class="crop-backdrop" style={`background-image: url('${crop.bgImage}');`}></div>
          <div class="crop-wash"></div>
          
          <div class="crop-content">
            <div class="crop-left-col">
              <h2 class="crop-title">{crop.title}</h2>
              <span class="crop-record">{crop.specimenRecord}</span>
              
              <!-- Timeline using Stage separators instead of table -->
              <div class="crop-timeline">
                <span class="timeline-stage">{crop.timeline.split('·')[0].trim()}</span>
                <span class="timeline-dot">·</span>
                <span class="timeline-stage">{crop.timeline.split('·')[1].trim()}</span>
                <span class="timeline-dot">·</span>
                <span class="timeline-stage">{crop.timeline.split('·')[2].trim()}</span>
              </div>
            </div>

            <div class="crop-right-col">
              <!-- Telemetry Dense Table -->
              <div class="telemetry-table" role="table" aria-label="Ecological Telemetry">
                <div class="telemetry-row" role="row">
                  <span class="tel-label" role="rowheader">PROVENANCE:</span>
                  <span class="tel-value">{crop.location}</span>
                </div>
                <div class="telemetry-row" role="row">
                  <span class="tel-label" role="rowheader">ELEVATION:</span>
                  <span class="tel-value">{crop.altitude}</span>
                </div>
                <div class="telemetry-row" role="row">
                  <span class="tel-label" role="rowheader">SOIL BASE:</span>
                  <span class="tel-value">{crop.soilBase}</span>
                </div>
                <div class="telemetry-row" role="row">
                  <span class="tel-label" role="rowheader">STATE:</span>
                  <span class="tel-value status-highlight">{crop.status.toUpperCase()}</span>
                </div>
              </div>

              <!-- Curator's Observation -->
              <div class="curator-notes">
                <span class="notes-tag">[ CURATOR'S NOTE ]</span>
                <p class="notes-body">{crop.observation}</p>
              </div>
            </div>
          </div>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .horizon-page-container {
    padding-top: max(140px, 20vh);
    padding-bottom: 10vh;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
  }

  .horizon-header {
    max-width: 1200px;
    margin: 0 auto 5rem auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
    text-align: left;
    border-bottom: 1px solid rgba(245, 237, 216, 0.15);
    padding-bottom: 2rem;
  }

  .horizon-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--color-gold);
  }

  .horizon-title {
    font-family: var(--font-institutional);
    font-size: clamp(2.5rem, 5vw, 6rem);
    font-weight: 300;
    margin: 0.5rem 0 0 0;
    line-height: 1;
    text-transform: uppercase;
  }

  .horizon-subtitle {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: rgba(245, 237, 216, 0.4);
    margin: 0.5rem 0 0 0;
  }

  .crops-stream {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  .crop-section {
    position: relative;
    border: 1px solid rgba(245, 237, 216, 0.1);
    min-height: 350px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .crop-backdrop {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.15;
    z-index: 1;
    filter: saturate(0.1) contrast(1.1) brightness(0.5);
    transition: transform 6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .crop-section:hover .crop-backdrop {
    transform: scale(1.05);
  }

  .crop-wash {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 0%, var(--color-forest-deep) 100%);
    z-index: 2;
  }

  .crop-content {
    position: relative;
    z-index: 3;
    width: 100%;
    padding: 3rem;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
    box-sizing: border-box;
  }

  .crop-left-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
  }

  .crop-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 300;
    margin: 0;
    line-height: 1.1;
  }

  .crop-record {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-gold);
  }

  .crop-timeline {
    font-family: var(--font-mono);
    font-size: var(--type-whisper);
    color: rgba(245, 237, 216, 0.4);
    margin-top: 1rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .timeline-dot {
    color: var(--color-gold);
  }

  .crop-right-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    text-align: left;
  }

  /* Telemetry Dense Table */
  .telemetry-table {
    display: flex;
    flex-direction: column;
    gap: 12px; /* md spacing (12px) */
    border-bottom: 1px dashed rgba(245, 237, 216, 0.15);
    padding-bottom: 1.2rem;
  }

  .telemetry-row {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: var(--type-evidence);
    letter-spacing: 0.05em;
  }

  .tel-label {
    color: rgba(245, 237, 216, 0.45);
  }

  .tel-value {
    color: var(--color-warm-cream);
  }

  .status-highlight {
    color: var(--color-gold);
  }

  .curator-notes {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .notes-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--color-gold);
  }

  .notes-body {
    font-family: var(--font-display);
    font-size: var(--type-narrative);
    line-height: 1.5;
    color: var(--color-warm-cream);
    opacity: 0.85;
    margin: 0;
    max-width: 480px;
  }

  @media (max-width: 1024px) {
    .crop-content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 2rem;
    }
    .crop-section {
      min-height: auto;
    }
  }
</style>
