---
import BaseLayout from '../components/BaseLayout.astro';
import { WHATSAPP_NUMBER, EMAIL_ADDRESS } from '../utils/constants';

const whatsappLink = `https://wa.me/${WHATSAPP_NUMBER}`;
const formattedPhone = '+91 96455 55668';
---

<BaseLayout
  title="Inquiry Dispatch — OurOrigin"
  description="Reach out to OurOrigin for inquiries, harvest reservations, or questions about our origins."
  canonicalPath="/contact"
  ogTitle="Inquiry Dispatch | OurOrigin"
  ogDescription="Reach out to OurOrigin for inquiries, harvest reservations, or questions about our origins."
  navVariant="light"
  showFooter={true}
>
    <main id="main-content" class="page-container">
        <h1>Inquiry Dispatch</h1>

        <div class="contact-details">
            <p>Our operations are based in Thiruvananthapuram, Kerala. If you seek to trace a specific coordinates matrix, or understand the curing chemistry of a yield, we will disclose every record in our archive.</p>
            <a href={whatsappLink} class="contact-link" target="_blank" rel="noopener noreferrer">{formattedPhone}</a>
            <a href={`mailto:${EMAIL_ADDRESS}`} class="contact-link">{EMAIL_ADDRESS}</a>
        </div>

        <p class="contact-gifting">For orders of 50 or more, reach us on the same number.</p>

        <a href="/" class="nav-link">← Back to Home</a>
    </main>
</BaseLayout>

<style>
    .page-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20vh 5vw 10vh;
        display: flex;
        flex-direction: column;
    }

    h1 {
        font-family: var(--font-institutional);
        font-size: 24px;
        margin: 0 0 1rem 0;
        font-weight: 400;
        color: var(--color-warm-cream);
    }

    .contact-details p {
        font-family: var(--font-display);
        font-size: 20px;
        line-height: 1.6;
        margin: 0 0 2rem 0;
        opacity: 0.9;
        color: var(--color-warm-cream);
    }

    .contact-link {
        font-family: var(--font-mono);
        font-size: 14px;
        color: var(--color-warm-cream);
        text-decoration: none;
        display: block;
        margin-bottom: 1rem;
        opacity: 0.6;
        transition: opacity 0.3s ease;
    }

    .contact-link:hover {
        opacity: 1;
    }

    .contact-gifting {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: rgba(245, 237, 216, 0.4);
        margin-top: 3rem;
        letter-spacing: 0.05em;
        line-height: 1.5;
    }

    .nav-link {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: rgba(245, 237, 216, 0.5);
        text-decoration: none;
        letter-spacing: 0.05em;
        margin-top: 3rem;
        display: inline-block;
        transition: color 0.3s ease;
        align-self: flex-start;
    }

    .nav-link:hover {
        color: var(--color-warm-cream);
    }
</style>
