---
import '../styles/tokens.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact | OurOrigin</title>
    <!-- Google Fonts with display=swap as explicitly requested -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&family=Cormorant+Garamond:wght@300;400;500&family=DM+Mono:ital,wght@0,300;0,400;0,500&display=swap" rel="stylesheet">
    <style>
        body, html {
            margin: 0;
            padding: 0;
            background-color: var(--color-forest-deep);
            color: var(--color-warm-cream);
            height: 100%;
        }
        .page-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20vh 5vw;
            display: flex;
            flex-direction: column;
        }
        h1 {
            font-family: 'Cinzel', serif;
            font-size: 2.5rem;
            margin: 0 0 1rem 0;
            font-weight: 400;
        }
        .intro {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.2rem;
            line-height: 1.6;
            margin: 0 0 3rem 0;
            opacity: 0.8;
        }
        .form-group {
            margin-bottom: 2rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        label {
            font-family: 'DM Mono', monospace;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            opacity: 0.8;
        }
        input, textarea {
            background: transparent;
            border: none;
            border-bottom: 1px solid rgba(244, 241, 235, 0.3);
            color: var(--color-warm-cream);
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.2rem;
            padding: 0.5rem 0;
            outline: none;
            transition: border-color 0.3s ease;
        }
        input:focus, textarea:focus {
            border-bottom-color: var(--color-warm-cream);
        }
        textarea {
            resize: vertical;
            min-height: 100px;
        }
        .submit-btn {
            background: var(--color-warm-cream);
            color: var(--color-forest-deep);
            border: none;
            font-family: 'DM Mono', monospace;
            font-size: 1rem;
            padding: 1rem;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-top: 1rem;
            transition: opacity 0.3s ease;
        }
        .submit-btn:hover {
            opacity: 0.9;
        }
        .fallback {
            margin-top: 3rem;
            font-family: 'DM Mono', monospace;
            font-size: 0.8rem;
            opacity: 0.6;
            text-align: center;
        }
        .fallback a {
            color: var(--color-warm-cream);
        }
        .nav-link {
            font-family: 'DM Mono', monospace;
            color: var(--color-warm-cream);
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-top: 4rem;
            display: inline-block;
            border-bottom: 1px solid rgba(244, 241, 235, 0.3);
            padding-bottom: 0.2rem;
            transition: border-color 0.3s ease;
            align-self: flex-start;
        }
        .nav-link:hover {
            border-bottom-color: var(--color-warm-cream);
        }
        .contact-details p {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            line-height: 1.6;
            margin: 0 0 1.5rem 0;
            opacity: 0.9;
        }
        .contact-details strong {
            font-family: 'DM Mono', monospace;
            font-size: 1.2rem;
            font-weight: normal;
        }
        .fssai-footer {
            margin-top: auto;
            padding-top: 4rem;
            font-family: 'DM Mono', monospace;
            font-size: 0.75rem;
            color: var(--color-warm-cream);
            opacity: 0.4;
            text-align: left;
        }
    </style>
</head>
<body>
    <div class="page-container">
        <h1>Reach us directly.</h1>
        
        <div class="contact-details">
            <p><strong>+91 96455 55668</strong><br>This is the fastest way to reach us. We respond personally, not through a bot.</p>
            <p>ourorigin.in@gmail.com</p>
            <p>@ourorigin.in on Instagram</p>
            <p>We are based in Thiruvananthapuram, Kerala. We source, we pack, we ship. If you have a question about where something comes from, we'll tell you everything we know.</p>
        </div>
        
        <a href="/" class="nav-link">Return to the Matrix</a>
        
        <div class="fssai-footer">FSSAI Reg. No. 21326135000354</div>
    </div>
</body>
</html>
