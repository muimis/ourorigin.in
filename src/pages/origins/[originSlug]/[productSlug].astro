---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../components/BaseLayout.astro';
import DepthExperience from '../../../components/DepthExperience.astro';
import Carousel from '../../../components/Carousel.astro';
import Ledger from '../../../components/Ledger.astro';
import AllYieldsPanel from '../../../components/AllYieldsPanel.astro';

// 1. Generate paths for all products
export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => {
    const originId = typeof product.data.originSlug === 'object' 
      ? product.data.originSlug.id 
      : product.data.originSlug;
      
    return {
      params: { 
        originSlug: originId, 
        productSlug: product.id 
      },
      props: { product }
    };
  });
}

// 2. Fetch the corresponding origin data for the matched product
const { product } = Astro.props;
const originId = typeof product.data.originSlug === 'object' 
  ? product.data.originSlug.id 
  : product.data.originSlug;
const origin = await getEntry('origins', originId);

if (!origin) {
  throw new Error(`Origin not found for product: ${product.id}`);
}

const ogImageUrl = origin.data.images?.specimen?.endsWith('.webp') 
  ? 'https://ourorigin.in/og-image.jpg' 
  : `https://ourorigin.in${origin.data.images?.specimen || '/og-image.jpg'}`;

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.data.name,
  "description": product.data.specimenCopy,
  "brand": {
    "@type": "Brand",
    "name": "OurOrigin"
  },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "INR",
    "lowPrice": product.data.sizes[0]?.priceINR || 0,
    "highPrice": product.data.sizes[product.data.sizes.length - 1]?.priceINR || 0,
    "offerCount": product.data.sizes.length,
    "availability": "https://schema.org/InStock"
  },
  "additionalProperty": {
    "@type": "PropertyValue",
    "name": "Origin",
    "value": `${origin.data.name}, ${origin.data.bioregion}`
  }
});
---

<BaseLayout
  title={`${product.data.name} from ${origin.data.name} — OurOrigin`}
  description={`${product.data.name} from ${origin.data.name} — ${origin.data.elevation}, ${origin.data.bioregion}. OurOrigin.`}
  canonicalPath={`/origins/${origin.id}/${product.id}`}
  ogTitle={`${product.data.name} from ${origin.data.name} — OurOrigin`}
  ogDescription={product.data.specimenCopy?.slice(0, 160)}
  ogImage={ogImageUrl}
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={structuredData} />
    </Fragment>

    <a href="#main-content" class="skip-nav">Skip to content</a>

    <main id="main-content">
      <h1 class="sr-only">{product.data.name} from {origin.data.name} — OurOrigin</h1>
      <DepthExperience origin={origin} product={product} />
      <AllYieldsPanel />
    </main>
    <Ledger />
</BaseLayout>

<style>
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
    }
    .skip-nav {
        position: absolute;
        top: -100%;
        left: 0;
        background: var(--color-warm-cream);
        color: var(--color-forest-deep);
        padding: 0.5rem 1rem;
        font-family: var(--font-evidence);
        font-size: 0.875rem;
        z-index: 9999;
        text-decoration: none;
    }
    .skip-nav:focus {
        top: 0;
    }
</style>
