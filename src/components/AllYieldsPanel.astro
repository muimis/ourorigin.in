    color: var(--color-gold);
    white-space: pre;
  }
  
  .yield-action-btn {
    font-family: 'Cormorant Garamond', serif;
    font-size: 12px;
    font-style: italic;
    color: rgba(245, 237, 216, 0.6);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .yield-action-btn:hover {
    color: var(--color-warm-cream);
  }
</style>
