  }
  .yield-group h3 {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    color: rgba(245, 237, 216, 0.5);
    margin: 0 0 1rem 0;
    font-weight: 400;
  }
  
  .yield-products {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  
  .yield-product-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }
  
  .yield-product-name {
    font-family: 'Cormorant Garamond', serif;
