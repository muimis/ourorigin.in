---
import { getCollection } from 'astro:content';

const products = await getCollection('products');
const origins = await getCollection('origins');
const originMap = new Map();
origins.forEach(o => {
  originMap.set(o.id, {
    name: o.data.name,
    elevation: o.data.elevation
  });
});

const groupedProducts: Record<string, any> = {};

// We want to sort origins by elevation, same as LivingMatrix.
const orderedSlugs = ['nilgiris', 'idukki', 'wayanad', 'malabar-coast', 'thiruvananthapuram'];
const orderedOriginIds = orderedSlugs.map(slug => origins.find(o => o.data.slug === slug)?.id).filter(Boolean);

orderedOriginIds.forEach(originId => {
  if(originId) {
    groupedProducts[originId] = {
      originInfo: originMap.get(originId),
      products: []
    };
  }
});

products.forEach(p => {
  const originId = typeof p.data.originSlug === 'object' ? p.data.originSlug.id : p.data.originSlug;
  if (groupedProducts[originId]) {
    groupedProducts[originId].products.push(p);
  }
});

// Helper to get highest elevation from string like "100m - 1500m"
function getHighestElevation(elevationString: string) {
  if (!elevationString) return '';
  const cleanStr = elevationString.replace(/,/g, '');
  const matches = cleanStr.match(/\d+/g);
  if (matches) {
    return Math.max(...matches.map(Number));
  }
  return cleanStr.replace(/[^0-9]/g, '');
}
---

<!-- Trigger -->
<button id="all-yields-trigger" class="all-yields-trigger" aria-label="Open All Yields">All yields</button>

<!-- Slide-in Panel -->
<div id="all-yields-panel" class="all-yields-panel hidden" aria-hidden="true">
  <div class="yields-header">
    <h2>ALL YIELDS</h2>
    <button id="all-yields-close" aria-label="Close all yields panel">✕</button>
  </div>
  <div class="yields-content">
    {orderedOriginIds.map(originId => {
      if(!originId) return null;
      const group = groupedProducts[originId];
      if (!group || group.products.length === 0) return null;
      
      const elevation = getHighestElevation(group.originInfo.elevation);
      
      return (
        <div class="yield-group">
          <h3>{group.originInfo.name.toUpperCase()} &nbsp;·&nbsp; {elevation}M</h3>
          <div class="yield-products">
            {group.products.sort((a, b) => a.data.name.localeCompare(b.data.name)).map((product) => (
              <div class="yield-product-row">
                <div class="yield-product-name">{product.data.name}</div>
                <div class="yield-product-sizes">
                  {product.data.sizes.map((sizeObj) => (
                    <div class="yield-size-row">
                      <div class="yield-size-price">
                        {sizeObj.label} &nbsp;₹{sizeObj.priceINR}
                      </div>
                      {product.data.isAnchorProduct ? (
                        <a href={`/origins/${originId}/${product.id}`} class="yield-action-btn">Enter</a>
                      ) : (
                        <button class="yield-action-btn add-to-ledger-btn" data-product={JSON.stringify({
                          id: product.id,
                          name: product.data.name,
                          origin: group.originInfo.name,
                          originId: originId,
                          size: sizeObj.label,
                          price: sizeObj.priceINR
                        })}>Add</button>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</div>

<div id="all-yields-backdrop" class="yields-backdrop hidden"></div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const trigger = document.getElementById('all-yields-trigger');
    const panel = document.getElementById('all-yields-panel');
    const closeBtn = document.getElementById('all-yields-close');
    const backdrop = document.getElementById('all-yields-backdrop');

    const openPanel = () => {
      panel.classList.remove('hidden');
      void panel.offsetWidth;
      panel.classList.add('open');
      backdrop.classList.remove('hidden');
      void backdrop.offsetWidth;
      backdrop.classList.add('visible');
      panel.setAttribute('aria-hidden', 'false');
    };

    const closePanel = () => {
      panel.classList.remove('open');
      backdrop.classList.remove('visible');
      panel.setAttribute('aria-hidden', 'true');
      setTimeout(() => {
        panel.classList.add('hidden');
        backdrop.classList.add('hidden');
      }, 400); 
    };

    if (trigger) trigger.addEventListener('click', openPanel);
    if (closeBtn) closeBtn.addEventListener('click', closePanel);
    if (backdrop) backdrop.addEventListener('click', closePanel);
    
    // Wiring Add buttons
    document.querySelectorAll('.add-to-ledger-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const productData = JSON.parse(btn.getAttribute('data-product') || '{}');
        
        const item = {
          id: productData.id + '-' + productData.size,
          productId: productData.id,
          name: productData.name,
          origin: productData.origin,
          originId: productData.originId,
          size: productData.size,
          price: productData.price,
          quantity: 1
        };
        
        window.dispatchEvent(new CustomEvent('add-to-ledger', { detail: item }));
      });
    });
  });
</script>

<style>
  .all-yields-trigger {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 900;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: rgba(245, 237, 216, 0.5);
    background: transparent;
    border: none;
    cursor: pointer;
    text-transform: none;
    padding: 0;
    transition: color 0.3s ease;
  }
  .all-yields-trigger:hover {
    color: rgba(245, 237, 216, 1);
  }

  .all-yields-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 360px;
    height: 100vh;
    height: 100dvh;
    background-color: var(--color-forest-deep);
    border-left: 1px solid rgba(245, 237, 216, 0.1);
    z-index: 1100;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    color: var(--color-warm-cream);
  }
  
  @media (max-width: 768px) {
    .all-yields-panel {
      max-width: 70vw;
    }
  }
  
  .all-yields-panel.open {
    transform: translateX(0);
  }

  .yields-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(12, 21, 9, 0.6);
    backdrop-filter: blur(4px);
    z-index: 1050;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .yields-backdrop.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .yields-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 1.5rem;
    border-bottom: 1px solid rgba(245, 237, 216, 0.1);
  }
  .yields-header h2 {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: rgba(245, 237, 216, 0.4);
    font-weight: 400;
    margin: 0;
  }
  .yields-header button {
    background: none;
    border: none;
    color: var(--color-warm-cream);
    font-size: 1rem;
    cursor: pointer;
    opacity: 0.6;
    transition: opacity 0.3s;
    padding: 0;
  }
  .yields-header button:hover {
    opacity: 1;
  }

  .yields-content {
    flex: 1;
