---
// src/components/Footer.astro
import { WHATSAPP_NUMBER, EMAIL_ADDRESS, FSSAI_NUMBER } from '../utils/constants';

const whatsappLink = `https://wa.me/${WHATSAPP_NUMBER}`;
const formattedPhone = '+91 96455 55668';
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-nav">
      <a href="/why" class="footer-link">Why This Exists</a>
      <a href="/observations" class="footer-link">Observations</a>
      <a href="/contact" class="footer-link">Contact</a>
      <a href="/terms" class="footer-link">Terms & Conditions</a>
      <a href="/privacy" class="footer-link">Privacy Policy</a>
    </div>

    <div class="footer-contact">
      <a href={whatsappLink} class="footer-link" target="_blank" rel="noopener noreferrer">{formattedPhone}</a>
      <a href={`mailto:${EMAIL_ADDRESS}`} class="footer-link">{EMAIL_ADDRESS}</a>
    </div>

    <div class="footer-legal">
      <span class="footer-fssai">FSSAI Reg. No. {FSSAI_NUMBER}</span>
      <span class="footer-copy">&copy; {new Date().getFullYear()} OurOrigin</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(245, 237, 216, 0.08);
    padding: 4rem clamp(1.5rem, 5vw, 4rem) 3rem;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
    text-align: center;
  }

  .footer-nav {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245, 237, 216, 0.5);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-link:hover {
    color: var(--color-warm-cream);
  }

  .footer-contact {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-legal {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    color: rgba(245, 237, 216, 0.25);
  }

  @media (max-width: 600px) {
    .footer-nav,
    .footer-contact {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
