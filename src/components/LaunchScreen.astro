---
// LaunchScreen.astro
import OriginMark from './OriginMark.astro';
---
<div id="launch-screen" class="launch-screen">
  <div id="launch-bg" style="position: absolute; inset: 0; background-color: #000000; z-index: -1;"></div>
  <OriginMark variant="primary" size={120} id="launch-mark" animate={true} />
  <div class="launch-text-container">
    <p class="launch-text-2">from the source...</p>
  </div>
</div>

<script is:inline>
  // Execute immediately during HTML parsing to prevent FOUC
  if (sessionStorage.getItem('ourorigin_visited')) {
    const ls = document.getElementById('launch-screen');
    if (ls) ls.style.display = 'none';
  }
</script>

<style>
  .launch-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background-color: transparent;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    pointer-events: auto;
    transition: opacity 0.7s ease, background-color 0.7s ease;
  }
  .launch-screen.hidden {
    display: none !important;
  }
  .launch-screen.fade-out {
    opacity: 0;
  }
  
  .launch-text-container {
    position: absolute;
    bottom: 25vh;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    align-items: center;
  }

  .launch-text-2 {
    margin: 0;
    font-family: var(--font-narrative);
    font-size: 20px;
    font-style: italic;
    letter-spacing: 0.15em;
    color: var(--color-warm-cream);
    opacity: 0;
    will-change: opacity;
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const hasVisited = sessionStorage.getItem('ourorigin_visited');
    const launchScreen = document.getElementById('launch-screen');
    
    if (!hasVisited && launchScreen) {
      const text2 = document.querySelector('.launch-text-2');
      const mark = document.getElementById('origin-mark-launch-mark');
      
      // Trigger SVG draw animation (takes ~1.4s)
      document.dispatchEvent(new CustomEvent('play-origin-mark-entrance'));
      
      const tl = gsap.timeline({
        onComplete: () => {
          launchScreen.style.pointerEvents = 'none';
          launchScreen.style.opacity = '0';
          launchScreen.classList.add('fade-out');
          
          sessionStorage.setItem('ourorigin_visited', 'true');
          window.dispatchEvent(new Event('launch-sequence-complete'));
          
          setTimeout(() => {
            launchScreen.classList.add('hidden');
          }, 700); 
        }
      });
      
      const launchBg = document.getElementById('launch-bg');
      
      // Scene 1: Mark draws (0 to 1.4s) - handled internally by play-origin-mark-entrance
      
      // Scene 2: At 1.4s, text appears and background fades to green simultaneously (no flicker)
      tl.to(launchBg, { backgroundColor: 'var(--color-forest-deep)', duration: 0.3, ease: "power2.inOut", delay: 0.4 })
        .to(text2, { opacity: 0.9, duration: 0.3, ease: "power2.out" }, "<");
        
      // Scene 3: Text fades out quickly
      tl.to(text2, { opacity: 0, duration: 0.2, ease: "power2.inOut", delay: 0.2 });
      
      // Scene 4: Matrix Reveal
      // launchBg fades to transparent instantly to reveal matrix without lag.
      tl.addLabel("fly");
      
      tl.to(launchBg, { opacity: 0, duration: 0.2 }, "fly");
      
      tl.to(mark, {
        scale: 0,
        opacity: 0,
        transformOrigin: "50% 50%",
        duration: 0.2,
        ease: "power2.inOut"
      }, "fly");
      
      // Scene 5: Landed
      tl.call(() => {
        mark.style.display = 'none';
        window.dispatchEvent(new Event('origin-marks-arrived'));
      });
        
    } else if (launchScreen) {
      launchScreen.classList.add('hidden');
      // Fire immediately if already visited
      window.dispatchEvent(new Event('launch-sequence-complete'));
    }
  });
</script>
