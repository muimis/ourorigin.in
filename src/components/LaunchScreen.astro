---
// LaunchScreen.astro
import OriginMark from './OriginMark.astro';
---
<div id="launch-screen" class="launch-screen">
  <OriginMark variant="primary" size={120} id="launch-mark" animate={false} />
  <div class="launch-text-container">
    <p class="launch-text-1">From the Western Ghats.</p>
    <p class="launch-text-2">FROM THE SOURCE.</p>
  </div>
</div>

<script is:inline>
  // Execute immediately during HTML parsing to prevent FOUC
  if (sessionStorage.getItem('ourorigin_visited')) {
    const ls = document.getElementById('launch-screen');
    if (ls) ls.style.display = 'none';
  }
</script>

<style>
  .launch-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background-color: #000000; /* The Void */
    z-index: 9999;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    pointer-events: auto;
    transition: opacity 0.7s ease, background-color 0.7s ease;
  }
  .launch-screen.hidden {
    display: none !important;
  }
  .launch-screen.fade-out {
    opacity: 0;
  }
  
  .launch-text-container {
    position: absolute;
    bottom: 25vh;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    align-items: center;
  }
  
  .launch-text-1 {
    margin: 0;
    font-family: var(--font-narrative);
    font-style: italic;
    font-size: 16px;
    letter-spacing: 0.12em;
    color: var(--color-warm-cream);
    opacity: 0;
    will-change: opacity;
  }

  .launch-text-2 {
    margin: 0;
    font-family: var(--font-institutional);
    font-size: 12px;
    letter-spacing: 0.4em;
    color: var(--color-warm-cream);
    opacity: 0;
    will-change: opacity;
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const hasVisited = sessionStorage.getItem('ourorigin_visited');
    const launchScreen = document.getElementById('launch-screen');
    
    if (!hasVisited && launchScreen) {
      const text1 = document.querySelector('.launch-text-1');
      const text2 = document.querySelector('.launch-text-2');
      
      // Mark takes ~1.8s, but since it's static now, we just proceed.
      // document.dispatchEvent(new CustomEvent('play-origin-mark-entrance'));
      
      const tl = gsap.timeline({
        onComplete: () => {
          setTimeout(() => {
            launchScreen.style.pointerEvents = 'none';
            launchScreen.style.backgroundColor = 'transparent';
            launchScreen.classList.add('fade-out');
            
            sessionStorage.setItem('ourorigin_visited', 'true');
            window.dispatchEvent(new Event('launch-sequence-complete'));
            
            setTimeout(() => {
              launchScreen.classList.add('hidden');
            }, 700); 
          }, 300); // reduced hold time so total sequence is < 4s
        }
      });
      
      // Mark takes ~1.8s. Line 1 at 0.3s after mark = 2.1s
      tl.to(text1, { opacity: 1, duration: 0.6, ease: "power2.out", delay: 2.1 })
        // Line 2 at 0.8s after Line 1 starts => absolute time 2.9s => offset relative to previous is -0.6 + 0.8 = +0.2s
        .to(text2, { opacity: 1, duration: 0.6, ease: "power2.out" }, "2.9");
        
    } else if (launchScreen) {
      launchScreen.classList.add('hidden');
      // Fire immediately if already visited
      window.dispatchEvent(new Event('launch-sequence-complete'));
    }
  });
</script>
