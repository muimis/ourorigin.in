---
// LaunchScreen.astro
import OriginMark from './OriginMark.astro';
---
<div id="launch-screen" class="launch-screen">
  <div id="launch-bg" style="position: absolute; inset: 0; background-color: #000000; z-index: -1;"></div>
  <OriginMark variant="primary" size={120} id="launch-mark" animate={true} />
  <div class="launch-text-container">
    <p class="launch-text-2">from the source...</p>
  </div>
</div>

<script is:inline>
  // Execute immediately during HTML parsing to prevent FOUC
  if (sessionStorage.getItem('ourorigin_visited')) {
    const ls = document.getElementById('launch-screen');
    if (ls) ls.style.display = 'none';
  }
</script>

<style>
  .launch-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background-color: transparent;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    pointer-events: auto;
    transition: opacity 0.7s ease, background-color 0.7s ease;
  }
  .launch-screen.hidden {
    display: none !important;
  }
  .launch-screen.fade-out {
    opacity: 0;
  }
  
  .launch-text-container {
    position: absolute;
    bottom: 25vh;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    align-items: center;
  }

  .launch-text-2 {
    margin: 0;
    font-family: var(--font-narrative);
    font-size: 20px;
    font-style: italic;
    letter-spacing: 0.15em;
    color: var(--color-warm-cream);
    opacity: 0;
    will-change: opacity;
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const hasVisited = sessionStorage.getItem('ourorigin_visited');
    const launchScreen = document.getElementById('launch-screen');
    
    if (!hasVisited && launchScreen) {
      const text2 = document.querySelector('.launch-text-2');
      const mark = document.getElementById('origin-mark-launch-mark');
      
      // Trigger SVG draw animation (takes ~1.4s)
      document.dispatchEvent(new CustomEvent('play-origin-mark-entrance'));
      
      const tl = gsap.timeline({
        onComplete: () => {
          launchScreen.style.pointerEvents = 'none';
          launchScreen.style.opacity = '0';
          launchScreen.classList.add('fade-out');
          
          sessionStorage.setItem('ourorigin_visited', 'true');
          window.dispatchEvent(new Event('launch-sequence-complete'));
          
          setTimeout(() => {
            launchScreen.classList.add('hidden');
          }, 700); 
        }
      });
      
      const launchBg = document.getElementById('launch-bg');
      
      // Scene 1: Mark draws (0 to 1.4s) - handled internally by play-origin-mark-entrance
      
      // Scene 2: At 1.4s, text appears and background fades to green simultaneously (no flicker)
      tl.to(launchBg, { backgroundColor: 'var(--color-forest-deep)', duration: 0.8, ease: "power2.inOut", delay: 1.4 })
        .to(text2, { opacity: 0.9, duration: 0.8, ease: "power2.out" }, "<");
        
      // Scene 3: Text fades out quickly
      tl.to(text2, { opacity: 0, duration: 0.4, ease: "power2.inOut", delay: 0.4 });
      
      // Scene 4: Mark flies to top plate border, shrinks, becomes golden. 
      // launchBg fades to transparent revealing matrix instantly.
      tl.addLabel("fly");
      
      tl.to(launchBg, { opacity: 0, duration: 1.0 }, "fly");
      
      const allMarks = Array.from(document.querySelectorAll('.matrix-band .plate-origin-mark svg'));
      if (allMarks.length > 0) {
        const targetSvg = allMarks[0];
        const targetRect = targetSvg.getBoundingClientRect();
        const markRect = mark.getBoundingClientRect();
        
        const scale = targetRect.width / markRect.width;
        const deltaX = (targetRect.left + targetRect.width/2) - (markRect.left + markRect.width/2);
        const deltaY = (targetRect.top + targetRect.height/2) - (markRect.top + markRect.height/2);
        
        tl.to(mark, {
          x: deltaX,
          y: deltaY,
          scale: scale,
          transformOrigin: "50% 50%",
          duration: 1.0,
          ease: "power3.inOut"
        }, "fly");
        
        tl.to(mark.querySelectorAll('circle, g, line'), { stroke: 'var(--color-gold)', duration: 1.0 }, "fly");
        tl.to(mark.querySelectorAll('.om-dot'), { fill: 'var(--color-gold)', duration: 1.0 }, "fly");
      } else {
        // Fallback if matrix is missing
        tl.to(mark, { scale: 0.2, x: "-40vw", y: "-40vh", opacity: 0, duration: 1.0, ease: "power3.inOut" }, "fly");
      }
      
      // Scene 5: Landed
      tl.call(() => {
        window.dispatchEvent(new Event('origin-marks-arrived'));
      });
        
    } else if (launchScreen) {
      launchScreen.classList.add('hidden');
      // Fire immediately if already visited
      window.dispatchEvent(new Event('launch-sequence-complete'));
    }
  });
</script>
