---
// LaunchScreen.astro
---
<div id="launch-screen" class="launch-screen hidden">
  <div class="launch-text-container">
    <div class="launch-item">From the <span class="cream">Source.</span></div>
    <div class="launch-item">From the <span class="gold">Western Ghats.</span></div>
    <div class="launch-item">From the <span class="cream">Nilgiris.</span></div>
    <div class="launch-item">From <span class="cream">Idukki.</span></div>
    <div class="launch-item">From <span class="cream">Wayanad.</span></div>
    <div class="launch-item">From <span class="cream">Thiruvananthapuram.</span></div>
    <div class="launch-item">From the <span class="cream">Malabar Coast.</span></div>
  </div>
</div>

<style>
  .launch-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    background-color: #000;
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    pointer-events: auto; /* Block clicks behind it during initial load */
    transition: opacity 1s ease;
  }
  .launch-screen.hidden {
    display: none;
  }
  .launch-screen.fade-out {
    opacity: 0;
  }
  .launch-text-container {
    position: relative;
    width: 100%;
    height: 3rem; /* Fixed height to allow absolute centering of items */
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .launch-item {
    position: absolute;
    font-family: 'Cormorant Garamond', serif;
    /* Scale down for Thiruvananthapuram to fit mobile */
    font-size: clamp(1.1rem, 4vw, 2.2rem);
    color: var(--color-warm-cream);
    opacity: 0;
    text-align: center;
    white-space: nowrap;
  }
  .gold {
    color: var(--color-gold);
  }
  .cream {
    color: var(--color-warm-cream);
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    // Check if this is the first visit
    const hasVisited = sessionStorage.getItem('ourorigin_visited');
    const launchScreen = document.getElementById('launch-screen');
    
    if (!hasVisited && launchScreen) {
      launchScreen.classList.remove('hidden');
      
      const items = gsap.utils.toArray('.launch-item');
      
      // Set initial positions below the center
      gsap.set(items, { y: 20, opacity: 0 });
      
      const tl = gsap.timeline({
        onComplete: () => {
          launchScreen.style.pointerEvents = 'none'; // Allow clicks to pass through once fading
          launchScreen.classList.add('fade-out');
          setTimeout(() => {
            launchScreen.classList.add('hidden');
            sessionStorage.setItem('ourorigin_visited', 'true');
          }, 1000); // Wait for CSS fade out
        }
      });
      
      const durationIn = 0.3;
      const hold = 0.4;
      const durationOut = 0.3;
      
      items.forEach((item, i) => {
        // First item starts immediately, subsequent items start exactly as previous item animates out
        const startTime = i === 0 ? 0 : `-=${durationOut}`;
        
        tl.to(item, { y: 0, opacity: 1, duration: durationIn, ease: "power2.out" }, startTime)
          .to(item, { y: -20, opacity: 0, duration: durationOut, ease: "power2.in" }, `+=${hold}`);
      });
        
    } else if (launchScreen) {
      launchScreen.classList.add('hidden');
    }
  });
</script>
