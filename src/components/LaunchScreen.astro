---
// LaunchScreen.astro
import OriginMark from './OriginMark.astro';
---
<div id="launch-screen" class="launch-screen hidden">
  <OriginMark variant="primary" size={120} id="launch-mark" animate={true} />
  <div class="launch-text"><span class="cream">From the Source.</span></div>
</div>

<style>
  .launch-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    background-color: #000000; /* The Void */
    z-index: 9999;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    pointer-events: auto;
    transition: opacity 0.7s ease, background-color 0.7s ease;
  }
  .launch-screen.hidden {
    display: none;
  }
  .launch-screen.fade-out {
    opacity: 0;
  }
  


  .launch-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    font-style: italic;
    color: var(--color-warm-cream);
    letter-spacing: 0.12em;
    opacity: 0;
    margin-top: 1.5rem;
    will-change: opacity;
  }
  
  .cream {
    color: var(--color-warm-cream);
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const hasVisited = sessionStorage.getItem('ourorigin_visited');
    const launchScreen = document.getElementById('launch-screen');
    
    if (!hasVisited && launchScreen) {
      launchScreen.classList.remove('hidden');
      
      const text = document.querySelector('.launch-text');
      
      // The mark draws on automatically via its internal logic (takes ~1.8s to finish)
      // So we wait for 1.8s + 0.5s = 2.3s total before fading in text.
      const tl = gsap.timeline({
        delay: 2.3, // Delay matching mark completion + 0.5s
        onComplete: () => {
          // Hold the text for 1.5s
          setTimeout(() => {
            launchScreen.style.pointerEvents = 'none';
            launchScreen.style.backgroundColor = 'transparent';
            launchScreen.classList.add('fade-out');
            
            sessionStorage.setItem('ourorigin_visited', 'true');
            window.dispatchEvent(new Event('launch-sequence-complete'));
            
            setTimeout(() => {
              launchScreen.classList.add('hidden');
            }, 700); // Wait for transition out
          }, 1500); 
        }
      });
      
      // Fade in text over 600ms
      tl.to(text, { opacity: 1, duration: 0.6, ease: "power2.out" });
        
    } else if (launchScreen) {
      launchScreen.classList.add('hidden');
      // Fire immediately if already visited
      window.dispatchEvent(new Event('launch-sequence-complete'));
    }
  });
</script>
