---
// LaunchScreen.astro
---
<div id="launch-screen" class="launch-screen hidden">
  <div class="source-glow"></div>
  <div class="launch-text-container">
    <div class="launch-text"><i>From the</i> <span class="cream">Source.</span></div>
  </div>
</div>

<style>
  .launch-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    background-color: #000000; /* The Void */
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    pointer-events: auto;
    transition: opacity 1.5s ease, background-color 1.5s ease;
  }
  .launch-screen.hidden {
    display: none;
  }
  .launch-screen.fade-out {
    opacity: 0;
  }
  
  .source-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.8);
    width: 90vw;
    height: 90vw;
    max-width: 800px;
    max-height: 800px;
    background: radial-gradient(circle, rgba(166, 124, 60, 0.15) 0%, rgba(166, 124, 60, 0.05) 40%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    opacity: 0;
    will-change: transform, opacity;
  }

  .launch-text-container {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
  }
  .launch-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 6vw, 3.2rem); /* Slightly larger again for the void */
    color: var(--color-warm-cream);
    letter-spacing: 0.04em;
    opacity: 0;
    will-change: transform, opacity, filter;
  }
  .launch-text i {
    opacity: 0.7;
    font-weight: 300;
  }
  .cream {
    color: var(--color-warm-cream);
    text-shadow: 0 0 15px rgba(245, 237, 216, 0.25);
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const hasVisited = sessionStorage.getItem('ourorigin_visited');
    const launchScreen = document.getElementById('launch-screen');
    
    if (!hasVisited && launchScreen) {
      launchScreen.classList.remove('hidden');
      
      const text = document.querySelector('.launch-text');
      const glow = document.querySelector('.source-glow');
      
      // Starting positions (deep in the void)
      gsap.set(text, { y: 15, opacity: 0, filter: 'blur(8px)', scale: 0.95 });
      gsap.set(glow, { opacity: 0, scale: 0.7 });
      
      const tl = gsap.timeline({
        onComplete: () => {
          launchScreen.style.pointerEvents = 'none';
          
          // Fade to transparent (revealing the matrix beneath)
          launchScreen.style.backgroundColor = 'transparent';
          launchScreen.classList.add('fade-out');
          
          setTimeout(() => {
            launchScreen.classList.add('hidden');
            sessionStorage.setItem('ourorigin_visited', 'true');
            // Allow LivingMatrix orchestrator to begin its sequence
            window.dispatchEvent(new Event('launch-sequence-complete'));
          }, 1500); 
        }
      });
      
      // 1. The Glow breathes in
      tl.to(glow, { opacity: 1, scale: 1.1, duration: 3.0, ease: "power1.out" }, 0);
      
      // 2. The Text emerges from the glow, scaling up slowly towards the viewer
      tl.to(text, { y: 0, opacity: 1, filter: 'blur(0px)', scale: 1, duration: 1.8, ease: "power2.out" }, 0.5)
        // 3. The Text holds, then drifts up and dissolves
        .to(text, { y: -15, opacity: 0, filter: 'blur(8px)', scale: 1.05, duration: 1.2, ease: "power2.in" }, "+=1.2");
        
      // 4. The Glow breathes out as the text leaves
      tl.to(glow, { opacity: 0, scale: 1.3, duration: 1.5, ease: "power1.in" }, "-=1.0");
        
    } else if (launchScreen) {
      launchScreen.classList.add('hidden');
      // Fire immediately if already visited
      window.dispatchEvent(new Event('launch-sequence-complete'));
    }
  });
</script>
