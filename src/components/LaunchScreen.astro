---
// LaunchScreen.astro
import OriginMark from './OriginMark.astro';
---
<div id="launch-screen" class="launch-screen">
  <OriginMark variant="primary" size={120} id="launch-mark" animate={true} />
  <div class="launch-text-container">
    <p class="launch-text-2">from the source...</p>
  </div>
</div>

<script is:inline>
  // Execute immediately during HTML parsing to prevent FOUC
  if (sessionStorage.getItem('ourorigin_visited')) {
    const ls = document.getElementById('launch-screen');
    if (ls) ls.style.display = 'none';
  }
</script>

<style>
  .launch-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background-color: #000000; /* The Void */
    z-index: 9999;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    pointer-events: auto;
    transition: opacity 0.7s ease, background-color 0.7s ease;
  }
  .launch-screen.hidden {
    display: none !important;
  }
  .launch-screen.fade-out {
    opacity: 0;
  }
  
  .launch-text-container {
    position: absolute;
    bottom: 25vh;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    align-items: center;
  }

  .launch-text-2 {
    margin: 0;
    font-family: var(--font-narrative);
    font-size: 20px;
    font-style: italic;
    letter-spacing: 0.15em;
    color: var(--color-warm-cream);
    opacity: 0;
    will-change: opacity;
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const hasVisited = sessionStorage.getItem('ourorigin_visited');
    const launchScreen = document.getElementById('launch-screen');
    
    if (!hasVisited && launchScreen) {
      const text2 = document.querySelector('.launch-text-2');
      const mark = document.getElementById('origin-mark-launch-mark');
      
      // Trigger SVG draw animation (takes ~1.4s)
      document.dispatchEvent(new CustomEvent('play-origin-mark-entrance'));
      
      const tl = gsap.timeline({
        onComplete: () => {
          launchScreen.style.pointerEvents = 'none';
          launchScreen.style.opacity = '0';
          launchScreen.classList.add('fade-out');
          
          // Remove all flying clones
          document.querySelectorAll('[id^="flying-clone-"]').forEach(el => el.remove());
          
          sessionStorage.setItem('ourorigin_visited', 'true');
          window.dispatchEvent(new Event('launch-sequence-complete'));
          
          setTimeout(() => {
            launchScreen.classList.add('hidden');
          }, 700); 
        }
      });
      
      // Scene 1: Mark draws (0 to 1.4s) - handled internally by play-origin-mark-entrance
      
      // Scene 2: At 1.4s, text appears. We NO LONGER fade the background to green here.
      // The background remains black, so the matrix underneath stays hidden until Scene 4.
      tl.to(text2, { opacity: 0.9, duration: 0.8, ease: "power2.out", delay: 1.4 });
        
      // Scene 3: Text fades out quickly
      tl.to(text2, { opacity: 0, duration: 0.4, ease: "power2.inOut", delay: 0.4 });
      
      // Scene 4: Split into 5 and reveal Matrix
      tl.addLabel("split");
      tl.to(launchScreen, { opacity: 0, duration: 1.0 }, "split");
      tl.to(mark, { opacity: 0, duration: 0.1 }, "split");
      
      // We calculate targets on the fly in an onCall or just before animation.
      // Since it's DOMContentLoaded, the matrix plates are rendered.
      const targetMarks = Array.from(document.querySelectorAll('.matrix-band .plate-origin-mark svg'));
      
      if (targetMarks.length > 0) {
        const markRect = mark.getBoundingClientRect();
        const markCenterX = markRect.left + markRect.width / 2;
        const markCenterY = markRect.top + markRect.height / 2;
        
        targetMarks.forEach((targetSvg, i) => {
          const targetRect = targetSvg.getBoundingClientRect();
          const targetCenterX = targetRect.left + targetRect.width / 2;
          const targetCenterY = targetRect.top + targetRect.height / 2;
          
          const clone = mark.cloneNode(true);
          clone.id = `flying-clone-${i}`;
          clone.classList.remove('om-animated', 'gsap-ready');
          clone.style.position = 'absolute';
          clone.style.left = `${markRect.left}px`;
          clone.style.top = `${markRect.top}px`;
          clone.style.margin = '0';
          clone.style.zIndex = '10000';
          clone.style.opacity = '1';
          clone.style.pointerEvents = 'none';
          clone.querySelectorAll('*').forEach(el => el.style.opacity = '1');
          document.body.appendChild(clone);
          
          const scale = targetRect.width / markRect.width;
          const deltaX = targetCenterX - markCenterX;
          const deltaY = targetCenterY - markCenterY;
          
          tl.to(clone, {
            x: deltaX,
            y: deltaY,
            scale: scale,
            transformOrigin: "50% 50%",
            duration: 1.2,
            ease: "power3.inOut"
          }, "split");
          
          // Turn to gold
          tl.to(clone.querySelectorAll('circle, g, line'), { stroke: 'var(--color-gold)', duration: 1.2 }, "split");
          tl.to(clone.querySelectorAll('.om-dot'), { fill: 'var(--color-gold)', duration: 1.2 }, "split");
        });
        
        // Notify LivingMatrix to reveal real marks after animation
        tl.call(() => {
          window.dispatchEvent(new Event('origin-marks-arrived'));
        });
      }
        
        
    } else if (launchScreen) {
      launchScreen.classList.add('hidden');
      // Fire immediately if already visited
      window.dispatchEvent(new Event('launch-sequence-complete'));
    }
  });
</script>
