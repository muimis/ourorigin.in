---
// LaunchScreen.astro
---
<div id="launch-screen" class="launch-screen hidden">
  <div class="launch-text-container">
    <div class="launch-text"><i>From the</i> <span class="cream">Source.</span></div>
  </div>
</div>

<style>
  .launch-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    background-color: var(--color-forest-deep);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    pointer-events: auto;
    transition: opacity 1.5s ease;
  }
  .launch-screen.hidden {
    display: none;
  }
  .launch-screen.fade-out {
    opacity: 0;
  }
  .launch-text-container {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .launch-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.4rem, 5vw, 2.8rem);
    color: var(--color-warm-cream);
    letter-spacing: 0.02em;
    opacity: 0;
    will-change: transform, opacity, filter;
  }
  .launch-text i {
    opacity: 0.8;
  }
  .cream {
    color: var(--color-warm-cream);
    text-shadow: 0 0 10px rgba(245, 237, 216, 0.2);
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const hasVisited = sessionStorage.getItem('ourorigin_visited');
    const launchScreen = document.getElementById('launch-screen');
    
    if (!hasVisited && launchScreen) {
      launchScreen.classList.remove('hidden');
      
      const text = document.querySelector('.launch-text');
      
      gsap.set(text, { y: 20, opacity: 0, filter: 'blur(4px)' });
      
      const tl = gsap.timeline({
        onComplete: () => {
          launchScreen.style.pointerEvents = 'none';
          launchScreen.classList.add('fade-out');
          setTimeout(() => {
            launchScreen.classList.add('hidden');
            sessionStorage.setItem('ourorigin_visited', 'true');
            // Allow LivingMatrix orchestrator to begin its sequence
            window.dispatchEvent(new Event('launch-sequence-complete'));
          }, 1500); 
        }
      });
      
      // Fade in "From the Source."
      tl.to(text, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 1.0, ease: "power2.out" })
        .to(text, { y: -20, opacity: 0, filter: 'blur(4px)', duration: 0.8, ease: "power2.in" }, "+=1.5");
        
    } else if (launchScreen) {
      launchScreen.classList.add('hidden');
      // Fire immediately if already visited
      window.dispatchEvent(new Event('launch-sequence-complete'));
    }
  });
</script>
