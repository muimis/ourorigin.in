---
// src/components/TheIndexLedger.astro
import { getCollection } from 'astro:content';

const yields = await getCollection('products');
const origins = await getCollection('origins');

function parseElevation(elevStr: string) {
  const match = String(elevStr || '').match(/[\d,]+/);
  return match ? parseInt(match[0].replace(/,/g, ''), 10) : 0;
}

const elevationById = Object.fromEntries(
  origins.map(o => [o.data.slug || o.id, parseElevation(o.data.elevation)])
);

function originIdOf(y: any) {
  return typeof y.data.originSlug === 'object' ? y.data.originSlug?.id : y.data.originSlug;
}

// Descend through the Ghats, highest origin first — not the alphabet
const sortedYields = [...yields].sort((a, b) => {
  const elevA = elevationById[originIdOf(a)] ?? 0;
  const elevB = elevationById[originIdOf(b)] ?? 0;
  if (elevB !== elevA) return elevB - elevA;
  return (a.data.name || '').localeCompare(b.data.name || '');
});
---

<section id="archival-index" class="archival-index-section">
  <div class="index-container">
    <div class="index-header" data-reveal>
      <span class="index-tag">[ SOURCING MATRIX ]</span>
      <h2 class="index-title">The Archival Ledger</h2>
      <p class="index-subtitle">COMPLETE DATABASE OF ACTIVE SPECIMENS & HARVEST HISTORIES</p>
    </div>

    <div class="ledger-table-wrapper" data-reveal data-delay="150">
      <div class="ledger-table" role="table" aria-label="Sourcing Ledger Database">
        <!-- Header Row -->
        <div class="ledger-header-row" role="row">
          <span class="col-yield" role="columnheader">NOMENCLATURE</span>
          <span class="col-collective" role="columnheader">PROVENANCE COLLECTIVE</span>
          <span class="col-status" role="columnheader">STATUS / COMPLIANCE</span>
          <span class="col-action" role="columnheader">ACTION</span>
        </div>

        <!-- Body Rows -->
        {sortedYields.map((y) => {
          const originId = typeof y.data.originSlug === 'object' ? y.data.originSlug?.id : y.data.originSlug;
          return (
            <a href={`/origins/${originId}/${y.id}`} class="ledger-row-link" role="row" aria-label={`View details of ${y.data.name}`}>
              <div class="ledger-row">
                <span class="col-yield">
                  <span class="yield-name">{y.data.name}</span>
                  <span class="yield-botanical">{y.data.botanicalName}</span>
                </span>
                <span class="col-collective">{String(originId || '').toUpperCase()} COLLECTIVE</span>
                <span class="col-status">
                  <span class="status-badge">[ PRICE VERIFIED ]</span>
                </span>
                <span class="col-action">
                  <span class="action-btn">[ DESCEND ]</span>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style>
  .archival-index-section {
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    padding: 10vh 8vw;
    border-bottom: 1px solid rgba(245, 237, 216, 0.1);
  }

  .index-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .index-header {
    border-bottom: 1px solid rgba(245, 237, 216, 0.15);
    padding-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    text-align: left;
  }

  .index-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--color-gold);
  }

  .index-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 6rem);
    font-weight: 300;
    margin: 0;
    line-height: 1;
  }

  .index-subtitle {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: rgba(245, 237, 216, 0.4);
    margin: 0;
  }

  /* Table Style */
  .ledger-table-wrapper {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ledger-table {
    display: flex;
    flex-direction: column;
    width: 100%;
    min-width: 800px;
    text-align: left;
  }

  .ledger-header-row {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr 0.5fr;
    padding: 1.2rem 1.5rem;
    border-bottom: 1px solid rgba(245, 237, 216, 0.3);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: rgba(245, 237, 216, 0.5);
  }

  .ledger-row-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ledger-row {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr 0.5fr;
    padding: 1.8rem 1.5rem;
    border-bottom: 1px solid rgba(245, 237, 216, 0.1);
    align-items: center;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .ledger-row-link:hover .ledger-row {
    background-color: rgba(245, 237, 216, 0.02);
    border-bottom-color: var(--color-gold);
  }

  .col-yield {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .yield-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--color-warm-cream);
  }

  .yield-botanical {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.9rem;
    color: rgba(245, 237, 216, 0.5);
  }

  .col-collective {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--color-warm-cream);
  }

  .col-status {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
  }

  .status-badge {
    color: var(--color-gold);
    opacity: 0.85;
  }

  .col-action {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-align: right;
  }

  .action-btn {
    color: rgba(245, 237, 216, 0.55);
    transition: color 0.3s ease;
  }

  .ledger-row-link:hover .action-btn {
    color: var(--color-gold);
  }

  /* Responsive column alignments */
  @media (max-width: 768px) {
    .ledger-header-row, .ledger-row {
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .col-status, .col-action {
      display: none;
    }
  }
</style>
