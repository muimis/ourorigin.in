---
import { getCollection } from 'astro:content';

const products = await getCollection('products');
const origins = await getCollection('origins');

// Helper to get the origin name
function getOriginName(originId) {
  const origin = origins.find(o => o.id === originId);
  return origin ? origin.data.name : '';
}

// Helper to get the first sentence
function getFirstSentence(text) {
  if (!text) return '';
  const match = text.match(/[^.!?]+[.!?]+/);
  return match ? match[0].trim() : text;
}
---

<div id="origin-carousel-overlay" class="carousel-overlay hidden">
  <div class="carousel-backdrop" id="carousel-close-backdrop"></div>
  <div class="carousel-container">
    <div class="carousel-header">
      <h2 id="carousel-origin-title" class="carousel-title">Products</h2>
      <button id="carousel-close-btn" class="carousel-close">Close</button>
    </div>
    
    <div class="carousel-track" id="carousel-track">
      <!-- Empty State Card -->
      <div id="carousel-empty-state" class="carousel-card hidden-by-filter" style="justify-content: center; text-align: center; border: 1px dashed rgba(244, 241, 235, 0.3);">
         <p class="observation-line" style="margin: 0; opacity: 0.6;">No companion yields have been documented for this origin yet.</p>
      </div>

      {products.map(product => {
        const isAnchor = product.data.isAnchorProduct;
        const originId = typeof product.data.originSlug === 'object' ? product.data.originSlug.id : product.data.originSlug;
        const originName = getOriginName(originId);
        
        return (
          <div class={`carousel-card ${isAnchor ? 'anchor-card' : 'companion-card'}`} data-origin={originId} data-product-id={product.id}>
            <div class="card-content">
              <h3 class="product-name">{product.data.name}</h3>
              <p class="botanical-name">{product.data.botanicalName}</p>
              
              {isAnchor ? (
                <>
                  <p class="observation-line">{getFirstSentence(product.data.specimenCopy)}</p>
                  <div class="card-footer">
                    <a href={`/origins/${originId}/${product.id}`} class="anchor-cta">Enter this origin</a>
                  </div>
                </>
              ) : (
                <>
                  <p class="specimen-desc">{getFirstSentence(product.data.specimenCopy)}</p>
                  
                  <div class="size-selector">
                    {product.data.sizes.map((size, index) => (
                      <button 
                        class={`size-btn ${index === 0 ? 'selected' : ''}`} 
                        data-size={size.label} 
                        data-price={size.priceINR}>
                        {size.label}
                      </button>
                    ))}
                  </div>
                  
                  <div class="card-footer companion-footer">
                    <p class="price-display">₹<span class="price-val">{product.data.sizes[0].priceINR}</span></p>
                    <button class="add-to-ledger-btn" data-product={JSON.stringify({
                      id: product.id,
                      name: product.data.name,
                      origin: originName,
                      originId: originId
                    })}>Record in Ledger</button>
                  </div>
                </>
              )}
            </div>
          </div>
        )
      })}
    </div>
  </div>
</div>

<style>
  .carousel-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    justify-content: center;
    pointer-events: auto;
    opacity: 1;
    transition: opacity 0.4s ease;
  }
  .carousel-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }
  .carousel-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(12, 21, 9, 0.85); /* forest deep with opacity */
    backdrop-filter: blur(8px);
  }
  .carousel-container {
    position: relative;
    width: 100%;
    z-index: 1;
    display: flex;
    flex-direction: column;
  }
  .carousel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 5vw;
  }
  .carousel-title {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    margin: 0;
    color: var(--color-warm-cream);
  }
  .carousel-close {
    background: none;
    border: none;
    color: var(--color-warm-cream);
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .carousel-track {
    display: flex;
    overflow-x: auto;
    padding: 0 5vw 4rem 5vw;
    gap: 2rem;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  .carousel-track::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }
  .carousel-card {
    flex: 0 0 80vw;
    max-width: 320px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    scroll-snap-align: center;
    display: flex;
    flex-direction: column;
    padding: 2rem;
  }
  .carousel-card.hidden-by-filter {
    display: none;
  }
  .product-name {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    margin: 0 0 0.5rem 0;
  }
  .botanical-name {
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    color: rgba(244, 241, 235, 0.6);
    margin: 0 0 1.5rem 0;
    font-style: italic;
  }
  .observation-line, .specimen-desc {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    line-height: 1.5;
    flex-grow: 1;
    margin: 0 0 2rem 0;
  }
  
  /* Anchor Card Specific */
  .anchor-card {
    justify-content: space-between;
  }
  .anchor-cta {
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    color: var(--color-warm-cream);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--color-warm-cream);
    padding-bottom: 0.2rem;
  }
  
  /* Companion Card Specific */
  .size-selector {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .size-btn {
    background: none;
    border: 1px solid rgba(244, 241, 235, 0.3);
    color: var(--color-warm-cream);
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    padding: 0.4rem 0.8rem;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .size-btn.selected {
    background: var(--color-warm-cream);
    color: var(--color-forest-deep);
  }
  .companion-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .price-display {
    font-family: 'DM Mono', monospace;
    margin: 0;
    font-size: 1rem;
  }
  .add-to-ledger-btn {
    background: var(--color-warm-cream);
    color: var(--color-forest-deep);
    border: none;
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    padding: 0.6rem 1.2rem;
    border-radius: 2px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>

<script>
  // Carousel Logic
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('origin-carousel-overlay');
    const closeBtn = document.getElementById('carousel-close-btn');
    const backdrop = document.getElementById('carousel-close-backdrop');
    const track = document.getElementById('carousel-track');
    const title = document.getElementById('carousel-origin-title');
    const cards = document.querySelectorAll('.carousel-card');
    
    // Listen for custom open event
    window.addEventListener('open-carousel', (e) => {
      const detail = e.detail || {};
      const targetOrigin = detail.originId;
      const excludeAnchor = detail.excludeAnchor || false;
      
      let visibleCount = 0;
      let originName = '';
      
      cards.forEach(card => {
        const isAnchor = card.classList.contains('anchor-card');
        const cardOrigin = card.getAttribute('data-origin');
        
        let shouldShow = true;
        if (targetOrigin && cardOrigin !== targetOrigin) {
          shouldShow = false;
        }
        if (excludeAnchor && isAnchor) {
          shouldShow = false;
        }
        
        if (shouldShow) {
          card.classList.remove('hidden-by-filter');
          visibleCount++;
          // Snag the origin name from the first visible product data if not set
          if (!originName) {
            const btn = card.querySelector('.add-to-ledger-btn');
            if (btn) {
              const data = JSON.parse(btn.getAttribute('data-product'));
              originName = data.origin;
            }
          }
        } else {
          card.classList.add('hidden-by-filter');
        }
      });
      
      const emptyStateCard = document.getElementById('carousel-empty-state');
      if (visibleCount === 0) {
        emptyStateCard.classList.remove('hidden-by-filter');
      } else {
        emptyStateCard.classList.add('hidden-by-filter');
      }
      
      title.textContent = originName ? `${originName} Yields` : 'Products';
      overlay.classList.remove('hidden');
      track.scrollLeft = 0;
    });
    
    const closeCarousel = () => {
      overlay.classList.add('hidden');
    };
    
    closeBtn.addEventListener('click', closeCarousel);
    backdrop.addEventListener('click', closeCarousel);
    
    // Size selector logic
    document.querySelectorAll('.companion-card').forEach(card => {
      const sizeBtns = card.querySelectorAll('.size-btn');
      const priceVal = card.querySelector('.price-val');
      
      sizeBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          sizeBtns.forEach(b => b.classList.remove('selected'));
          btn.classList.add('selected');
          priceVal.textContent = btn.getAttribute('data-price');
        });
      });
      
      // Add to Ledger logic
      const addBtn = card.querySelector('.add-to-ledger-btn');
      
      addBtn.addEventListener('click', () => {
        const productData = JSON.parse(addBtn.getAttribute('data-product'));
        const selectedSizeBtn = card.querySelector('.size-btn.selected');
        const size = selectedSizeBtn ? selectedSizeBtn.getAttribute('data-size') : '';
        const price = selectedSizeBtn ? parseInt(selectedSizeBtn.getAttribute('data-price'), 10) : 0;
        
        const item = {
          id: productData.id + '-' + size,
          productId: productData.id,
          name: productData.name,
          origin: productData.origin,
          originId: productData.originId,
          size: size,
          price: price,
          quantity: 1
        };
        
        // Dispatch to Ledger
        window.dispatchEvent(new CustomEvent('add-to-ledger', { detail: item }));
      });
    });
  });
</script>
