---
// src/components/TheThreshold.astro
---

<div id="threshold-container" class="threshold-container">
  
  <!-- The Breathing SVG Noise Filter -->
  <svg class="noise-svg">
    <filter id="breathing-noise">
      <feTurbulence 
        id="turbulence"
        type="fractalNoise" 
        baseFrequency="0.015" 
        numOctaves="4" 
        seed="1"
        result="noise"
      />
      <!-- We map the noise to a rich, earthy color palette -->
      <feColorMatrix 
        type="matrix" 
        values="
          0.05 0 0 0 0.02
          0.04 0 0 0 0.04
          0.02 0 0 0 0.02
          0 0 0 1 0" 
      />
    </filter>
  </svg>

  <!-- Forest Canopy Background Image (Cinematic Single Held Shot) -->
  <div class="canopy-backdrop"></div>

  <!-- The Physical Canvas that holds the noise -->
  <div class="soil-canvas" id="soil-canvas"></div>
  
  <!-- The Deep Gradient Overlay to create depth -->
  <div class="abyss-overlay" id="abyss-overlay"></div>

  <!-- Editorial Gallery Frame -->
  <div class="gallery-frame">
    <span class="corner-coordinate top-left">NILGIRIS · 11°29'N 76°42'E</span>
    <span class="corner-coordinate top-right">IDUKKI · 9°51'N 77°14'E</span>
    <span class="corner-coordinate bottom-left">WAYANAD · 11°36'N 76°04'E</span>
    <span class="corner-coordinate bottom-right">T'PURAM · 8°29'N 76°57'E</span>
    
    <div class="side-log left-log">WESTERN GHATS RANGE SYSTEM</div>
    <div class="side-log right-log">TELEMETRY MONITORING ACTIVE</div>
  </div>

  <!-- Central Origin Mark Sacred Geometry -->
  <div class="central-geometry" id="central-geometry">
    <svg class="geometry-circle" viewBox="0 0 100 100" width="220" height="220" fill="none" stroke="var(--color-gold)" stroke-width="0.5">
      <circle cx="50" cy="50" r="48" stroke-dasharray="2" opacity="0.3" />
      <circle cx="50" cy="50" r="32" stroke-linecap="round" />
      <circle cx="50" cy="50" r="16" stroke-dasharray="4" opacity="0.6" />
      <line x1="50" y1="2" x2="50" y2="98" stroke-dasharray="2" opacity="0.15" />
      <line x1="2" y1="50" x2="98" y2="50" stroke-dasharray="2" opacity="0.15" />
      <circle cx="50" cy="50" r="3" fill="var(--color-gold)" />
    </svg>
  </div>

  <!-- The Typographic Core -->
  <div class="monument-content" id="monument-content">
    <h1 class="ethos-text">
      We do not greet the visitor with a catalog.<br/>
      We greet them with our absolute truth.
    </h1>
    
    <button class="step-btn" id="step-btn">
      [ STEP INTO THE ORIGIN ]
    </button>
  </div>
</div>

<style>
  .threshold-container {
    position: relative;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    background-color: var(--color-forest-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1000px;
  }

  .noise-svg {
    position: absolute;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .canopy-backdrop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background-image: url('/assets/origins/wayanad-canopy.webp');
    background-size: cover;
    background-position: center;
    opacity: 0.18;
    z-index: 1;
    filter: saturate(0.4) contrast(1.3) brightness(0.5);
    transform: scale(1);
    transition: transform 4s cubic-bezier(0.22, 1, 0.36, 1), opacity 3s ease;
    will-change: transform, opacity;
  }

  .threshold-container.is-entering .canopy-backdrop {
    transform: scale(1.08);
    opacity: 0;
  }

  .soil-canvas {
    position: absolute;
    inset: -20%; /* Bleed past edges for scale animation */
    filter: url(#breathing-noise);
    opacity: 0.6;
    z-index: 2;
    pointer-events: none;
    /* Hardware accelerated scaling */
    transform: scale3d(1, 1, 1);
    transform-origin: center center;
    will-change: transform, opacity;
    transition: transform 3s cubic-bezier(0.76, 0, 0.24, 1), opacity 3s ease;
  }

  .abyss-overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: radial-gradient(circle at center, transparent 0%, var(--color-forest-deep) 85%);
    pointer-events: none;
    transition: background 3s cubic-bezier(0.76, 0, 0.24, 1);
    will-change: background;
  }

  /* Editorial Gallery Frame */
  .gallery-frame {
    position: absolute;
    inset: 24px;
    border: 1px solid rgba(245, 237, 216, 0.1);
    z-index: 8;
    pointer-events: none;
    box-sizing: border-box;
    transition: opacity 1.5s ease;
  }

  .threshold-container.is-entering .gallery-frame {
    opacity: 0;
  }

  .corner-coordinate {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.15em;
    color: rgba(245, 237, 216, 0.35);
    text-transform: uppercase;
  }

  .corner-coordinate.top-left { top: 12px; left: 16px; }
  .corner-coordinate.top-right { top: 12px; right: 16px; }
  .corner-coordinate.bottom-left { bottom: 12px; left: 16px; }
  .corner-coordinate.bottom-right { bottom: 12px; right: 16px; }

  .side-log {
    position: absolute;
    top: 50%;
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.2em;
    color: rgba(245, 237, 216, 0.2);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .left-log {
    left: 12px;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: left center;
  }

  .right-log {
    right: 12px;
    transform: translateY(-50%) rotate(90deg);
    transform-origin: right center;
  }

  /* Central Geometry Compass Dial */
  .central-geometry {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 5;
    pointer-events: none;
    opacity: 0.5;
    transition: transform 3s cubic-bezier(0.76, 0, 0.24, 1), opacity 2s ease;
    will-change: transform, opacity;
  }

  .geometry-circle {
    animation: spinGeometry 45s linear infinite;
    transform-origin: center center;
  }

  @keyframes spinGeometry {
    to { transform: rotate(360deg); }
  }

  .threshold-container.is-entering .central-geometry {
    transform: translate(-50%, -50%) scale(20);
    opacity: 0;
  }

  .monument-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4rem;
    transition: filter 1.5s ease, opacity 1.5s ease, transform 1.5s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: filter, opacity, transform;
    max-width: 90vw;
  }

  .ethos-text {
    font-family: var(--font-display);
    font-size: var(--text-massive);
    font-weight: 300;
    line-height: var(--line-height-tight);
    color: var(--color-warm-cream);
    margin: 0;
    text-align: center;
    letter-spacing: -0.01em;
    text-shadow: 0 10px 40px rgba(0,0,0,0.9);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUpText 2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 0.5s;
  }

  .step-btn {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    color: var(--color-warm-cream);
    background: transparent;
    border: none;
    padding: 1rem 0;
    cursor: pointer;
    text-transform: uppercase;
    position: relative;
    opacity: 0;
    animation: fadeUpText 2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 1.2s;
  }

  /* Architectural line hover effect */
  .step-btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0%;
    height: 1px;
    background-color: var(--color-warm-cream);
    transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .step-btn:hover::after {
    width: 100%;
  }

  @keyframes fadeUpText {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* --- Animation States --- */
  
  .threshold-container.is-entering .monument-content {
    opacity: 0;
    filter: blur(20px);
    transform: scale3d(1.1, 1.1, 1);
    pointer-events: none;
  }

  .threshold-container.is-entering .soil-canvas {
    transform: scale3d(5, 5, 1); /* Pull viewer deeply into the soil */
    opacity: 1;
  }

  .threshold-container.is-entering .abyss-overlay {
    background: radial-gradient(circle at center, rgba(12, 21, 9, 0) 0%, var(--color-forest-deep) 100%);
  }

  @media (max-width: 768px) {
    .gallery-frame {
      inset: 12px;
    }
    .corner-coordinate {
      font-size: 7px;
    }
    .side-log {
      display: none;
    }
    .central-geometry {
      transform: translate(-50%, -50%) scale(0.75);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Advanced invisible engineering: SVG breathing noise
    const turbulence = document.getElementById('turbulence');
    const baseFreqX = 0.015;
    const baseFreqY = 0.015;
    let startTime = Date.now();

    function animateSoil() {
      // We create a very slow, sine-wave oscillation to shift the frequency, creating a "breathing" texture
      const elapsed = (Date.now() - startTime) / 1000;
      const shift = Math.sin(elapsed * 0.5) * 0.003;
      
      if (turbulence) {
        turbulence.setAttribute('baseFrequency', `${baseFreqX + shift} ${baseFreqY + shift}`);
      }
      requestAnimationFrame(animateSoil);
    }
    
    // Start the microscopic breathing
    animateSoil();

    // Parallax background cursor effect
    const container = document.getElementById('threshold-container');
    const backdrop = document.querySelector('.canopy-backdrop') as HTMLElement;
    const geometry = document.getElementById('central-geometry') as HTMLElement;
    
    if (container && backdrop && geometry) {
      container.addEventListener('mousemove', (e) => {
        if (container.classList.contains('is-entering')) return;
        const rect = container.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5; // -0.5 to 0.5
        const y = (e.clientY - rect.top) / rect.height - 0.5; // -0.5 to 0.5
        
        backdrop.style.transform = `scale(1.02) translate3d(${x * -20}px, ${y * -20}px, 0)`;
        geometry.style.transform = `translate3d(calc(-50% + ${x * 15}px), calc(-50% + ${y * 15}px), 0)`;
      });
    }

    // The Transition
    const btn = document.getElementById('step-btn');

    if (btn && container) {
      btn.addEventListener('click', () => {
        // Fire the cinematic transition
        container.classList.add('is-entering');
        
        // Dispatch State 1 transition just before the violent green bleed finishes (2s)
        setTimeout(() => {
          window.dispatchEvent(new Event('enter-state-1'));
        }, 2000);
        
        // Remove Threshold from DOM flow after animation finishes completely
        setTimeout(() => {
          container.style.display = 'none';
        }, 3000);
      });
    }
  });
</script>
