---
// src/components/TheHorizonLog.astro
---

<section id="horizon-log" class="horizon-log-section">
  <div class="horizon-container">
    <div class="horizon-journal-header">
      <span class="journal-tag">[ ECOLOGICAL HORIZON ]</span>
      <h2 class="journal-title">Winter Curing Vanilla</h2>
      <p class="journal-subtitle">SPECIMEN RECORD: IDK-VN-2026 · CURING PHASE</p>
    </div>
    
    <div class="horizon-journal-body">
      <!-- Telemetry Specs Column -->
      <div class="journal-column border-right">
        <h3 class="column-title">ECOLOGICAL TELEMETRY</h3>
        <table class="telemetry-table">
          <tbody>
            <tr>
              <td class="lbl">LOCATION</td>
              <td class="val">Idukki Collective · 9°51'N 77°14'E</td>
            </tr>
            <tr>
              <td class="lbl">ALTITUDE</td>
              <td class="val">1,200M Elevation</td>
            </tr>
            <tr>
              <td class="lbl">SOIL BASE</td>
              <td class="val">Cardamom Transition Loam</td>
            </tr>
            <tr>
              <td class="lbl">STATUS</td>
              <td class="val status-curing">CURING IN WOOL WRAP</td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <!-- Narrative & Timeline Column -->
      <div class="journal-column">
        <h3 class="column-title">CURATOR'S OBSERVATION</h3>
        <p class="journal-text">
          The vanilla vines are currently dormant, holding the pods for the final curing phase. Our curing process takes up to four months of direct sun manipulation and wool wrapping to lock in the true vanillin compounds. The target yield is strictly limited to 12 kilograms.
        </p>
        
        <div class="journal-timeline-wrapper">
          <span class="timeline-title">[ THE TIMELINE ]</span>
          <div class="journal-timeline">
            <div class="timeline-step">
              <span class="step-lbl">HARVEST</span>
              <span class="step-val">JAN 2026</span>
            </div>
            <span class="timeline-arrow">&rarr;</span>
            <div class="timeline-step">
              <span class="step-lbl">CURING</span>
              <span class="step-val">FEB-SEP</span>
            </div>
            <span class="timeline-arrow">&rarr;</span>
            <div class="timeline-step">
              <span class="step-lbl">DISPATCH</span>
              <span class="step-val">OCT 2026</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .horizon-log-section {
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    padding: 10vh 8vw;
    border-bottom: 1px solid rgba(245, 237, 216, 0.1);
  }

  .horizon-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .horizon-journal-header {
    border-bottom: 1px solid rgba(245, 237, 216, 0.15);
    padding-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    text-align: left;
  }

  .journal-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--color-gold);
  }

  .journal-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 6rem);
    font-weight: 300;
    margin: 0;
    line-height: 1;
  }

  .journal-subtitle {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: rgba(245, 237, 216, 0.4);
    margin: 0;
  }

  /* Body columns split */
  .horizon-journal-body {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 6vw;
  }

  .journal-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-align: left;
  }

  .journal-column.border-right {
    border-right: 1px solid rgba(245, 237, 216, 0.1);
    padding-right: 4vw;
  }

  .column-title {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin: 0;
    border-bottom: 1px dashed rgba(245, 237, 216, 0.15);
    padding-bottom: 0.5rem;
  }

  /* Telemetry Table */
  .telemetry-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 11px;
    margin-top: 0.5rem;
  }

  .telemetry-table td {
    padding: 1rem 0;
    border-bottom: 1px solid rgba(245, 237, 216, 0.08);
  }

  .telemetry-table td:last-child {
    border-bottom: none;
  }

  .telemetry-table .lbl {
    color: rgba(245, 237, 216, 0.4);
  }

  .telemetry-table .val {
    color: var(--color-warm-cream);
    text-align: right;
  }

  .telemetry-table .status-curing {
    color: var(--color-gold);
    font-weight: 500;
  }

  /* Observation Log Details */
  .journal-text {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.5vw, 1.35rem);
    line-height: 1.6;
    color: var(--color-warm-cream);
    opacity: 0.85;
    margin: 0;
  }

  .journal-timeline-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .timeline-title {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: rgba(245, 237, 216, 0.4);
  }

  .journal-timeline {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
  }

  .timeline-step {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .timeline-step .step-lbl {
    font-size: 8px;
    color: rgba(245, 237, 216, 0.4);
  }

  .timeline-step .step-val {
    color: var(--color-warm-cream);
  }

  .timeline-arrow {
    color: var(--color-gold);
    font-size: 14px;
  }

  /* Mobile responsiveness */
  @media (max-width: 900px) {
    .horizon-journal-body {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .journal-column.border-right {
      border-right: none;
      padding-right: 0;
      border-bottom: 1px solid rgba(245, 237, 216, 0.1);
      padding-bottom: 2rem;
    }
  }
</style>
