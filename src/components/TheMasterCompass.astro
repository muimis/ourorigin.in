---
// src/components/TheMasterCompass.astro
import OriginMark from './OriginMark.astro';
import { getCollection } from 'astro:content';

// We fetch the yields to populate the views
const yields = await getCollection('products');
const origins = await getCollection('origins');

// Sort alphabetically for the Index (safeguard against missing name)
const sortedYields = [...yields].sort((a, b) => {
  const nameA = a.data.name || '';
  const nameB = b.data.name || '';
  return nameA.localeCompare(nameB);
});
---

<div id="master-compass" class="master-compass is-hidden">
  
  <!-- Fixed Top Left: Origin Mark -->
  <div class="compass-header">
    <OriginMark variant="gold" size={32} animate={false} />
  </div>

  <!-- VIEW LOBBY: THE CROSSROADS COMPASS -->
  <div id="view-lobby" class="compass-view is-active">
    <div class="lobby-container">
      <!-- High-End Circular Compass Dial Axis -->
      <div class="lobby-axis">
        <div class="compass-dial-ring"></div>
        <div class="compass-dial-coordinates">GHATS : 10°N 76°E</div>
      </div>

      <!-- Quadrant grid design -->
      <div class="lobby-grid">
        <!-- Quadrant 1: Brand Monolith -->
        <div class="lobby-quad quad-telemetry">
          <div class="quad-header">[ IDENTIFIER ]</div>
          <div class="quad-body">
            <h1 class="brand-monolith">OurOrigin</h1>
            <p class="brand-subtext">THE ARCHIVAL CHRONICLES</p>
            <div class="telemetry-log">
              <div>STATUS: SYSTEM DISPATCH ACTIVE</div>
              <div>GHATS TIME: <span id="telemetry-time">15:45:00</span> (GMT+5:30)</div>
              <div>TELEMETRY LINK: <span id="telemetry-flicker">11.3621°N 76.0405°E</span></div>
            </div>
          </div>
        </div>

        <!-- Quadrant 2: Path 01 (The Yield) -->
        <button class="lobby-quad quad-link" data-target="view-yield" aria-label="Open Yield section">
          <div class="quad-header">[ PATH 01 ]</div>
          <div class="quad-body">
            <span class="quad-num">01</span>
            <h2 class="quad-title">THE YIELD</h2>
            <p class="quad-desc">What the earth has surrendered. The active wild harvest.</p>
          </div>
        </button>

        <!-- Quadrant 3: Path 02 (The Horizon) -->
        <button class="lobby-quad quad-link" data-target="view-horizon" aria-label="Open Horizon section">
          <div class="quad-header">[ PATH 02 ]</div>
          <div class="quad-body">
            <span class="quad-num">02</span>
            <h2 class="quad-title">THE HORIZON</h2>
            <p class="quad-desc">What the soil is preparing. Curing and future crops.</p>
          </div>
        </button>

        <!-- Quadrant 4: Path 03 (The Index) -->
        <button class="lobby-quad quad-link" data-target="view-index" aria-label="Open Index section">
          <div class="quad-header">[ PATH 03 ]</div>
          <div class="quad-body">
            <span class="quad-num">03</span>
            <h2 class="quad-title">THE INDEX</h2>
            <p class="quad-desc">The absolute ledger. Our complete global catalog.</p>
          </div>
        </button>
      </div>
    </div>
  </div>

  <!-- VIEW A: THE YIELD (Active Harvests) -->
  <div id="view-yield" class="compass-view">
    <div class="horizontal-stream">
      {yields.map((y) => {
        const originId = typeof y.data.originSlug === 'object' ? y.data.originSlug?.id : y.data.originSlug;
        const origin = origins.find(o => o.data.slug === originId);
        const elevation = origin ? origin.data.elevation : '950M';
        const coordinates = origin ? origin.data.coordinates : '10°N 76°E';
        return (
          <div class="stream-item">
            <!-- Left Side: Product Showcase -->
            <div class="stream-split-left">
              <div class="product-showcase-wrapper">
                <img 
                  src={y.data.images?.packaging || '/assets/products/black-pepper.png'} 
                  alt={`Packaging of ${y.data.name}`} 
                  class="product-floating-img" 
                  width="500"
                  height="500"
                />
                <div class="product-glow-backdrop"></div>
              </div>
              
              <div class="product-technical-specs">
                <div class="spec-line">
                  <span class="label">BATCH RECORD</span>
                  <span class="value">{y.data.batchRef}</span>
                </div>
                <div class="spec-line">
                  <span class="label">COORDINATES</span>
                  <span class="value">{coordinates}</span>
                </div>
                <div class="spec-line">
                  <span class="label">ALTITUDE</span>
                  <span class="value">{elevation}</span>
                </div>
              </div>
            </div>
            
            <!-- Right Side: Narrative and Price Details -->
            <div class="stream-split-right">
              <div class="product-header-block">
                <span class="origin-tag">[{String(originId || '').toUpperCase()} COLLECTIVE]</span>
                <h2 class="stream-title">{y.data.name}</h2>
                <p class="botanical-line">{y.data.botanicalName}</p>
              </div>
              
              <div class="product-description-block">
                <p class="description-text">{y.data.specimenCopy}</p>
              </div>
              
              <div class="product-pricing-block">
                <div class="price-grid-title">[ SIZES & VALUES ]</div>
                <div class="price-grid">
                  {y.data.sizes.map(size => (
                    <div class="price-cell">
                      <span class="cell-label">{size.label}</span>
                      <span class="cell-val">₹{size.priceINR}</span>
                    </div>
                  ))}
                </div>
              </div>
              
              <div class="product-action-block">
                <button class="descend-action-btn" data-slug={y.id} data-origin={originId}>
                  [ DESCEND INTO ORIGIN DETAILS ]
                </button>
              </div>
            </div>
          </div>
        );
      })}
    </div>
    <div class="stream-position" aria-live="polite">
      <span class="stream-index-val">1</span> / <span class="stream-total-val"></span>
    </div>
    <!-- Horizontal navigation arrows for desktop -->
    <div class="stream-nav-controls">
      <button class="stream-nav-btn prev-btn" aria-label="Previous Product">[ &larr; ]</button>
      <button class="stream-nav-btn next-btn" aria-label="Next Product">[ &rarr; ]</button>
    </div>
  </div>

  <!-- VIEW B: THE HORIZON (Future Harvests - Journal Format) -->
  <div id="view-horizon" class="compass-view">
    <div class="horizon-journal-container">
      <div class="horizon-journal-header">
        <span class="journal-tag">[ IDUKKI EXPEDITION LOG ]</span>
        <h2 class="journal-title">Winter Curing Vanilla</h2>
        <p class="journal-subtitle">SPECIMEN RECORD: IDK-VN-2026 · CURING PHASE</p>
      </div>
      
      <div class="horizon-journal-body">
        <div class="journal-column">
          <h3>ECOLOGICAL TELEMETRY</h3>
          <table class="telemetry-table">
            <tbody>
              <tr>
                <td class="label">LOCATION</td>
                <td class="value">9°51'N, 77°14'E</td>
              </tr>
              <tr>
                <td class="label">ALTITUDE</td>
                <td class="value">1,200M Elevation</td>
              </tr>
              <tr>
                <td class="label">SOIL BASE</td>
                <td class="value">Cardamom Transition Loam</td>
              </tr>
              <tr>
                <td class="label">STATUS</td>
                <td class="value status-curing">CURING IN WOOL WRAP</td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <div class="journal-column">
          <h3>CURATOR'S OBSERVATION</h3>
          <p class="journal-text">
            The vines are currently dormant, holding the pods for the final curing phase. Our curing process takes up to four months of direct sun manipulation and wool wrapping to lock in the true vanillin compounds. The target yield is strictly limited to 12 kilograms.
          </p>
          <div class="journal-timeline">
            <span class="timeline-point">HARVEST: JAN 2026</span>
            <span class="timeline-arrow">&rarr;</span>
            <span class="timeline-point">CURING: FEB-SEP</span>
            <span class="timeline-arrow">&rarr;</span>
            <span class="timeline-point">DISPATCH: OCT 2026</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- VIEW C: THE INDEX (Typographic Ledger) -->
  <div id="view-index" class="compass-view">
    <div class="ledger-container">
      <div class="ledger-list">
        <div class="ledger-header-row">
          <span class="col-yield">NOMENCLATURE</span>
          <span class="col-collective">PROVENANCE</span>
          <span class="col-status">COMPLIANCE / ACTION</span>
        </div>
        {sortedYields.map((y) => {
          const originId = typeof y.data.originSlug === 'object' ? y.data.originSlug?.id : y.data.originSlug;
          return (
            <div class="ledger-row" data-slug={y.id} data-origin={originId}>
              <span class="col-yield">
                <span class="yield-name">{y.data.name}</span>
                <span class="yield-botanical">{y.data.botanicalName}</span>
              </span>
              <span class="col-collective">{String(originId || '').toUpperCase()} COLLECTIVE</span>
              <span class="col-status"><span class="status-action">[ DESCEND ]</span></span>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Fixed Bottom Center: Master Toggle -->
  <div class="compass-toggle is-hidden-initially" id="master-toggle">
    <button class="toggle-btn" data-target="view-yield">YIELD</button>
    <button class="toggle-btn" data-target="view-horizon">HORIZON</button>
    <button class="toggle-btn" data-target="view-index">INDEX</button>
  </div>

</div>

<style>
  .master-compass {
    position: fixed;
    inset: 0;
    z-index: 50;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    opacity: 1;
    visibility: visible;
    transition: opacity 1.5s ease, visibility 1.5s;
  }
  
  .master-compass.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .compass-header {
    position: absolute;
    top: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
  }

  /* Views Base */
  .compass-view {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.8s;
  }

  .compass-view.is-active {
    opacity: 1;
    visibility: inherit;
    pointer-events: inherit;
  }

  /* --- Quadrant Compass Lobby --- */
  .lobby-container {
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    background-color: var(--color-forest-deep);
    position: relative;
    overflow: hidden;
  }

  .lobby-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    width: 100%;
    height: 100%;
    position: relative;
  }

  /* Dividing lines */
  .lobby-grid::after {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: 1px;
    height: 100%;
    background-color: rgba(245, 237, 216, 0.1);
    z-index: 5;
    pointer-events: none;
  }
  .lobby-grid::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: rgba(245, 237, 216, 0.1);
    z-index: 5;
    pointer-events: none;
  }

  .lobby-quad {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 4vw;
    box-sizing: border-box;
    position: relative;
    background: transparent;
    border: none;
    text-align: left;
  }

  .quad-link {
    cursor: pointer;
    transition: background-color 0.4s var(--ease-settle);
  }

  .quad-link:hover {
    background-color: rgba(245, 237, 216, 0.015);
  }

  .quad-header {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: rgba(245, 237, 216, 0.35);
  }

  .quad-body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.8rem;
    margin-top: auto;
  }

  .brand-monolith {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 6rem);
    font-weight: 300;
    color: var(--color-warm-cream);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .brand-subtext {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.25em;
    color: var(--color-gold);
    margin: 0;
  }

  .telemetry-log {
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    color: rgba(245, 237, 216, 0.4);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .quad-num {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 7.5rem);
    font-weight: 300;
    line-height: 0.9;
    color: rgba(245, 237, 216, 0.08);
    transition: color 0.4s var(--ease-settle), transform 0.4s var(--ease-settle);
  }

  .quad-link:hover .quad-num {
    color: var(--color-gold);
    opacity: 0.15;
    transform: scale(1.05) translateY(-5px);
  }

  .quad-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 4.5rem);
    font-weight: 300;
    margin: 0;
    color: var(--color-warm-cream);
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .quad-desc {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.6;
    letter-spacing: 0.05em;
    color: rgba(245, 237, 216, 0.55);
    margin: 0;
    max-width: 280px;
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .quad-link:hover .quad-desc {
    color: var(--color-warm-cream);
  }

  /* --- Compass Dial in Center --- */
  .lobby-axis {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 200px;
    height: 200px;
    z-index: 10;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .compass-dial-ring {
    position: absolute;
    width: 100%;
    height: 100%;
    border: 1px dashed rgba(245, 237, 216, 0.12);
    border-radius: 50%;
    animation: rotateCompassDial 60s linear infinite;
  }

  .compass-dial-coordinates {
    position: absolute;
    bottom: -32px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.25em;
    color: var(--color-gold);
    white-space: nowrap;
  }

  @keyframes rotateCompassDial {
    to { transform: rotate(360deg); }
  }

  /* HORIZONTAL STREAM (Yield & Horizon) */
  .horizontal-stream {
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .horizontal-stream::-webkit-scrollbar { display: none; }

  /* SPLIT COLUMN PRODUCT ARRANGEMENT */
  .stream-item {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    padding: 12vh 6vw 8vh 6vw;
    gap: 5vw;
    align-items: center;
    background-color: var(--color-forest-deep);
    position: relative;
    box-sizing: border-box;
    scroll-snap-align: center;
    scroll-snap-stop: always;
    flex: 0 0 100vw;
    overflow: hidden;
  }

  .stream-split-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    height: 100%;
  }

  .product-showcase-wrapper {
    position: relative;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-floating-img {
    max-height: 50vh;
    max-width: 90%;
    object-fit: contain;
    z-index: 2;
    filter: drop-shadow(0 20px 50px rgba(0, 0, 0, 0.7));
    transition: transform 0.6s var(--ease-settle);
  }

  .stream-item:hover .product-floating-img {
    transform: scale(1.05) translateY(-5px);
  }

  .product-glow-backdrop {
    position: absolute;
    width: 60%;
    height: 60%;
    background: radial-gradient(circle, rgba(166, 124, 60, 0.08) 0%, transparent 70%);
    z-index: 1;
  }

  .product-technical-specs {
    width: 100%;
    max-width: 420px;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    border-top: 1px solid rgba(245, 237, 216, 0.15);
    padding-top: 1.2rem;
  }

  .spec-line {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
  }

  .spec-line .label {
    color: rgba(245, 237, 216, 0.4);
  }

  .spec-line .value {
    color: var(--color-warm-cream);
  }

  .stream-split-right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 2.5rem;
    height: 100%;
    text-align: left;
  }

  .product-header-block {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .origin-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.25em;
    color: var(--color-gold);
  }

  .stream-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 5.5rem);
    font-weight: 300;
    line-height: 0.95;
    margin: 0;
    color: var(--color-warm-cream);
    letter-spacing: -0.02em;
  }

  .botanical-line {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-style: italic;
    color: rgba(245, 237, 216, 0.6);
    margin: 0;
  }

  .product-description-block {
    max-width: 480px;
  }

  .description-text {
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-warm-cream);
    margin: 0;
    opacity: 0.85;
  }

  .product-pricing-block {
    width: 100%;
    max-width: 480px;
  }

  .price-grid-title {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    color: rgba(245, 237, 216, 0.4);
    margin-bottom: 0.8rem;
  }

  .price-grid {
    display: flex;
    gap: 1.5rem;
  }

  .price-cell {
    border: 1px solid rgba(245, 237, 216, 0.15);
    padding: 0.6rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .price-cell .cell-label {
    font-family: var(--font-mono);
    font-size: 9px;
    color: rgba(245, 237, 216, 0.5);
  }

  .price-cell .cell-val {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-warm-cream);
  }

  .product-action-block {
    width: 100%;
  }

  .descend-action-btn {
    background: transparent;
    color: var(--color-warm-cream);
    border: 1px solid rgba(245, 237, 216, 0.3);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    padding: 1.2rem 2.5rem;
    cursor: pointer;
    transition: all 0.3s var(--ease-settle);
  }

  .descend-action-btn:hover {
    color: var(--color-gold);
    border-color: var(--color-gold);
    background: rgba(166, 124, 60, 0.05);
  }

  /* --- Horizon Journal Layout --- */
  .horizon-journal-container {
    width: 100%;
    height: 100%;
    padding: 15vh 8vw 8vh 8vw;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    box-sizing: border-box;
    overflow-y: auto;
  }

  .horizon-journal-header {
    border-bottom: 1px solid rgba(245, 237, 216, 0.15);
    padding-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .journal-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--color-gold);
  }

  .journal-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 6rem);
    font-weight: 300;
    margin: 0;
    line-height: 1;
    color: var(--color-warm-cream);
  }

  .journal-subtitle {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: rgba(245, 237, 216, 0.4);
    margin: 0;
  }

  .horizon-journal-body {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 6vw;
  }

  .journal-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .journal-column h3 {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin: 0;
    border-bottom: 1px dashed rgba(245, 237, 216, 0.15);
    padding-bottom: 0.5rem;
  }

  .telemetry-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .telemetry-table td {
    padding: 0.8rem 0;
    border-bottom: 1px solid rgba(245, 237, 216, 0.08);
  }

  .telemetry-table .label {
    color: rgba(245, 237, 216, 0.4);
  }

  .telemetry-table .value {
    color: var(--color-warm-cream);
    text-align: right;
  }

  .telemetry-table .status-curing {
    color: var(--color-gold);
    font-weight: 500;
  }

  .journal-text {
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.6;
    color: var(--color-warm-cream);
    opacity: 0.85;
    margin: 0;
  }

  .journal-timeline {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--color-gold);
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .timeline-arrow {
    opacity: 0.5;
  }

  /* THE INDEX (Brutalist Ledger) */
  .ledger-container {
    width: 100%;
    height: 100%;
    padding: 15vh clamp(1.5rem, 5vw, 6vw);
    overflow-y: auto;
    scrollbar-width: none;
    box-sizing: border-box;
  }
  .ledger-container::-webkit-scrollbar { display: none; }

  .ledger-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(245, 237, 216, 0.2); /* Stark top boundary */
  }

  .ledger-header-row {
    display: grid;
    grid-template-columns: 3fr 1.5fr 1fr;
    align-items: center;
    padding: 1.5rem 0;
    border-bottom: 2px solid rgba(245, 237, 216, 0.3);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    pointer-events: none;
  }

  .ledger-row {
    display: grid;
    grid-template-columns: 3fr 1.5fr 1fr;
    align-items: center;
    padding: 2rem 0;
    border-bottom: 1px solid rgba(245, 237, 216, 0.15);
    cursor: pointer;
    transition: all 0.4s var(--ease-settle);
    position: relative;
  }

  /* Tactile grid borders on hover */
  .ledger-row::before,
  .ledger-row::after {
    content: '';
    position: absolute;
    top: 0;
    height: 100%;
    width: 1px;
    background-color: rgba(245, 237, 216, 0.08);
    opacity: 0;
    transition: opacity 0.4s var(--ease-settle);
    pointer-events: none;
  }

  .ledger-row::before {
    left: calc(3 / 5.5 * 100%);
  }
  .ledger-row::after {
    left: calc(4.5 / 5.5 * 100%);
  }

  .ledger-row:hover::before,
  .ledger-row:hover::after {
    opacity: 1;
  }

  .ledger-row:hover {
    padding-left: 1.5rem;
    background: rgba(245, 237, 216, 0.015);
  }

  .ledger-row .col-yield {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .yield-name {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 3.8rem);
    font-weight: 300;
    color: var(--color-warm-cream);
    line-height: 1;
    transition: color 0.4s ease;
  }

  .ledger-row:hover .yield-name {
    color: var(--color-gold);
  }

  .yield-botanical {
    font-family: var(--font-mono);
    font-size: 11px;
    font-style: italic;
    color: rgba(245, 237, 216, 0.4);
  }

  .ledger-row .col-collective {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: rgba(245, 237, 216, 0.7);
  }

  .ledger-row .col-status {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--color-warm-cream);
    text-align: right;
  }

  .status-action {
    display: inline-block;
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .ledger-row:hover .status-action {
    color: var(--color-gold);
    border-color: var(--color-gold);
  }

  /* BOTTOM MASTER TOGGLE */
  .compass-toggle {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    background: var(--color-forest-deep);
    border: 1px solid rgba(245, 237, 216, 0.15); /* Stark structural line */
    transition: opacity 1s ease, visibility 1s;
  }
  
  .compass-toggle.is-hidden-initially {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .toggle-btn {
    background: transparent;
    border: none;
    border-right: 1px solid rgba(245, 237, 216, 0.15); /* Gauge separators */
    padding: 16px 32px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: rgba(245, 237, 216, 0.4);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .toggle-btn:last-child {
    border-right: none;
  }

  .toggle-btn.is-active {
    background: var(--color-warm-cream);
    color: var(--color-forest-deep);
  }

  .stream-position {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-warm-cream);
    opacity: 0.7;
    z-index: 50;
    pointer-events: none;
  }

  /* Horizontal desktop navigation controls */
  .stream-nav-controls {
    position: absolute;
    bottom: 28px;
    right: 6vw;
    z-index: 60;
    display: flex;
    gap: 1rem;
  }

  .stream-nav-btn {
    background: transparent;
    border: none;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-warm-cream);
    opacity: 0.5;
    cursor: pointer;
    padding: 0.5rem;
    transition: opacity 0.3s ease, color 0.3s ease;
  }

  .stream-nav-btn:hover {
    opacity: 1;
    color: var(--color-gold);
  }

  @media (max-width: 960px) {
    .stream-item {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      gap: 3rem;
      padding: 12vh 6vw 10vh 6vw;
      overflow-y: auto;
    }

    .stream-split-left,
    .stream-split-right {
      height: auto;
      align-items: center;
      text-align: center;
    }

    .stream-split-right {
      align-items: center;
    }

    .product-floating-img {
      max-height: 35vh;
    }

    .product-description-block {
      text-align: center;
    }

    .price-grid {
      justify-content: center;
    }

    .descend-action-btn {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .lobby-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto auto;
      overflow-y: auto;
    }

    .lobby-grid::after,
    .lobby-grid::before {
      display: none;
    }

    .lobby-quad {
      padding: 3rem 2rem;
      border-bottom: 1px solid rgba(245, 237, 216, 0.08);
      justify-content: flex-start;
      gap: 1.5rem;
    }

    .quad-body {
      margin-top: 0;
    }

    .lobby-axis {
      display: none;
    }

    .horizon-journal-body {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .ledger-header-row {
      display: none;
    }
    
    .ledger-row {
      grid-template-columns: 1fr;
      gap: 0.8rem;
      padding: 1.5rem 0;
    }
    
    .ledger-row .col-status {
      text-align: left;
      margin-top: 0.5rem;
    }

    .stream-nav-controls {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // State Machine Logic for Compass Toggles
    const toggles = document.querySelectorAll('.toggle-btn');
    const views = document.querySelectorAll('.compass-view');
    const lobbyLinks = document.querySelectorAll('.lobby-link, .quad-link');
    const masterToggle = document.getElementById('master-toggle');

    function activateView(targetId) {
      // Update toggle states
      toggles.forEach(t => {
        if(t.getAttribute('data-target') === targetId) {
          t.classList.add('is-active');
        } else {
          t.classList.remove('is-active');
        }
      });

      // Update view states
      views.forEach(v => {
        if (v.id === targetId) {
          v.classList.add('is-active');
        } else {
          v.classList.remove('is-active');
        }
      });
      
      // If we are leaving the lobby, reveal the master toggle permanently
      if (targetId !== 'view-lobby' && masterToggle) {
        masterToggle.classList.remove('is-hidden-initially');
      }
    }

    toggles.forEach(btn => {
      btn.addEventListener('click', () => {
        activateView(btn.getAttribute('data-target'));
      });
    });

    lobbyLinks.forEach(link => {
      link.addEventListener('click', () => {
        activateView(link.getAttribute('data-target'));
      });
    });

    // State 0 -> State 1 Transition Event Listener
    window.addEventListener('enter-state-1', () => {
      const compass = document.getElementById('master-compass');
      if (compass) {
        compass.classList.remove('is-hidden');
      }
    });

    // Navigation Triggers to dynamic product pages
    const streamTriggers = document.querySelectorAll('.stream-btn-trigger, .descend-action-btn');
    const ledgerRows = document.querySelectorAll('.ledger-row');

    function triggerDeepDive(slug, origin) {
      if (!slug || !origin) return;
      window.location.href = `/origins/${origin}/${slug}`;
    }

    streamTriggers.forEach(btn => {
      btn.addEventListener('click', () => {
        triggerDeepDive(btn.getAttribute('data-slug'), btn.getAttribute('data-origin'));
      });
    });

    ledgerRows.forEach(row => {
      row.addEventListener('click', () => {
        triggerDeepDive(row.getAttribute('data-slug'), row.getAttribute('data-origin'));
      });
    });

    // Stream position indicators
    function initStreamPosition(streamEl) {
      const items = streamEl.querySelectorAll('.stream-item');
      const container = streamEl.parentElement;
      const indexEl = container.querySelector('.stream-index-val');
      const totalEl = container.querySelector('.stream-total-val');
      if(!items.length || !indexEl || !totalEl) return;
      
      totalEl.textContent = items.length.toString();
      
      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if(entry.isIntersecting && entry.intersectionRatio > 0.6) {
            indexEl.textContent = (Array.from(items).indexOf(entry.target) + 1).toString();
          }
        });
      }, { root: streamEl, threshold: 0.6 });
      
      items.forEach(item => io.observe(item));
    }
    
    document.querySelectorAll('.horizontal-stream').forEach(el => initStreamPosition(el as HTMLElement));

    // Horizontal navigation arrow controls
    document.querySelectorAll('.compass-view').forEach(view => {
      const stream = view.querySelector('.horizontal-stream');
      const prevBtn = view.querySelector('.prev-btn');
      const nextBtn = view.querySelector('.next-btn');
      
      if (stream && prevBtn && nextBtn) {
        prevBtn.addEventListener('click', () => {
          stream.scrollBy({ left: -window.innerWidth, behavior: 'smooth' });
        });
        nextBtn.addEventListener('click', () => {
          stream.scrollBy({ left: window.innerWidth, behavior: 'smooth' });
        });
      }
    });

    // Telemetry log real-time updates (UTC+5:30)
    const timeEl = document.getElementById('telemetry-time');
    const flickerEl = document.getElementById('telemetry-flicker');
    
    if (timeEl) {
      setInterval(() => {
        const now = new Date();
        const utc = now.getTime() + (now.getTimezoneOffset() * 60000);
        const ghatsOffset = 5.5; // GMT+5:30
        const ghatsDate = new Date(utc + (3600000 * ghatsOffset));
        
        const hrs = ghatsDate.getHours().toString().padStart(2, '0');
        const mins = ghatsDate.getMinutes().toString().padStart(2, '0');
        const secs = ghatsDate.getSeconds().toString().padStart(2, '0');
        timeEl.textContent = `${hrs}:${mins}:${secs}`;
      }, 1000);
    }

    if (flickerEl) {
      setInterval(() => {
        const lat = (11.58 + (Math.random() - 0.5) * 0.04).toFixed(4);
        const lng = (76.08 + (Math.random() - 0.5) * 0.04).toFixed(4);
        flickerEl.textContent = `${lat}°N ${lng}°E`;
      }, 1500);
    }
  });
</script>
