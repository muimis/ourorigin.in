---
// src/components/OpeningSequence.astro
import OriginMark from './OriginMark.astro';

const dimensions = [
  { 
    id: 'geo',
    name: 'Geo', 
    text: 'Every true thing comes from one exact place. Not a region. A place.',
    d: 'M 50,20 L 50,40 M 50,60 L 50,80 M 20,50 L 40,50 M 60,50 L 80,50 M 40,50 A 10,10 0 1,0 60,50 A 10,10 0 1,0 40,50' 
  },
  { 
    id: 'bio',
    name: 'Bio', 
    text: 'Before anyone arrives to take anything, the place already has a life of its own.',
    d: 'M 30,50 A 20,20 0 0,1 70,50 M 20,50 A 30,30 0 0,1 80,50 M 40,50 A 10,10 0 0,1 60,50' 
  },
  { 
    id: 'community',
    name: 'Community', 
    text: "Someone has understood this place longer than we've known it exists.",
    d: 'M 42,50 A 18,18 0 1,0 78,50 A 18,18 0 1,0 42,50 M 58,50 A 18,18 0 1,0 94,50 A 18,18 0 1,0 58,50' 
  },
  { 
    id: 'method',
    name: 'Method', 
    text: 'There is a way of taking, and a way of taking too much. This is the difference we look for.',
    d: 'M 25,35 L 75,35 M 18,50 L 82,50 M 25,65 L 75,65' 
  },
  { 
    id: 'observation',
    name: 'Observation', 
    text: "Not a photograph from last year. What's happening there, right now.",
    d: 'M 20,50 C 35,25 40,75 50,50 C 60,25 65,75 80,50' 
  },
  { 
    id: 'time',
    name: 'Time', 
    text: "It has seasons. It changes. What you're looking at is alive, not preserved.",
    d: 'M 50,20 L 50,80 M 20,50 L 80,50 M 50,50 L 70,30' 
  },
  { 
    id: 'product',
    name: 'Product', 
    text: "What ends up in your hand is proof all of this was true. Or it's nothing.",
    d: 'M 50,38 A 12,12 0 1,0 62,50 A 12,12 0 1,0 50,38 M 50,32 L 50,15 M 50,68 L 50,85 M 32,50 L 15,50 M 68,50 L 85,50' 
  }
];
---

<div id="opening-sequence" class="opening-sequence-container">
  <!-- 7-Segment Stories Progress Bar -->
  <div class="progress-bar-container">
    {Array.from({ length: 7 }).map((_, idx) => (
      <div class="progress-segment" data-segment-index={idx}>
        <div class="progress-segment-fill"></div>
      </div>
    ))}
  </div>

  <!-- Slides Container -->
  <div class="slides-container">
    {dimensions.map((beat) => (
      <div class="beat-slide" data-id={beat.id} style={`--total-words: ${beat.text.split(' ').length};`}>
        <div class="glyph-container">
          <svg viewBox="0 0 100 100" class="cipher-icon" width="160" height="160">
            <circle cx="50" cy="50" r="48" stroke-dasharray="2" opacity="0.3" />
            <path d={beat.d} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none" />
            {beat.id === 'product' && <circle cx="50" cy="50" r="3" fill="currentColor" />}
          </svg>
        </div>
        <p class="beat-statement">
          {beat.text.split(' ').map((word, wIdx) => (
            <span class="word" style={`--word-index: ${wIdx};`}>{word} </span>
          ))}
        </p>
        <span class="first-visit-label">{beat.name.toUpperCase()}</span>
        <span class="beat-marker">·</span>
      </div>
    ))}
  </div>

  <!-- Resolution Beat -->
  <div class="resolution-slide">
    <div class="resolution-glyphs">
      {dimensions.map((beat) => (
        <svg viewBox="0 0 100 100" class="mini-glyph" width="24" height="24">
          <circle cx="50" cy="50" r="48" stroke-dasharray="2" opacity="0.3" />
          <path d={beat.d} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none" />
          {beat.id === 'product' && <circle cx="50" cy="50" r="3" fill="currentColor" />}
        </svg>
      ))}
    </div>
    
    <h2 class="res-statement">This is what we mean by an origin.</h2>
    <p class="res-narrative">Right now, ours is the Western Ghats.</p>
    
    <button id="enter-btn" class="enter-button">
      [ ENTER ]
    </button>
  </div>
</div>

<style>
  .opening-sequence-container {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    background-color: #0c1509;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: transform 1.2s cubic-bezier(0.76, 0, 0.24, 1), opacity 1s ease;
  }

  .opening-sequence-container.passed {
    transform: translateY(-100dvh);
    opacity: 0;
    pointer-events: none;
  }

  /* Progress Bar */
  .progress-bar-container {
    position: absolute;
    top: 24px;
    left: 24px;
    right: 24px;
    display: flex;
    gap: 4px;
    z-index: 10;
  }

  .progress-segment {
    flex: 1;
    height: 4px;
    background-color: rgba(245, 237, 218, 0.2);
    overflow: hidden;
  }

  .progress-segment-fill {
    width: 0%;
    height: 100%;
    background-color: var(--color-gold);
  }

  @media (max-width: 768px) {
    .progress-bar-container {
      gap: 2px;
    }
    .progress-segment {
      height: 2px;
    }
  }

  /* Slides */
  .slides-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .beat-slide {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
    width: 90vw;
    max-width: 480px;
  }

  .beat-slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  .glyph-container {
    margin-bottom: 2rem;
    color: var(--color-warm-cream);
  }

  .cipher-icon {
    width: 160px;
    height: 160px;
  }

  @media (max-width: 768px) {
    .cipher-icon {
      width: 120px;
      height: 120px;
    }
    .beat-slide {
      max-width: 320px;
    }
  }

  .cipher-icon path {
    stroke: var(--color-warm-cream);
    transition: stroke 0.8s ease;
  }

  .beat-slide.active .cipher-icon path {
    stroke: var(--color-gold);
    transition-delay: calc(var(--total-words) * 50ms + 300ms);
  }

  .beat-statement {
    font-family: var(--font-display);
    font-size: var(--type-statement);
    font-style: italic;
    line-height: 1.4;
    color: var(--color-warm-cream);
    margin: 0 0 1.5rem 0;
  }

  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(8px);
    transition: none;
  }

  .beat-slide.active .word {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.4s ease, transform 0.5s var(--ease-settle);
    transition-delay: calc(var(--word-index) * 50ms);
  }

  .first-visit-label {
    font-family: var(--font-mono);
    font-size: var(--type-whisper);
    letter-spacing: 0.15em;
    color: var(--color-gold);
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.8s ease, transform 0.8s ease;
    margin-bottom: 1rem;
  }

  .beat-slide.active .first-visit-label {
    opacity: 0.7;
    transform: scale(1);
    transition-delay: calc(var(--total-words) * 50ms + 400ms);
  }

  .beat-marker {
    font-size: 11px;
    color: var(--color-warm-cream);
    opacity: 0.4;
  }

  /* Resolution Slide */
  .resolution-slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.8s ease;
    background-color: #0c1509;
    z-index: 5;
    padding: 0 24px;
  }

  .resolution-slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  .resolution-glyphs {
    display: flex;
    gap: 8px;
    margin-bottom: 3rem;
    color: var(--color-gold);
  }

  .mini-glyph {
    width: 24px;
    height: 24px;
  }

  .res-statement {
    font-family: var(--font-display);
    font-size: var(--type-statement);
    font-style: italic;
    color: var(--color-warm-cream);
    margin: 0 0 1rem 0;
    line-height: 1.3;
  }

  .res-narrative {
    font-family: var(--font-display);
    font-size: var(--type-narrative);
    color: var(--color-warm-cream);
    opacity: 0.85;
    margin: 0 0 3rem 0;
  }

  .enter-button {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    background: transparent;
    border: 1px solid var(--color-gold);
    padding: 14px 44px;
    cursor: pointer;
    border-radius: 0;
    transition: background-color 0.4s ease, color 0.4s ease;
    margin-top: 2vh;
  }

  .enter-button:hover {
    background-color: var(--color-gold);
    color: #0c1509;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('opening-sequence');
    if (!container) return;

    // Check if user has already passed introduction in this session
    const isPassed = sessionStorage.getItem('ourorigin_threshold_passed');
    if (isPassed) {
      container.style.display = 'none';
      document.body.style.overflow = '';
      return;
    }

    // Lock page scrolling while sequence runs
    document.body.style.overflow = 'hidden';

    const slideContainer = document.querySelector('.slides-container');
    const slides = Array.from(document.querySelectorAll('.beat-slide')) as HTMLElement[];
    const progressSegments = Array.from(document.querySelectorAll('.progress-segment')) as HTMLElement[];
    const resolutionSlide = document.querySelector('.resolution-slide') as HTMLElement;
    const enterBtn = document.getElementById('enter-btn');

    if (!slideContainer || slides.length === 0 || !resolutionSlide || !enterBtn) return;

    // Is this first visit? (We check localStorage similar to other components)
    const isFirstVisit = !localStorage.getItem('ourorigin_explored_all');
    if (!isFirstVisit) {
      // If not first visit, hide labels
      slides.forEach(slide => {
        const lbl = slide.querySelector('.first-visit-label') as HTMLElement;
        if (lbl) lbl.style.display = 'none';
      });
    }

    // Set up shuffling: Keep 'product' slide last, shuffle the rest
    const otherSlides = slides.filter(s => s.getAttribute('data-id') !== 'product');
    const productSlide = slides.find(s => s.getAttribute('data-id') === 'product');

    // Retrieve or create session intro order
    let orderStr = sessionStorage.getItem('ourorigin_intro_order');
    let order: string[] = [];
    if (orderStr) {
      order = JSON.parse(orderStr);
    } else {
      order = otherSlides.map(s => s.getAttribute('data-id')!).sort(() => Math.random() - 0.5);
      sessionStorage.setItem('ourorigin_intro_order', JSON.stringify(order));
    }

    // Sort slides according to shuffled order, then append product last
    const shuffledSlides: HTMLElement[] = order.map(id => slides.find(s => s.getAttribute('data-id') === id)!);
    if (productSlide) shuffledSlides.push(productSlide);

    // Empty slide container and append in shuffled order
    slideContainer.innerHTML = '';
    shuffledSlides.forEach(slide => slideContainer.appendChild(slide));

    let activeIndex = 0;
    let autoAdvanceTimer: number | null = null;
    const beatDuration = 4000; // ~4 seconds

    // Check prefers-reduced-motion
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function renderSlide(index: number) {
      // Clear previous states
      slides.forEach(slide => slide.classList.remove('active'));
      progressSegments.forEach(seg => {
        const fill = seg.querySelector('.progress-segment-fill') as HTMLElement;
        if (fill) fill.style.transition = 'none';
      });

      if (index < 7) {
        const currentSlide = shuffledSlides[index];
        currentSlide.classList.add('active');

        // Fill previous progress bars fully, clear following ones, animate active one
        progressSegments.forEach((seg, sIdx) => {
          const fill = seg.querySelector('.progress-segment-fill') as HTMLElement;
          if (!fill) return;

          if (sIdx < index) {
            fill.style.width = '100%';
          } else if (sIdx === index) {
            fill.style.width = '0%';
            if (!prefersReducedMotion) {
              // Force reflow to restart transition
              void seg.offsetWidth;
              fill.style.transition = `width ${beatDuration}ms linear`;
              fill.style.width = '100%';
            }
          } else {
            fill.style.width = '0%';
          }
        });

        // Set auto-advance if allowed
        if (!prefersReducedMotion) {
          if (autoAdvanceTimer) clearTimeout(autoAdvanceTimer);
          autoAdvanceTimer = window.setTimeout(() => {
            advance();
          }, beatDuration);
        }
      } else {
        // Show Resolution Beat
        resolutionSlide.classList.add('active');
        progressSegments.forEach(seg => {
          const fill = seg.querySelector('.progress-segment-fill') as HTMLElement;
          if (fill) fill.style.width = '100%';
        });
      }
    }

    function advance() {
      if (activeIndex < 7) {
        activeIndex++;
        renderSlide(activeIndex);
      }
    }

    // Tap to advance anywhere
    container.addEventListener('click', (e) => {
      // Don't advance if they click the enter button itself
      if (e.target === enterBtn || enterBtn.contains(e.target as Node)) return;
      if (activeIndex < 7) {
        advance();
      }
    });

    // Enter Button Action
    enterBtn.addEventListener('click', () => {
      // Mark as passed in session
      sessionStorage.setItem('ourorigin_threshold_passed', 'true');
      localStorage.setItem('ourorigin_explored_all', 'true');

      // Animate out container
      container.classList.add('passed');
      document.body.style.overflow = '';

      // Clean up timer
      if (autoAdvanceTimer) clearTimeout(autoAdvanceTimer);
    });

    // Start!
    renderSlide(0);
  });
</script>
