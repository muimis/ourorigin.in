---
// src/components/LivingCanvas.astro
import { getCollection } from 'astro:content';
import OriginMark from './OriginMark.astro';

const products = await getCollection('products');
const origins = await getCollection('origins');

// We will scatter the nodes organically across the canvas.
// For stable SSR rendering, we use a deterministic pseudo-random approach based on the string name.
function getStableHash(str) {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = ((hash << 5) - hash) + str.charCodeAt(i);
    hash |= 0; 
  }
  return Math.abs(hash);
}

// 5 Pillars anchoring the experience
const pillars = ["Bio", "Geo", "Method", "People", "Product"];
---

<div id="living-canvas" class="living-canvas">
  
  <!-- 1. The Breathing Topography (Organic Life) -->
  <svg class="filter-def" aria-hidden="true">
    <filter id="breathing-topo" x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence type="fractalNoise" baseFrequency="0.005" numOctaves="2" result="noise" id="topo-turb" />
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="30" xChannelSelector="R" yChannelSelector="G" id="topo-disp" />
    </filter>
  </svg>
  
  <div class="canvas-bg">
    <img src="/topographic_pattern.svg" class="topo-layer" alt="Living Topography" />
  </div>

  <!-- 2. The Arrival (Visitor is Known) -->
  <div id="canvas-arrival" class="canvas-arrival">
    <h2 class="arrival-text">You have arrived at the source.</h2>
  </div>

  <!-- 3. The 5 Pillars (Anchors) -->
  <div class="pillar-anchors">
    <div class="pillar top-left">BIO</div>
    <div class="pillar top-right">GEO</div>
    <div class="pillar center-anchor"><OriginMark variant="gold" size={64} animate={true} /></div>
    <div class="pillar bottom-left">METHOD</div>
    <div class="pillar bottom-right">PEOPLE</div>
  </div>

  <!-- 4. The Typographic Constellation (Unconventional / Minimalism) -->
  <div class="constellation" id="constellation">
    {products.map((product) => {
      // Deterministic scattering between 15% and 85% of viewport
      const hashX = getStableHash(product.id + "x");
      const hashY = getStableHash(product.id + "y");
      const x = 15 + (hashX % 70);
      const y = 20 + (hashY % 60);
      
      const origin = origins.find(o => o.id === (typeof product.data.originSlug === 'object' ? product.data.originSlug.id : product.data.originSlug));
      
      return (
        <div 
          class="typographic-node" 
          style={`animation-delay: ${(hashX % 2000)}ms;`}
          data-id={product.id}
          data-name={product.data.name}
          data-botanical={product.data.botanicalName}
          data-origin={origin?.data.name || 'Unknown'}
          data-method={product.data.methodDescription || 'Traditional'}
          data-price={product.data.sizes[0].priceINR}
          data-weight={product.data.sizes[0].label}
          data-image={product.data.images?.packaging || ''}
        >
          <span class="node-origin">{origin?.data.name || 'Origin'}</span>
          <h2 class="node-title">{product.data.name}</h2>
          <span class="node-botanical">{product.data.botanicalName}</span>
        </div>
      );
    })}
  </div>

  <!-- 5. The Maximalist Dossier (Revealed on Click) -->
  <div id="dossier-panel" class="dossier-panel">
    <button id="close-dossier" class="close-btn">[ CLOSE ]</button>
    <div class="dossier-content">
      <div class="dossier-visual">
        <img id="dossier-img" src="" alt="" />
      </div>
      <div class="dossier-data">
        <h3 id="dossier-title" class="d-title">Title</h3>
        <p class="d-origin">[ GEO ] <span id="dossier-geo"></span></p>
        <p class="d-botanical">[ BIO ] <span id="dossier-bio"></span></p>
        <p class="d-method">[ METHOD ] <span id="dossier-method"></span></p>
        <p class="d-people">[ PEOPLE ] <span>Artisan Harvesters</span></p>
        
        <div class="d-action">
          <p class="d-price">[ PRODUCT ] ₹<span id="dossier-price"></span> / <span id="dossier-weight"></span></p>
          <button id="dossier-add-btn" class="brutalist-btn">ADD TO BASKET</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. The Arrival Sequence
    setTimeout(() => {
      document.getElementById('canvas-arrival').classList.add('fade-out');
      document.getElementById('constellation').classList.add('visible');
    }, 2500);

    // 2. The Living Breath (SVG Animation)
    const turb = document.getElementById('topo-turb');
    const disp = document.getElementById('topo-disp');
    let frame = 0;
    
    function breathe() {
      frame += 0.005;
      // Gently morph the base frequency
      const freq = 0.005 + Math.sin(frame) * 0.001;
      turb.setAttribute('baseFrequency', freq.toString());
      // Gently pulsate the displacement scale
      const scale = 30 + Math.cos(frame * 0.5) * 10;
      disp.setAttribute('scale', scale.toString());
      
      requestAnimationFrame(breathe);
    }
    
    // Start breathing if performance allows
    if(window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
       breathe();
    }

    // 3. Dossier Interaction
    const nodes = document.querySelectorAll('.typographic-node');
    const dossierPanel = document.getElementById('dossier-panel');
    const closeBtn = document.getElementById('close-dossier');
    
    // Elements to populate
    const dTitle = document.getElementById('dossier-title');
    const dGeo = document.getElementById('dossier-geo');
    const dBio = document.getElementById('dossier-bio');
    const dMethod = document.getElementById('dossier-method');
    const dPrice = document.getElementById('dossier-price');
    const dWeight = document.getElementById('dossier-weight');
    const dImg = document.getElementById('dossier-img');
    const dAddBtn = document.getElementById('dossier-add-btn');

    let currentProduct = null;

    nodes.forEach(node => {
      node.addEventListener('click', () => {
        // Populate Dossier
        dTitle.textContent = node.dataset.name;
        dGeo.textContent = node.dataset.origin;
        dBio.textContent = node.dataset.botanical;
        dMethod.textContent = node.dataset.method;
        dPrice.textContent = node.dataset.price;
        dWeight.textContent = node.dataset.weight;
        dImg.src = node.dataset.image;
        
        currentProduct = {
          id: node.dataset.id,
          name: node.dataset.name,
          price: node.dataset.price,
          origin: node.dataset.origin,
          weight: node.dataset.weight
        };

        dossierPanel.classList.add('is-open');
      });
    });

    closeBtn.addEventListener('click', () => {
      dossierPanel.classList.remove('is-open');
    });

    // 4. Cart Integration
    dAddBtn.addEventListener('click', () => {
      if(!currentProduct) return;
      
      window.dispatchEvent(new CustomEvent('cart-add', { 
        detail: {
          id: currentProduct.id,
          name: currentProduct.name,
          price: parseFloat(currentProduct.price),
          weight: currentProduct.weight,
          origin: currentProduct.origin
        }
      }));
      
      // Give feedback then open drawer
      dAddBtn.textContent = "[ ADDED ]";
      setTimeout(() => {
        dAddBtn.textContent = "ADD TO BASKET";
        window.dispatchEvent(new Event('open-cart'));
      }, 600);
    });
  });
</script>

<style>
  .living-canvas {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
  }

  .filter-def {
    position: absolute;
    width: 0;
    height: 0;
  }

  .canvas-bg {
    position: absolute;
    inset: -20%;
    z-index: 0;
    opacity: 0.15;
    pointer-events: none;
    /* Apply the living breath filter */
    filter: url(#breathing-topo);
  }

  .topo-layer {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .canvas-arrival {
    position: absolute;
    inset: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-forest-deep);
    transition: opacity 1.5s ease, visibility 1.5s;
  }

  .canvas-arrival.fade-out {
    opacity: 0;
    visibility: hidden;
  }

  .arrival-text {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 300;
    letter-spacing: 0.05em;
    animation: pulse 4s ease-in-out infinite alternate;
  }

  @keyframes pulse {
    0% { opacity: 0.5; }
    100% { opacity: 1; }
  }

  /* Pillars */
  .pillar-anchors {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
  }

  .pillar {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    opacity: 0.3;
    transition: opacity 0.5s ease;
  }
  .pillar:hover { opacity: 1; }

  .top-left { top: var(--space-2xl); left: var(--space-2xl); }
  .top-right { top: var(--space-2xl); right: var(--space-2xl); }
  .bottom-left { bottom: var(--space-2xl); left: var(--space-2xl); }
  .bottom-right { bottom: var(--space-2xl); right: var(--space-2xl); }
  .center-anchor {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.1;
  }

  /* Constellation Nodes */
  .constellation {
    position: absolute;
    inset: 0;
    z-index: 10;
    opacity: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-content: center;
    align-items: center;
    gap: var(--space-4xl) var(--space-3xl);
    padding: var(--space-2xl);
    transition: opacity 2s ease;
  }
  .constellation.visible {
    opacity: 1;
  }

  .typographic-node {
    position: relative;
    transform: translate(0, 0);
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    text-align: center;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s ease;
    opacity: 0.7;
    animation: drift 10s ease-in-out infinite alternate;
  }

  .typographic-node:hover {
    transform: scale(1.1);
    opacity: 1;
    z-index: 20;
  }

  @keyframes drift {
    0% { margin-top: 0; margin-left: 0; }
    100% { margin-top: 15px; margin-left: -15px; }
  }

  .node-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 5rem);
    line-height: 1;
    white-space: nowrap;
    text-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .node-origin {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-xs);
  }

  .node-botanical {
    font-family: var(--font-narrative);
    font-size: 1rem;
    font-style: italic;
    opacity: 0.5;
    margin-top: var(--space-xs);
  }

  /* Maximalist Dossier */
  .dossier-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 600px;
    height: 100vh;
    background: rgba(12, 21, 9, 0.7);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-left: 1px solid rgba(245, 237, 216, 0.1);
    z-index: 100;
    transform: translateX(100%);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    padding: var(--space-2xl);
  }

  .dossier-panel.is-open {
    transform: translateX(0);
  }

  .close-btn {
    align-self: flex-end;
    background: transparent;
    border: none;
    color: var(--color-warm-cream);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.3s ease;
    margin-bottom: var(--space-2xl);
  }
  .close-btn:hover { opacity: 1; }

  .dossier-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    flex-grow: 1;
    overflow-y: auto;
  }

  .dossier-visual {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(245, 237, 216, 0.03);
    border-radius: 8px;
  }
  
  .dossier-visual img {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.5));
  }

  .d-title {
    font-family: var(--font-display);
    font-size: 3rem;
    line-height: 1.1;
    margin-bottom: var(--space-xl);
  }

  .dossier-data p {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-bottom: var(--space-md);
    line-height: 1.5;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .dossier-data p span {
    font-family: var(--font-narrative);
    font-size: 1.25rem;
    color: rgba(245, 237, 216, 0.8);
  }

  .d-action {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid rgba(245, 237, 216, 0.1);
  }

  .brutalist-btn {
    width: 100%;
    padding: var(--space-xl);
    background: var(--color-warm-cream);
    color: var(--color-forest-deep);
    border: none;
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .brutalist-btn:hover {
    transform: translateY(-4px);
    background: #fff;
  }

  @media (max-width: 768px) {
    .node-title { font-size: 2.5rem; }
    .dossier-panel { max-width: 100%; padding: var(--space-xl); }
  }
</style>
