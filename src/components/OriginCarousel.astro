---
// src/components/OriginCarousel.astro
import { getCollection } from 'astro:content';

const origins = await getCollection('origins');
const orderedSlugs = ['nilgiris', 'idukki', 'wayanad', 'malabar-coast', 'thiruvananthapuram'];
const orderedOrigins = orderedSlugs.map(slug => origins.find(o => o.data.slug === slug)).filter(Boolean);

function getHighestElevation(elevationString) {
  if (!elevationString) return '';
  const cleanStr = elevationString.replace(/,/g, '');
  const matches = cleanStr.match(/\d+/g);
  if (matches) {
    return Math.max(...matches.map(Number));
  }
  return cleanStr.replace(/[^0-9]/g, '');
}

const originMarks = {
  'wayanad': 'var(--color-gold)',
  'idukki': 'var(--color-ruby)',
  'thiruvananthapuram': 'var(--color-copper)',
  'nilgiris': 'var(--color-forest-deep)',
  'kollam': 'var(--color-silver)',
  'malabar-coast': 'var(--color-primary)'
};
---

<section class="origin-carousel-section">
  <div class="section-header">
    <h2 class="section-title">The Origins</h2>
    <p class="section-subtitle">Swipe to explore the Western Ghats</p>
  </div>
  
  <div class="carousel-container">
    <div class="carousel-track">
      {orderedOrigins.map((origin) => (
        <a href={`/origins/${origin.data.slug}`} class="origin-card" style={`--mark-color: ${originMarks[origin.data.slug] || 'var(--color-forest-deep)'};`}>
          <div class="origin-mark"></div>
          <div class="origin-info">
            <h3 class="origin-name">{origin.data.name}</h3>
            <p class="origin-elevation">{getHighestElevation(origin.data.elevation)}M ELEVATION</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .origin-carousel-section {
    padding: var(--space-4xl) 0;
    background-color: var(--color-warm-cream);
    border-bottom: 1px solid rgba(13, 30, 17, 0.1);
  }

  .section-header {
    padding: 0 var(--space-xl);
    margin-bottom: var(--space-2xl);
    text-align: center;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-forest-deep);
    font-weight: 400;
  }

  .section-subtitle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-forest-deep);
    opacity: 0.6;
    margin-top: var(--space-sm);
  }

  .carousel-container {
    width: 100%;
    overflow-x: auto;
    /* Hide scrollbar for cleaner look */
    -ms-overflow-style: none;
    scrollbar-width: none;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    padding: 0 var(--space-xl);
  }

  .carousel-container::-webkit-scrollbar {
    display: none;
  }

  .carousel-track {
    display: flex;
    gap: var(--space-lg);
    /* Extra padding at the end so last item can be scrolled past */
    padding-right: var(--space-xl);
  }

  .origin-card {
    flex: 0 0 80%; /* 80% width on mobile shows a peek of the next card */
    max-width: 320px;
    background-color: #f7f6f2; /* slightly darker cream */
    border: 1px solid rgba(13, 30, 17, 0.1);
    border-radius: 4px;
    padding: var(--space-xl);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 240px;
    scroll-snap-align: center;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .origin-card:hover {
    transform: translateY(-4px);
    border-color: var(--mark-color);
  }

  .origin-mark {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background-color: var(--mark-color);
    margin-bottom: var(--space-2xl);
  }

  .origin-name {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-forest-deep);
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: var(--space-xs);
  }

  .origin-elevation {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-forest-deep);
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
