---
// src/components/HeroStorefront.astro
import OriginMark from './OriginMark.astro';
---
<section class="hero-storefront">
  <div class="hero-map-bg" aria-hidden="true">
    <div class="om-watermark">
      <OriginMark variant="reversed" size={600} animate={false} />
    </div>
    <img src="/topographic_pattern.svg" alt="" class="topo-map" loading="eager" />
  </div>

  <div class="hero-content">
    <p class="hero-provenance">Western Ghats · 5 Origins · 12 Yields</p>
    <h1 class="hero-title">From<br/>the Source.</h1>
    <p class="hero-subtitle">Spices and ingredients from the Western Ghats.<br/>Traceable to the person who harvested them.</p>
    <a href="#yields" class="cta-primary">Explore the Harvest</a>
  </div>
</section>

<style>
  .hero-storefront {
    position: relative;
    width: 100%;
    min-height: 100svh;
    min-height: 100vh; /* fallback */
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-warm-cream);
    overflow: hidden;
  }

  /* Topographic map layer */
  .hero-map-bg {
    position: absolute;
    inset: -5%;
    z-index: 1;
    overflow: hidden;
    opacity: 0.1;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .topo-map {
    width: 110%;
    height: 110%;
    object-fit: cover;
    transform: scale(1.02);
    transition: transform 30s linear;
    will-change: transform;
  }

  .hero-storefront:hover .topo-map {
    transform: scale(1.06);
  }

  .om-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.04;
  }

  .hero-content {
    text-align: center;
    position: relative;
    z-index: 3;
    padding: var(--space-xl);
    max-width: 900px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-provenance {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-forest-deep);
    opacity: 0.5;
    margin: 0 0 var(--space-xl);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 12vw, 9rem);
    line-height: 0.95;
    color: var(--color-forest-deep);
    margin: 0 0 var(--space-xl);
    font-weight: 300;
    letter-spacing: -0.03em;
  }

  .hero-subtitle {
    font-family: var(--font-narrative);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-forest-deep);
    line-height: 1.6;
    margin: 0 0 var(--space-3xl);
    opacity: 0.7;
    max-width: 480px;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.5rem;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    border-radius: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.3s ease;
    min-height: 48px;
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    background-color: #000;
  }

  .cta-primary:active {
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .hero-subtitle br {
      display: none;
    }
    .hero-content {
      padding: var(--space-xl) var(--space-lg);
    }
  }
</style>
