---
// src/components/HeroStorefront.astro
import OriginMark from './OriginMark.astro';
---
<section class="hero-storefront">
  <div class="hero-map-bg">
    <div class="om-watermark">
      <OriginMark variant="gold" size={800} animate={false} />
    </div>
    <img src="/topographic_pattern.svg" alt="" aria-hidden="true" class="topo-map" />
  </div>
  <div class="hero-content">
    <div class="pillars-signature">
      <span>Bio</span><span class="dot"></span>
      <span>Geo</span><span class="dot"></span>
      <span>Method</span><span class="dot"></span>
      <span>People</span><span class="dot"></span>
      <span>Product</span>
    </div>
    <h1 class="hero-title">Connecting<br/>the Universe.</h1>
    <p class="hero-subtitle">Boundless origins. A singular philosophy. Experienceable at the source.</p>
    <a href="#yields" class="cta-primary">Shop the Harvest</a>
  </div>
</section>

<style>
  .hero-storefront {
    position: relative;
    width: 100%;
    min-height: 90vh; /* Leave room for header / next section */
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-warm-cream);
    overflow: hidden;
    padding-top: var(--space-4xl); /* Account for header */
  }

  /* Topographic map layer */
  .hero-map-bg {
    position: absolute;
    inset: -10%;
    z-index: 1;
    overflow: hidden;
    opacity: 0.15;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .topo-map {
    width: 120%;
    height: 120%;
    object-fit: cover;
    animation: slow-pan 60s linear infinite alternate;
  }

  .om-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.05;
    mix-blend-mode: overlay;
  }

  @keyframes slow-pan {
    0% { transform: translate(-2%, -2%) scale(1.05); }
    100% { transform: translate(2%, 2%) scale(1.05); }
  }

  /* Optional: subtle noise overlay for premium feel */
  .hero-storefront::after {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.04;
    z-index: 2;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  }

  .hero-content {
    text-align: center;
    position: relative;
    z-index: 3;
    padding: var(--space-xl);
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pillars-signature {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-forest-deep);
    opacity: 0.7;
  }

  .pillars-signature .dot {
    width: 3px;
    height: 3px;
    background-color: var(--color-forest-deep);
    border-radius: 50%;
    opacity: 0.5;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 8rem);
    line-height: 1;
    color: var(--color-forest-deep);
    margin-bottom: var(--space-lg);
    font-weight: 400;
    letter-spacing: -0.02em;
    text-shadow: 0 4px 20px rgba(245, 237, 216, 0.5); /* subtle glow to lift off topo map */
  }

  .hero-subtitle {
    font-family: var(--font-mono);
    font-size: clamp(0.875rem, 2vw, 1rem);
    color: var(--color-forest-deep);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2xl);
    opacity: 0.8;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.5rem;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border-radius: 9999px;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.3s ease;
    /* Minimum touch target 48px */
    min-height: 48px;
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    background-color: #0d1e11; /* slightly darker forest */
  }

  .cta-primary:active {
    transform: translateY(0);
  }
</style>
