---
// src/components/GlobalNav.astro
---

<nav class="global-nav">
  <a href="/observations">Observations</a> &middot; 
  <a href="/why">Why this exists.</a> &middot; 
  <a href="/contact">Contact</a> &middot; 
  <button id="global-yields-btn" class="nav-button">All Yields</button>
</nav>

<style>
  .global-nav {
    position: fixed;
    top: 2rem;
    left: 2rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    color: var(--color-warm-cream);
    z-index: 1000;
    opacity: 0.8;
  }
  
  .global-nav a, .nav-button {
    color: var(--color-warm-cream);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: opacity 0.2s ease;
  }
  
  .nav-button {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    cursor: pointer;
  }

  .global-nav a:hover, .nav-button:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  @media (max-width: 768px) {
    .global-nav {
      top: 1.5rem;
      left: 1.5rem;
      right: 1.5rem;
      font-size: 0.75rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem 0.5rem;
      align-items: center;
    }
  }
</style>

<script>
  const btn = document.getElementById('global-yields-btn');
  if (btn) {
    btn.addEventListener('click', () => {
      window.dispatchEvent(new Event('open-all-yields-panel'));
    });
  }
</script>
