---
// src/components/CartDrawer.astro
const whatsappNumber = "+919645555668";
---
<div id="cart-overlay" class="cart-overlay" aria-hidden="true">
  <div class="cart-backdrop"></div>
  <aside class="cart-drawer" role="dialog" aria-labelledby="cart-title">
    <header class="cart-header">
      <h2 id="cart-title" class="cart-title">Your Basket</h2>
      <button class="cart-close-btn" aria-label="Close basket">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </header>

    <div class="cart-body">
      <ul id="cart-items-list" class="cart-items-list">
        <!-- Rendered by client JS -->
      </ul>
      <div id="cart-empty-state" class="cart-empty-state">
        <p>Your basket is empty.</p>
        <p class="empty-sub">Explore the harvest to add items.</p>
      </div>
    </div>

    <footer class="cart-footer">
      <div class="cart-summary">
        <span class="summary-label">Subtotal</span>
        <span id="cart-total-price" class="summary-value">₹0</span>
      </div>
      <p class="summary-note">Shipping calculated during concierge confirmation.</p>
      
      <button id="whatsapp-checkout-btn" class="whatsapp-checkout-btn" disabled>
        <svg class="wa-icon" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
        </svg>
        Complete via WhatsApp
      </button>
    </footer>
  </aside>
</div>

<style>
  /* 2050 Design: Glassmorphism & Smooth Transitions */
  .cart-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    justify-content: flex-end;
    pointer-events: none; /* Let clicks pass through when hidden */
  }

  .cart-overlay.is-open {
    pointer-events: auto;
  }

  .cart-backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(12, 21, 9, 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity 0.4s var(--ease-settle);
  }

  .cart-overlay.is-open .cart-backdrop {
    opacity: 1;
  }

  .cart-drawer {
    position: relative;
    width: 100%;
    max-width: 440px;
    height: 100svh;
    background-color: var(--color-warm-cream);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.5s var(--ease-settle);
    box-shadow: -10px 0 30px rgba(0, 0, 0, 0.1);
  }

  .cart-overlay.is-open .cart-drawer {
    transform: translateX(0);
  }

  .cart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-xl);
    border-bottom: 1px solid rgba(13, 30, 17, 0.1);
  }

  .cart-title {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-forest-deep);
    font-weight: 400;
  }

  .cart-close-btn {
    background: transparent;
    border: none;
    color: var(--color-forest-deep);
    cursor: pointer;
    padding: var(--space-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .cart-close-btn:hover {
    transform: rotate(90deg);
  }

  .cart-body {
    flex-grow: 1;
    overflow-y: auto;
    padding: var(--space-xl);
    position: relative;
  }

  .cart-empty-state {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-family: var(--font-mono);
    color: var(--color-forest-deep);
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .cart-empty-state .empty-sub {
    font-size: 0.75rem;
    opacity: 0.5;
    margin-top: var(--space-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cart-items-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  /* When we have items, toggle visibility */
  .cart-body.has-items .cart-empty-state {
    opacity: 0;
    pointer-events: none;
  }

  .cart-body.has-items .cart-items-list {
    opacity: 1;
    pointer-events: auto;
  }

  .cart-footer {
    padding: var(--space-xl);
    border-top: 1px solid rgba(13, 30, 17, 0.1);
    background-color: var(--color-warm-cream);
  }

  .cart-summary {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-xs);
  }

  .summary-label {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-forest-deep);
    opacity: 0.7;
  }

  .summary-value {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-forest-deep);
  }

  .summary-note {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-forest-deep);
    opacity: 0.5;
    margin-bottom: var(--space-xl);
  }

  .whatsapp-checkout-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: 1.2rem;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    border: none;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    border-radius: 4px;
    transition: transform 0.3s ease, background-color 0.3s ease, opacity 0.3s ease;
  }

  .whatsapp-checkout-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .whatsapp-checkout-btn:not(:disabled):hover {
    background-color: #000;
    transform: translateY(-2px);
  }

  .whatsapp-checkout-btn:not(:disabled):active {
    transform: translateY(0);
  }
</style>

<script>
  import { cartState } from '../scripts/cart.js';

  // Constants
  const WHATSAPP_NUMBER = "919645555668"; // Normalized without '+'

  // DOM Elements
  const overlay = document.getElementById('cart-overlay');
  const backdrop = document.querySelector('.cart-backdrop');
  const closeBtn = document.querySelector('.cart-close-btn');
  const body = document.querySelector('.cart-body');
  const itemsList = document.getElementById('cart-items-list');
  const totalPriceEl = document.getElementById('cart-total-price');
  const checkoutBtn = document.getElementById('whatsapp-checkout-btn');

  // Currency formatter
  const formatPrice = (price) => {
    return new Intl.NumberFormat('en-IN', {
      style: 'currency',
      currency: 'INR',
      minimumFractionDigits: 0
    }).format(price);
  };

  // Render Cart Item HTML
  const renderCartItem = (item) => `
    <li class="cart-item" style="display: flex; justify-content: space-between; align-items: center; padding-bottom: var(--space-lg); border-bottom: 1px solid rgba(13,30,17,0.05);">
      <div style="display: flex; flex-direction: column;">
        <span style="font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; opacity: 0.6;">${item.origin}</span>
        <span style="font-family: var(--font-display); font-size: 1.25rem;">${item.name}</span>
        <span style="font-family: var(--font-mono); font-size: 0.75rem; opacity: 0.8;">${formatPrice(item.price)} / ${item.weight}</span>
      </div>
      <div style="display: flex; align-items: center; gap: var(--space-md);">
        <div style="display: flex; align-items: center; border: 1px solid rgba(13,30,17,0.2); border-radius: 99px;">
          <button data-id="${item.id}" class="qty-btn dec" style="background:none; border:none; padding: 4px 12px; cursor:pointer;">-</button>
          <span style="font-family: var(--font-mono); font-size: 0.875rem; min-width: 1ch; text-align: center;">${item.quantity}</span>
          <button data-id="${item.id}" class="qty-btn inc" style="background:none; border:none; padding: 4px 12px; cursor:pointer;">+</button>
        </div>
      </div>
    </li>
  `;

  // Update UI on state change
  window.addEventListener('cart-updated', (e) => {
    const { items, totalItems, totalPrice } = e.detail;
    
    // Toggle Empty State
    if (totalItems > 0) {
      body.classList.add('has-items');
      checkoutBtn.disabled = false;
    } else {
      body.classList.remove('has-items');
      checkoutBtn.disabled = true;
    }

    // Render List
    itemsList.innerHTML = items.map(renderCartItem).join('');
    totalPriceEl.textContent = formatPrice(totalPrice);

    // Bind quantity buttons
    document.querySelectorAll('.qty-btn').forEach(btn => {
      btn.addEventListener('click', (ev) => {
        const id = ev.target.dataset.id;
        const delta = ev.target.classList.contains('inc') ? 1 : -1;
        cartState.updateQuantity(id, delta);
      });
    });
  });

  // Open/Close logic
  window.addEventListener('open-cart', () => {
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden'; // prevent bg scrolling
  });

  const closeCart = () => {
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  closeBtn.addEventListener('click', closeCart);
  backdrop.addEventListener('click', closeCart);

  // WhatsApp Generation Logic
  checkoutBtn.addEventListener('click', () => {
    const items = cartState.items;
    if (items.length === 0) return;

    let text = `Hello OurOrigin, I would like to reserve the following harvest:\n\n`;
    
    items.forEach(item => {
      text += `${item.quantity}x ${item.name} (${item.origin}) - ${formatPrice(item.price * item.quantity)}\n`;
    });

    text += `\n*Subtotal: ${formatPrice(cartState.getTotalPrice())}*\n\nPlease confirm shipping and payment details.`;

    const encodedText = encodeURIComponent(text);
    const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodedText}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>
