---
import OriginMark from './OriginMark.astro';
import LiveWeather from './LiveWeather.astro';

export interface Props {
  origin?: any;
  product?: any;
}

const { origin, product } = Astro.props;

const botanicalStates = {
  'nilgiris': 'LEAF FLUSH',
  'idukki': 'POD DEVELOPMENT',
  'wayanad': 'VINE MATURATION',
  'thiruvananthapuram': 'RHIZOME EXPANSION',
  'malabar-coast': 'DORMANT'
};
const botanicalState = origin ? botanicalStates[origin.data.slug] : '';


// Build the content for the first 4 strata
const strata = [
  { 
    id: 'canopy', 
    evidence: origin ? `${origin.data.elevation} · ${origin.data.bioregion}`.toUpperCase() : '',
    narrative: origin ? origin.data.narrative.canopy : '',
    image: origin ? origin.data.images.canopy : null, 
    hasWeather: true 
  },
  { 
    id: 'land', 
    evidence: origin ? origin.data.soil.toUpperCase() : '',
    narrative: origin ? origin.data.narrative.land : '',
    image: origin ? origin.data.images.land : null, 
    hasWeather: false 
  },
  { 
    id: 'hand', 
    evidence: origin ? origin.data.method.toUpperCase() : '',
    narrative: origin ? origin.data.narrative.hand : '',
    image: origin ? origin.data.images.hand : null, 
    hasWeather: false 
  },
  { 
    id: 'specimen', 
    evidence: product ? `${product.data.botanicalName} · BATCH ${product.data.batchRef}${product.data.harvestMonth && !['Seasonal', 'Ongoing'].includes(product.data.harvestMonth) ? ' · ' + product.data.harvestMonth : ''}`.toUpperCase() : '',
    narrative: product ? product.data.specimenCopy : '',
    botanicalName: product ? product.data.botanicalName : null,
    image: origin ? origin.data.images.specimen : null, 
    hasWeather: false 
  }
];

// Dynamically fetch the origin mask URL, but for Wayanad use the new solid SVG based on the uploaded border
const maskUrl = origin?.data.slug === 'wayanad' ? encodeURI('/maps/wayanadu map cut_solid.svg') : '';


// Determine sizes for the offering stratum
const sizes = product ? product.data.sizes : [];
---

<div class="depth-experience-container">
  <!-- Depth Gauge -->
  <div class="depth-gauge-wrapper">
    <OriginMark variant="gold" size={48} id="depth-gauge-mark" />
  </div>

  <div class="pin-container" data-origin-slug={origin?.data.slug} data-product-slug={product?.id} data-origin-name={origin?.data.name} data-product-name={product?.data.name}>
    {strata.map((s, i) => (
      <section 
        class={`stratum stratum-${s.id} ${maskUrl ? 'has-terrain-mask' : ''}`} 
        style={`z-index: ${i + 1}; height: 100dvh; width: 100%; transform: translateY(${i === 0 ? '0' : '100dvh'}); ${maskUrl ? `--mask-url: url('${maskUrl}');` : ''}`}
      >
        <div class="stratum-content">
          {s.image && !origin?.data.images.isPlaceholderImagery && (
            <div class={`stratum-image ${s.id === 'hand' ? 'image-preserve-people' : ''}`} style={`background-image: url('${s.image}')`}></div>
          )}
          <div class="stratum-shadow"></div>
          <div class="stratum-text-container">
            <h2 class="stratum-evidence">
              {s.evidence}
              {s.hasWeather && origin && <><span class="weather-separator">·</span><LiveWeather coordinates={origin.data.coordinates} originName={origin.data.name} /></>}
            </h2>
            {s.id === 'specimen' && s.botanicalName && (
              <>
                <p class="specimen-botanical-name">{s.botanicalName}</p>
                <div class="specimen-telemetry-handoff">
                  <span class="telemetry-label">STATE:</span> <span class="telemetry-value">{botanicalState}</span>
                </div>
              </>
            )}
            <p class="stratum-narrative">{s.narrative}</p>
          </div>
        </div>
      </section>
    ))}

    <!-- Offering Stratum (Custom Layout) -->
    <section class={`stratum stratum-offering ${maskUrl ? 'has-terrain-mask' : ''}`} style={`z-index: 10000; height: 100dvh; width: 100%; transform: translateY(100dvh); ${maskUrl ? `--mask-url: url('${maskUrl}');` : ''}`}>
      {product.data.images?.packaging && product.data.images.packaging.trim() !== '' && (
        <div class="stratum-image" style={`background-image: url('${product.data.images.packaging}')`}></div>
      )}
      <div class="stratum-content offering-content">
        <div class="stratum-shadow"></div>
        <h2 class="stratum-evidence">THE HARVEST</h2>
        
        {product.data.offeringCopy && (
          <p class="offering-copy">{product.data.offeringCopy}</p>
        )}
        
        <p class="yield-status">YIELD STATUS: STRICTLY LIMITED (WILD HARVEST)</p>
        
        <div class="offering-sizes-grid">
          {sizes.map((size) => (
            <div class="offering-size-row">
              <span class="size-label">{size.label}</span>
              <span class="size-price">₹{size.priceINR}</span>
            </div>
          ))}
        </div>
        
        <div class="offering-actions">
          <button class="add-to-ledger-btn" id="add-to-ledger-btn" aria-label="Add to Ledger">
            [ ADD TO BASKET ]
          </button>
          <a href="/" class="return-matrix-link">Return to the Matrix</a>
        </div>
      </div>
    </section>
  </div>
</div>

<style>
  .depth-experience-container {
    position: relative;
    width: 100%;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    /* GSAP will pin this container */
  }

  .pin-container {
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    position: relative;
  }

  .depth-gauge-wrapper {
    position: fixed;
    right: 24px;
    top: 0; 
    z-index: 9999;
    cursor: pointer;
  }

  .stratum {
    position: absolute;
    top: 0;
    left: 0;
    width: 110vw; /* Extended to allow right-side overlap during diagonal left stack */
    will-change: transform;
  }

  .stratum-content {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-forest-deep);
    transform-origin: top center;
    will-change: transform;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.4);
    position: relative;
    overflow: hidden;
  }

  .stratum-shadow {
    position: absolute;
    inset: 0;
    background-color: #000;
    opacity: 0;
    pointer-events: none;
    z-index: 5;
  }

  .stratum-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    /* Blend photography subtly into the Forest Deep brand color */
    opacity: 0.55;
    mix-blend-mode: luminosity;
    z-index: 1;
    pointer-events: none;
  }
  
  /* Hand stratum uses default or preserve-people styling */

  /* Terrain Cuts / Map Borders - Dynamically injected via --mask-url to match the active origin */
  .has-terrain-mask {
    /* We use two masks:
       1. The map cut SVG (placed top right, preserves its aspect ratio of ~0.61).
       2. A solid black gradient (placed top left, fills the remaining width of the screen). 
       This flawlessly handles all screen sizes (mobile and desktop) without hitting SVG rendering limits. */
    -webkit-mask-image: var(--mask-url), linear-gradient(black, black);
    mask-image: var(--mask-url), linear-gradient(black, black);
    
    -webkit-mask-repeat: no-repeat, no-repeat;
    mask-repeat: no-repeat, no-repeat;
    
    /* The map height is 100%. The map width naturally becomes 0.61 * 100vh. 
       The gradient covers the remaining width (100% - 60vh) so it overlaps slightly to prevent gaps. */
    -webkit-mask-size: auto 100%, calc(100% - 60vh) 100%;
    mask-size: auto 100%, calc(100% - 60vh) 100%;
    
    -webkit-mask-position: top right, top left;
    mask-position: top right, top left;
  }
  
  .stratum-content {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    /* Add padding so content doesn't get clipped by the top/right topographical cuts */
    padding-top: 8vh;
    padding-right: 12vw;
  }
  
  /* Additional layer specific styles can go here if needed */

  .stratum-image.image-preserve-people {
    opacity: 0.55;
    mix-blend-mode: normal;
  }

  /* Basic typographic styling */
  .stratum-text-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    z-index: 10;
    position: relative;
    max-width: 480px;
    padding: 0 2rem;
    text-align: center;
  }

  .stratum-evidence {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--color-warm-cream);
    margin: 0;
    opacity: 0.8;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .stratum-narrative {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 400;
    color: var(--color-warm-cream);
    line-height: 1.5;
    margin: 0;
  }
  
  .specimen-botanical-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    font-style: italic;
    color: var(--color-gold);
    margin: -1rem 0 0 0;
  }

  .specimen-telemetry-handoff {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--color-warm-cream);
    margin: -1rem 0 0 0;
    display: flex;
    gap: 0.5rem;
  }
  .specimen-telemetry-handoff .telemetry-label {
    opacity: 0.5;
  }
  .specimen-telemetry-handoff .telemetry-value {
    opacity: 0.9;
  }

  .yield-status {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    text-transform: uppercase;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .weather-separator {
    margin: 0 0.2rem;
  }

  .offering-content {
    flex-direction: column;
  }

  .offering-sizes-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 2rem 0;
    width: 100%;
    max-width: 320px;
    z-index: 10;
  }

  .offering-size-row {
    display: flex;
    justify-content: space-between;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(245, 237, 216, 0.2);
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    color: var(--color-warm-cream);
  }

  .size-price {
    color: var(--color-gold);
  }

  /* Action Styles */
  .offering-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    z-index: 10;
    position: relative;
    width: 100%;
    max-width: 320px;
  }

  .view-all-yields-btn {
    width: 100%;
    background: transparent;
    color: var(--color-warm-cream);
    border: 1px solid rgba(245, 237, 216, 0.3);
    font-family: 'Cormorant Garamond', serif;
    font-size: 14px;
    padding: 1.2rem;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.3s ease;
  }
  
  .view-all-yields-btn:hover {
    background: rgba(245, 237, 216, 0.1);
    border-color: rgba(245, 237, 216, 0.8);
  }

  .return-matrix-link {
    display: inline-block;
    color: var(--color-warm-cream);
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    margin-top: 1rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }
  .return-matrix-link:hover {
    opacity: 1;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  class DepthExperience {
    constructor() {
      this.initStrata();
      this.initDepthGauge();
      this.initPurchaseAction();
      
      document.fonts.ready.then(() => {
        ScrollTrigger.refresh();
      });
    }

    initPurchaseAction() {
      const openYieldsBtn = document.getElementById('open-yields-btn');
      if (openYieldsBtn) {
        openYieldsBtn.addEventListener('click', () => {
          // Open All Yields panel
          window.dispatchEvent(new Event('open-all-yields-panel'));
        });
      }
    }

    initStrata() {
      const strata = document.querySelectorAll('.stratum');
      
      // Start all strata below the viewport EXCEPT the first one
      // We start X at 0 so they stay perfectly vertically aligned for a pure top-stack effect
      gsap.set(strata, { 
        y: (i) => i === 0 ? "0dvh" : "100dvh",
        x: "0vw"
      });

      // Create a master pinned timeline
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: ".depth-experience-container",
          start: "top top",
          end: "+=350%", // Slowed down from 150% to give a luxurious, deliberate pace
          scrub: true,
          pin: ".pin-container",
          anticipatePin: 1,
          snap: {
            snapTo: "labels",
            duration: { min: 0.2, max: 0.6 },
            delay: 0.1,
            ease: "power1.inOut"
          }
        }
      });
      
      tl.addLabel("step0"); // Base state

      strata.forEach((stratum, index) => {
        if (index === 0) return; // First stratum is already at y:0

        const prevStratum = strata[index - 1];
        const prevContent = prevStratum.querySelector('.stratum-content');
        const prevShadow = prevStratum.querySelector('.stratum-shadow');
        const prevTitle = prevStratum.querySelector('.stratum-title');
        const prevSelector = prevStratum.querySelector('.size-selector'); 

        let topOffset = index * 2; // Halved distance (2vh down)
        
        // The offering page shouldn't be stacked; it should cover the full screen
        if (stratum.classList.contains('stratum-offering')) {
          topOffset = 0;
        }

        const label = `step${index}`;

        // 1. Current stratum slides straight up to its designated resting offset (top-stacking)
        tl.to(stratum, {
          y: `${topOffset}dvh`,
          ease: "none",
          duration: 1
        }, label)
        
        // 2. Previous stratum darkens completely so it becomes a receding shadow band
        .to(prevShadow, {
          opacity: 0.5,
          ease: "none",
          duration: 1
        }, label)
        
        // 3. Previous stratum text transforms into a large, faint watermark behind the organic terrain cut
        .to(prevStratum.querySelector('.stratum-text-container'), {
          y: "-30dvh",
          scale: 1.8,
          opacity: 0.08,
          ease: "none",
          duration: 1
        }, label);
      });
      
      tl.addLabel("step" + strata.length); // Final snap point
      
      // Gap 5: Mark as explored when reaching the Offering stratum
      const pinContainer = document.querySelector('.pin-container');
      const originSlug = pinContainer?.getAttribute('data-origin-slug');
      const productSlug = pinContainer?.getAttribute('data-product-slug');
      
      if (originSlug && productSlug) {
        ScrollTrigger.create({
          trigger: ".stratum-offering",
          start: "top center",
          containerAnimation: tl, 
          // Note: since we are animating the strata via timeline and pinning the container,
          // it's easier to just use the timeline's progress.
          // The offering stratum is the last index.
        });
        
        // Wait, since we are doing manual y translates instead of x translates, ScrollTrigger containerAnimation doesn't apply to vertical y translations directly.
        // We can just use the timeline's onUpdate or onComplete.
        // When progress > 0.8, we assume they reached the end.
      }
      
      // Update: we just attach an onUpdate to the main timeline.
      tl.eventCallback('onUpdate', function() {
        if (this.progress() > 0.8 && originSlug && productSlug) {
          localStorage.setItem(`ourorigin_explored_${originSlug}_${productSlug}`, 'true');
        }
      });
    }

    initDepthGauge() {
      const gauge = document.querySelector('.depth-gauge-wrapper');
      const container = document.querySelector('.depth-experience-container');

      if (gauge && container) {
        gsap.fromTo(gauge, 
          { y: "10dvh" }, 
          { 
            y: "80dvh",
            ease: "none",
            scrollTrigger: {
              trigger: container,
              start: "top top",
              end: "+=200%", // Matches the new faster pin duration
              scrub: true
            }
          }
        );

        gauge.addEventListener('click', () => {
          window.location.href = '/';
        });
      }

      const yieldsBtn = document.getElementById('open-yields-btn');
      if (yieldsBtn) {
        yieldsBtn.addEventListener('click', () => {
          window.dispatchEvent(new Event('open-all-yields-panel'));
        });
      }
    }
  }

  // Ensure initialization happens safely
  new DepthExperience();
</script>
