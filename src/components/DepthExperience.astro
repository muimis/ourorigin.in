---
import OriginMark from './OriginMark.astro';

export interface Props {
  origin?: any;
  product?: any;
}

const { origin, product } = Astro.props;

// Build the content for the first 4 strata
const strata = [
  { id: 'canopy', title: origin ? `CANOPY — ${origin.data.elevation}` : 'CANOPY — [origin.elevation]' },
  { id: 'land', title: origin ? `LAND — ${origin.data.soil}` : 'LAND — [origin.soil]' },
  { id: 'hand', title: origin && product ? `HAND — ${origin.data.method} / ${product.data.methodDescription}` : 'HAND — [origin.method]' },
  { id: 'specimen', title: product ? `SPECIMEN — ${product.data.botanicalName}` : 'SPECIMEN — [product.botanicalName]' }
];

// Determine sizes for the offering stratum
const sizes = product ? product.data.sizes : [];

---

<div class="depth-experience-container">
  <!-- Depth Gauge -->
  <div class="depth-gauge-wrapper">
    <OriginMark variant="gold" size={48} id="depth-gauge-mark" />
  </div>

  {strata.map((s, i) => (
    <section 
      class={`stratum stratum-${s.id}`} 
      style={`z-index: ${i + 1}; top: ${i * 5}dvh;`}
    >
      <div class="stratum-content">
        <h2>{s.title}</h2>
      </div>
    </section>
  ))}

  <!-- Offering Stratum (Custom Layout) -->
  <section class="stratum stratum-offering" style={`z-index: 5; top: 20dvh;`}>
    <div class="stratum-content offering-content">
      <h2>OFFERING</h2>
      
      {sizes.length > 0 ? (
        <div class="size-selector">
          <div class="size-options">
            {sizes.map((sizeObj: any, idx: number) => (
              <label class="size-option">
                <input 
                  type="radio" 
                  name="product-size" 
                  value={sizeObj.label} 
                  data-price={sizeObj.priceINR}
                  checked={idx === 0}
                />
                <span class="size-label">{sizeObj.label}</span>
                <span class="size-price">₹{sizeObj.priceINR}</span>
              </label>
            ))}
          </div>
          <button id="purchase-btn" class="primary-btn">Purchase</button>
        </div>
      ) : (
        <p>OFFERING — [product.sizes]</p>
      )}
    </div>
  </section>
</div>

<style>
  .depth-experience-container {
    position: relative;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    /* Extra padding at bottom so the final stratum can scroll fully up if needed,
       but actually each section is 100dvh, so total scroll is natural. */
    padding-bottom: 20dvh; 
  }

  .depth-gauge-wrapper {
    position: fixed;
    right: 24px;
    top: 0; 
    z-index: 9999;
    cursor: pointer;
  }

  .stratum {
    position: sticky;
    height: 100dvh;
    width: 100vw;
    display: flex;
    overflow: hidden;
  }

  .stratum-content {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-forest-deep);
    transform-origin: top center;
    will-change: transform, opacity;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.3);
  }

  /* Basic typographic styling for the placeholders */
  .stratum-content h2 {
    font-family: var(--font-narrative);
    font-size: var(--text-size-stratum-title);
    font-weight: 300;
    letter-spacing: 0.05em;
    margin: 0 0 1rem 0;
  }

  .offering-content {
    flex-direction: column;
  }

  /* Size Selector Styles */
  .size-selector {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }

  .size-options {
    display: flex;
    gap: 1rem;
  }

  .size-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 1.5rem;
    border: 1px solid rgba(245, 237, 216, 0.2);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .size-option:has(input:checked) {
    border-color: var(--color-gold);
    background-color: rgba(166, 124, 60, 0.1);
  }

  .size-option input {
    display: none;
  }

  .size-label {
    font-family: var(--font-evidence);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .size-price {
    font-family: var(--font-narrative);
    font-size: 1.2rem;
    color: var(--color-gold);
  }

  .primary-btn {
    background-color: var(--color-gold);
    color: var(--color-forest-deep);
    border: none;
    padding: 1rem 3rem;
    font-family: var(--font-institutional);
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .primary-btn:hover {
    background-color: var(--color-warm-cream);
  }

  /* Temporary differentiated backgrounds for Phase 1 testing */
  .stratum-canopy .stratum-content { background-color: #0c1509; }
  .stratum-land .stratum-content { background-color: #111a12; }
  .stratum-hand .stratum-content { background-color: #152016; }
  .stratum-specimen .stratum-content { background-color: #1a261a; }
  .stratum-offering .stratum-content { background-color: #1f2d1e; }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  class DepthExperience {
    constructor() {
      this.initStrata();
      this.initDepthGauge();
      this.initPurchaseAction();
      
      // Ensure ScrollTrigger recalculates after custom fonts (display=swap) load
      document.fonts.ready.then(() => {
        ScrollTrigger.refresh();
      });
    }

    initPurchaseAction() {
      const btn = document.getElementById('purchase-btn');
      if (btn) {
        btn.addEventListener('click', () => {
          const selected = document.querySelector('input[name="product-size"]:checked') as HTMLInputElement;
          if (selected) {
            console.log(`[Action] Add to Cart: ${selected.value} at ₹${selected.dataset.price}`);
          }
        });
      }
    }

    initStrata() {
      const strata = document.querySelectorAll('.stratum');
      
      strata.forEach((stratum, index) => {
        // The last stratum does not scale down (it's the final layer)
        if (index === strata.length - 1) return;

        const content = stratum.querySelector('.stratum-content');
        const nextStratum = strata[index + 1];

        // Animate the current stratum scaling down as the *next* stratum slides up
        gsap.to(content, {
          scale: 0.94,
          opacity: 0.3,
          ease: "none",
          scrollTrigger: {
            trigger: nextStratum,
            // Start when the top of the next stratum enters the bottom of the viewport
            start: "top bottom",
            // End when the top of the next stratum hits its own sticky 'top' position
            // Since nextStratum has top: (index+1)*5 dvh, we use that as the end point.
            end: `top ${(index + 1) * 5}%`,
            scrub: true,
          }
        });
      });
    }

    initDepthGauge() {
      const gauge = document.querySelector('.depth-gauge-wrapper');
      const container = document.querySelector('.depth-experience-container');

      if (gauge && container) {
        // Bind the gauge movement to the overall container scroll progress
        gsap.fromTo(gauge, 
          { y: "10dvh" }, 
          { 
            y: "80dvh",
            ease: "none",
            scrollTrigger: {
              trigger: container,
              start: "top top",
              end: "bottom bottom",
              scrub: true
            }
          }
        );

        // Click interaction
        gauge.addEventListener('click', () => {
          console.log('open spatial overlay - future direction');
        });
      }
    }
  }

  // Initialize on load
  new DepthExperience();
</script>
