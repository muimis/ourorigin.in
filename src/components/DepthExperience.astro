---
import OriginMark from './OriginMark.astro';
import LiveWeather from './LiveWeather.astro';

export interface Props {
  origin?: any;
  product?: any;
}

const { origin, product } = Astro.props;

// Build the content for the first 4 strata
const strata = [
  { id: 'canopy', title: origin ? `CANOPY — ${origin.data.elevation}` : 'CANOPY — [origin.elevation]', image: origin ? origin.data.images.canopy : null, hasWeather: true },
  { id: 'land', title: origin ? `LAND — ${origin.data.soil}` : 'LAND — [origin.soil]', image: origin ? origin.data.images.land : null, hasWeather: false },
  { id: 'hand', title: origin && product ? `HAND — ${origin.data.method} / ${product.data.methodDescription}` : 'HAND — [origin.method]', image: origin ? origin.data.images.hand : null, hasWeather: false },
  { id: 'specimen', title: product ? `SPECIMEN — ${product.data.botanicalName}` : 'SPECIMEN — [product.botanicalName]', image: origin ? origin.data.images.specimen : null, hasWeather: false }
];

// Determine sizes for the offering stratum
const sizes = product ? product.data.sizes : [];
---

<div class="depth-experience-container">
  <!-- Depth Gauge -->
  <div class="depth-gauge-wrapper">
    <OriginMark variant="gold" size={48} id="depth-gauge-mark" />
  </div>

  <div class="pin-container">
    {strata.map((s, i) => (
      <section 
        class={`stratum stratum-${s.id}`} 
        style={`z-index: ${i + 1}; height: ${100 - (i * 5)}dvh; transform: translateY(${i === 0 ? '0' : '100dvh'});`}
      >
        <div class="stratum-content">
          {s.image && !origin?.data.images.isPlaceholderImagery && (
            <div class={`stratum-image ${s.id === 'hand' ? 'image-preserve-people' : ''}`} style={`background-image: url('${s.image}')`}></div>
          )}
          <div class="stratum-shadow"></div>
          <h2 class="stratum-title">
            {s.title}
            {s.hasWeather && origin && <LiveWeather coordinates={origin.data.coordinates} />}
          </h2>
        </div>
      </section>
    ))}

    <!-- Offering Stratum (Custom Layout) -->
    <section class="stratum stratum-offering" style={`z-index: 5; height: 80dvh; transform: translateY(100dvh);`}>
      <div class="stratum-content offering-content">
        <div class="stratum-shadow"></div>
        <h2 class="stratum-title">OFFERING</h2>
        
        {sizes.length > 0 ? (
          <div class="size-selector">
            <div class="size-options">
              {sizes.map((sizeObj: any, idx: number) => (
                <label class="size-option">
                  <input 
                    type="radio" 
                    name="product-size" 
                    value={sizeObj.label} 
                    data-price={sizeObj.priceINR}
                    checked={idx === 0}
                  />
                  <span class="size-label">{sizeObj.label}</span>
                  <span class="size-price">₹{sizeObj.priceINR}</span>
                </label>
              ))}
            </div>
            <button id="purchase-btn" class="primary-btn">Continue to the Source</button>
          </div>
        ) : (
          <p>OFFERING — [product.sizes]</p>
        )}
      </div>
    </section>
  </div>
</div>

<style>
  .depth-experience-container {
    position: relative;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    /* GSAP will pin this container */
  }

  .pin-container {
    width: 100vw;
    height: 100dvh;
    overflow: hidden;
    position: relative;
  }

  .depth-gauge-wrapper {
    position: fixed;
    right: 24px;
    top: 0; 
    z-index: 9999;
    cursor: pointer;
  }

  .stratum {
    position: absolute;
    top: 0;
    left: 0;
    width: 100vw;
    will-change: transform;
  }

  .stratum-content {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-forest-deep);
    transform-origin: top center;
    will-change: transform;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.4);
    position: relative;
    overflow: hidden;
  }

  .stratum-shadow {
    position: absolute;
    inset: 0;
    background-color: #000;
    opacity: 0;
    pointer-events: none;
    z-index: 5;
  }

  .stratum-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    /* Blend photography subtly into the Forest Deep brand color */
    opacity: 0.35;
    mix-blend-mode: luminosity;
    z-index: 1;
    pointer-events: none;
  }

  /* Terrain Cuts / Map Borders */
  .stratum-land {
    clip-path: polygon(0% 4%, 15% 1%, 35% 6%, 50% 2%, 65% 5%, 85% 0%, 100% 3%, 100% 100%, 0% 100%);
  }
  .stratum-hand {
    clip-path: polygon(0% 1%, 20% 5%, 40% 1%, 60% 7%, 80% 2%, 100% 5%, 100% 100%, 0% 100%);
  }
  .stratum-specimen {
    clip-path: polygon(0% 6%, 10% 2%, 30% 7%, 55% 1%, 75% 5%, 90% 0%, 100% 4%, 100% 100%, 0% 100%);
  }
  .stratum-offering {
    clip-path: polygon(0% 3%, 25% 7%, 50% 2%, 70% 6%, 90% 1%, 100% 4%, 100% 100%, 0% 100%);
  }

  .stratum-image.image-preserve-people {
    opacity: 0.55;
    mix-blend-mode: normal;
  }

  /* Basic typographic styling */
  .stratum-title {
    font-family: var(--font-narrative);
    font-size: var(--text-size-stratum-title);
    font-weight: 300;
    letter-spacing: 0.05em;
    margin: 0 0 1rem 0;
    z-index: 10;
    position: relative;
    text-align: center;
    max-width: 85vw;
    line-height: 1.4;
  }

  .offering-content {
    flex-direction: column;
  }

  /* Size Selector Styles */
  .size-selector {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
    z-index: 10;
    position: relative;
  }

  .size-options {
    display: flex;
    gap: 1rem;
  }

  .size-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 1.5rem;
    border: 1px solid rgba(245, 237, 216, 0.2);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .size-option:has(input:checked) {
    border-color: var(--color-gold);
    background-color: rgba(166, 124, 60, 0.1);
  }

  .size-option input {
    display: none;
  }

  .size-label {
    font-family: var(--font-evidence);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .size-price {
    font-family: var(--font-narrative);
    font-size: 1.2rem;
    color: var(--color-gold);
  }

  .primary-btn {
    background-color: var(--color-gold);
    color: var(--color-forest-deep);
    border: none;
    padding: 1rem 3rem;
    font-family: var(--font-institutional);
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .primary-btn:hover {
    background-color: var(--color-warm-cream);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  class DepthExperience {
    constructor() {
      this.initStrata();
      this.initDepthGauge();
      this.initPurchaseAction();
      
      document.fonts.ready.then(() => {
        ScrollTrigger.refresh();
      });
    }

    initPurchaseAction() {
      const btn = document.getElementById('purchase-btn');
      if (btn) {
        btn.addEventListener('click', () => {
          const selected = document.querySelector('input[name="product-size"]:checked') as HTMLInputElement;
          if (selected) {
            console.log(`[Action] Add to Cart: ${selected.value} at ₹${selected.dataset.price}`);
          }
        });
      }
    }

    initStrata() {
      const strata = document.querySelectorAll('.stratum');
      
      // Start all strata below the viewport EXCEPT the first one (handled natively via CSS transform to prevent FOUC)
      // but we inform GSAP of the initial state
      gsap.set(strata, { y: (i) => i === 0 ? "0dvh" : "100dvh" });

      // Create a master pinned timeline
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: ".depth-experience-container",
          start: "top top",
          end: "+=150%", // Adjusted to 150% as requested
          scrub: true,
          pin: ".pin-container",
          anticipatePin: 1,
          snap: {
            snapTo: "labels",
            duration: { min: 0.2, max: 0.6 },
            delay: 0.1,
            ease: "power1.inOut"
          }
        }
      });
      
      tl.addLabel("step0"); // Base state

      strata.forEach((stratum, index) => {
        if (index === 0) return; // First stratum is already at y:0

        const prevStratum = strata[index - 1];
        const prevContent = prevStratum.querySelector('.stratum-content');
        const prevShadow = prevStratum.querySelector('.stratum-shadow');
        const prevTitle = prevStratum.querySelector('.stratum-title');
        const prevSelector = prevStratum.querySelector('.size-selector'); 

        const topOffset = index * 5; // The resting offset: 5, 10, 15, 20
        const label = `step${index}`;

        // 1. Current stratum slides up to its designated resting offset
        tl.to(stratum, {
          y: `${topOffset}dvh`,
          ease: "none",
          duration: 1
        }, label)
        
        // 2. Previous stratum darkens completely so it becomes a receding shadow band
        .to(prevShadow, {
          opacity: 0.85,
          ease: "none",
          duration: 1
        }, label)
        
        // 3. Previous stratum text transforms into a large, faint watermark behind the organic terrain cut
        .to(prevTitle, {
          y: "-30dvh",
          scale: 1.8,
          opacity: 0.08,
          ease: "none",
          duration: 1
        }, label)
        
        .to(prevSelector, {
          opacity: 0,
          ease: "none",
          duration: 0.5
        }, label);
      });
      
      tl.addLabel("step" + strata.length); // Final snap point
    }

    initDepthGauge() {
      const gauge = document.querySelector('.depth-gauge-wrapper');
      const container = document.querySelector('.depth-experience-container');

      if (gauge && container) {
        gsap.fromTo(gauge, 
          { y: "10dvh" }, 
          { 
            y: "80dvh",
            ease: "none",
            scrollTrigger: {
              trigger: container,
              start: "top top",
              end: "+=200%", // Matches the new faster pin duration
              scrub: true
            }
          }
        );

        gauge.addEventListener('click', () => {
          console.log('open spatial overlay - future direction');
        });

        document.dispatchEvent(new CustomEvent('play-origin-mark-entrance'));
      }
    }
  }

  // Ensure initialization happens safely
  new DepthExperience();
</script>
