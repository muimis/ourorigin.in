---
// src/components/DepthExperience.astro
import OriginMark from './OriginMark.astro';
import LiveWeather from './LiveWeather.astro';
import { FSSAI_NUMBER } from '../utils/constants';

export interface Props {
  origin?: any;
  product?: any;
}

const { origin, product } = Astro.props;

const botanicalStates = {
  'nilgiris': 'LEAF FLUSH',
  'idukki': 'POD DEVELOPMENT',
  'wayanad': 'VINE MATURATION',
  'thiruvananthapuram': 'RHIZOME EXPANSION',
  'malabar-coast': 'DORMANT'
};
const botanicalState = origin ? botanicalStates[origin.data.slug] : '';

// Build story sections
const storySections = [
  { 
    id: 'canopy',
    title: 'CANOPY & ELEVATION',
    evidence: origin ? `${origin.data.elevation} · ${origin.data.bioregion}` : '',
    narrative: origin ? origin.data.narrative.canopy : '',
    image: origin ? origin.data.images.canopy : null, 
    hasWeather: true 
  },
  { 
    id: 'land',
    title: 'SOIL & BIOSPHERE',
    evidence: origin ? origin.data.soil : '',
    narrative: origin ? origin.data.narrative.land : '',
    image: origin ? origin.data.images.land : null, 
    hasWeather: false 
  },
  { 
    id: 'hand',
    title: 'HARVEST PRACTICE',
    evidence: origin ? origin.data.method : '',
    narrative: origin ? origin.data.narrative.hand : '',
    image: origin ? origin.data.images.hand : null, 
    hasWeather: false 
  }
];

const sizes = product ? product.data.sizes : [];

const navDimensions = [
  { id: 'purchase', name: 'Purchase' },
  { id: 'canopy', name: 'Canopy' },
  { id: 'land', name: 'Soil' },
  { id: 'hand', name: 'Harvest' },
  { id: 'sensory', name: 'Sensory' }
];
---

<!-- Top HUD Navigation -->
<div class="depth-top-hud">
  <div class="hud-left-group">
    <a href="/" class="depth-escape-hatch" aria-label="Return to Home">
      &larr; Home
    </a>
    <button id="depth-share-trigger" class="depth-hud-btn" aria-label="Share harvest">
      Share
    </button>
  </div>
  <button class="depth-basket-trigger" id="depth-basket-trigger" aria-label="Open Basket">
    Basket &middot; <span class="dossier-count">0</span>
  </button>
</div>

<!-- Side Rail Navigation -->
<div class="cipher-rail-wrapper" role="navigation" aria-label="Product dimensions">
  <div class="cipher-rail">
    {navDimensions.map((dim) => (
      <a 
        href={`#section-${dim.id}`}
        class="cipher-node" 
        data-dim={dim.id}
        aria-label={dim.name}
      >
        <span class="cipher-label">{dim.name}</span>
        <div class="cipher-dot"></div>
      </a>
    ))}
  </div>
</div>

<div class="depth-experience-container" data-origin-slug={origin?.data.slug} data-product-slug={product?.id} data-origin-name={origin?.data.name} data-product-name={product?.data.name}>
  
  <div class="documentary-scroll-container">
    
    <!-- SECTION 1: HERO & IMMEDIATE PURCHASE (ABOVE THE FOLD) -->
    <section id="section-purchase" class="product-hero-section">
      <div class="hero-split-layout">
        
        <!-- Left: Product Image -->
        <div class="hero-visual-col">
          {product.data.images?.packaging && product.data.images.packaging.trim() !== '' ? (
            <img 
              src={product.data.images.packaging} 
              alt={`Packaging of ${product.data.name}`} 
              class="hero-product-img" 
              loading="eager" 
              width="800"
              height="800"
            />
          ) : (
            <div class="hero-img-fallback">
              <svg viewBox="0 0 100 100" width="80" height="80">
                <circle cx="50" cy="50" r="49" stroke="currentColor" stroke-width="1" fill="none"/>
                <circle cx="50" cy="50" r="4" fill="currentColor"/>
              </svg>
            </div>
          )}
        </div>

        <!-- Right: Purchase Details & Add to Cart -->
        <div class="hero-details-col">
          <div class="origin-tag-row">
            <span class="origin-badge">{origin?.data.name} · {origin?.data.elevation}</span>
            {origin && <LiveWeather coordinates={origin.data.coordinates} originName={origin.data.name} />}
          </div>

          <h1 class="product-main-title">{product.data.name}</h1>
          <p class="product-botanical-subtitle">{product.data.botanicalName}</p>

          <p class="specimen-intro-copy">{product.data.specimenCopy}</p>

          <!-- Size & Price Selection -->
          <div class="size-ledger">
            <div class="size-ledger-header">
              <span>Select Size</span>
              <span>Price</span>
            </div>
            {sizes.map((size, index) => (
              <button 
                class={`size-ledger-row ${index === 0 ? 'selected' : ''}`} 
                data-size={size.label} 
                data-price={size.priceINR}
                aria-label={`Select size ${size.label} for ₹${size.priceINR}`}
              >
                <span class="spec-size">{size.label}</span>
                <span class="spec-val">₹{size.priceINR}</span>
              </button>
            ))}
          </div>

          <!-- Add to Basket Button -->
          <div class="purchase-actions">
            <button class="add-to-ledger-btn" id="add-to-ledger-btn" aria-label="Add to basket">
              Add to basket
            </button>
          </div>

          <div class="product-fssai">FSSAI Reg. No. {FSSAI_NUMBER}</div>
        </div>

      </div>
    </section>

    <!-- STORY SECTIONS: CANOPY, SOIL, HARVEST -->
    {storySections.map((s) => (
      <section id={`section-${s.id}`} class="story-section">
        {s.image && !origin?.data.images.isPlaceholderImagery && (
          <img 
            src={s.image} 
            alt={`${origin.data.name} — ${s.title}`} 
            class="story-bg-img" 
            loading="lazy" 
            width="1920"
            height="1080"
          />
        )}
        <div class="story-overlay"></div>
        <div class="story-content-wrap">
          <span class="story-section-tag">{s.title}</span>
          <h2 class="story-evidence-title">{s.evidence}</h2>
          <p class="story-narrative-copy">{s.narrative}</p>
        </div>
      </section>
    ))}

    <!-- SECTION 5: SENSORY PROFILE MATRIX -->
    {(product.data.sensoryProfile || product.data.chemistry) && (
      <section id="section-sensory" class="sensory-section">
        <div class="sensory-content-wrap">
          <h2 class="sensory-main-title">Sensory & Chemical Profile</h2>

          <div class="sensory-grid">
            {product.data.sensoryProfile?.aroma && (
              <div class="sensory-cell">
                <span class="cell-label">Aroma</span>
                <span class="cell-value">{product.data.sensoryProfile.aroma}</span>
              </div>
            )}
            {product.data.sensoryProfile?.flavor && (
              <div class="sensory-cell">
                <span class="cell-label">Flavour</span>
                <span class="cell-value">{product.data.sensoryProfile.flavor}</span>
              </div>
            )}
            {product.data.sensoryProfile?.appearance && (
              <div class="sensory-cell">
                <span class="cell-label">Appearance</span>
                <span class="cell-value">{product.data.sensoryProfile.appearance}</span>
              </div>
            )}
            {product.data.chemistry?.activeCompound && (
              <div class="sensory-cell">
                <span class="cell-label">Active Compound</span>
                <span class="cell-value">{product.data.chemistry.activeCompound}</span>
              </div>
            )}
            {product.data.chemistry?.moistureContent && (
              <div class="sensory-cell">
                <span class="cell-label">Moisture</span>
                <span class="cell-value">{product.data.chemistry.moistureContent}</span>
              </div>
            )}
          </div>
        </div>
      </section>
    )}

  </div>
</div>

<style>
  .depth-experience-container {
    position: relative;
    width: 100%;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
  }

  .documentary-scroll-container {
    width: 100%;
    min-height: 100vh;
    position: relative;
  }

  /* --- SECTION 1: HERO PURCHASE LAYOUT --- */
  .product-hero-section {
    min-height: 100vh;
    padding: 16vh clamp(1.5rem, 5vw, 6rem) 8vh;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }

  .hero-split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    max-width: 1300px;
    width: 100%;
    align-items: center;
  }

  .hero-visual-col {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.35);
    aspect-ratio: 1;
    overflow: hidden;
  }

  .hero-product-img {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    filter: brightness(0.95) contrast(1.05);
  }

  .hero-img-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.3;
  }

  .hero-details-col {
    display: flex;
    flex-direction: column;
    text-align: left;
    gap: 1.2rem;
  }

  .origin-tag-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    text-transform: uppercase;
  }

  .product-main-title {
    font-family: var(--font-institutional);
    font-size: clamp(2.8rem, 5vw, 5rem);
    font-weight: 300;
    margin: 0;
    line-height: 1;
  }

  .product-botanical-subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.2rem;
    color: rgba(245, 237, 216, 0.55);
    margin: -0.5rem 0 0.5rem 0;
  }

  .specimen-intro-copy {
    font-family: var(--font-narrative);
    font-size: 1.1rem;
    line-height: 1.5;
    color: rgba(245, 237, 216, 0.85);
    margin: 0;
  }

  /* Size Selector */
  .size-ledger {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
    border-top: 1px solid rgba(245, 237, 216, 0.1);
    padding-top: 1rem;
  }

  .size-ledger-header {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: rgba(245, 237, 216, 0.4);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .size-ledger-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: transparent;
    border: 1px solid rgba(245, 237, 216, 0.15);
    padding: 12px 16px;
    color: var(--color-warm-cream);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 13px;
    transition: all 0.3s ease;
  }

  .size-ledger-row:hover,
  .size-ledger-row.selected {
    border-color: var(--color-gold);
    color: var(--color-gold);
    background: rgba(166, 124, 60, 0.08);
  }

  .purchase-actions {
    margin-top: 1.5rem;
  }

  .add-to-ledger-btn {
    width: 100%;
    background: var(--color-gold);
    color: var(--color-forest-deep);
    border: 1px solid var(--color-gold);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    padding: 16px;
    cursor: pointer;
    text-transform: uppercase;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .add-to-ledger-btn:hover {
    background: var(--color-warm-cream);
    border-color: var(--color-warm-cream);
  }

  .product-fssai {
    font-family: var(--font-mono);
    font-size: 10px;
    color: rgba(245, 237, 216, 0.3);
    margin-top: 0.5rem;
  }

  /* --- STORY SECTIONS --- */
  .story-section {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10vh clamp(1.5rem, 5vw, 6rem);
    box-sizing: border-box;
    overflow: hidden;
    background-color: #080f06;
  }

  .story-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    filter: saturate(0.3) contrast(1.1);
  }

  .story-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(12, 21, 9, 0.6), rgba(12, 21, 9, 0.95));
  }

  .story-content-wrap {
    position: relative;
    z-index: 2;
    max-width: 800px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }

  .story-section-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--color-gold);
  }

  .story-evidence-title {
    font-family: var(--font-institutional);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 300;
    margin: 0;
    line-height: 1.1;
  }

  .story-narrative-copy {
    font-family: var(--font-narrative);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    line-height: 1.6;
    color: rgba(245, 237, 216, 0.9);
    margin: 0;
  }

  /* --- SENSORY SECTION --- */
  .sensory-section {
    padding: 12vh clamp(1.5rem, 5vw, 6rem);
    background: var(--color-forest-deep);
  }

  .sensory-content-wrap {
    max-width: 1000px;
    margin: 0 auto;
    text-align: left;
  }

  .sensory-main-title {
    font-family: var(--font-institutional);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    margin: 0 0 3rem 0;
  }

  .sensory-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem;
  }

  .sensory-cell {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    border-bottom: 1px solid rgba(245, 237, 216, 0.1);
    padding-bottom: 1.5rem;
  }

  .cell-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    text-transform: uppercase;
  }

  .cell-value {
    font-family: var(--font-narrative);
    font-size: 1.1rem;
    color: var(--color-warm-cream);
  }

  /* Fixed Top HUD & Rail */
  .depth-top-hud {
    position: fixed;
    top: 24px;
    left: 24px;
    right: 24px;
    display: flex;
    justify-content: space-between;
    z-index: 9999;
    pointer-events: none;
  }
  
  .hud-left-group {
    display: flex;
    gap: 1.5rem;
    pointer-events: auto;
  }

  .depth-escape-hatch,
  .depth-basket-trigger,
  .depth-hud-btn {
    color: var(--color-warm-cream);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    opacity: 0.8;
    transition: opacity 0.3s ease;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    pointer-events: auto;
  }

  .depth-escape-hatch:hover, .depth-basket-trigger:hover, .depth-hud-btn:hover {
    opacity: 1;
    color: var(--color-gold);
  }

  .cipher-rail-wrapper {
    position: fixed;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 9990;
    display: flex;
    align-items: center;
    pointer-events: auto;
  }

  .cipher-rail {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-end;
  }

  .cipher-node {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    color: var(--color-warm-cream);
    opacity: 0.35;
    transition: opacity 0.3s ease, color 0.3s ease;
    text-decoration: none;
    gap: 1rem;
  }

  .cipher-node:hover,
  .cipher-node.active {
    opacity: 1;
    color: var(--color-gold);
  }

  .cipher-dot {
    width: 6px;
    height: 6px;
    background-color: currentColor;
    border-radius: 50%;
  }

  .cipher-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: currentColor;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .cipher-node:hover .cipher-label,
  .cipher-node.active .cipher-label {
    opacity: 1;
  }

  /* Mobile responsiveness */
  @media (max-width: 900px) {
    .hero-split-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .sensory-grid {
      grid-template-columns: 1fr;
    }
    .cipher-rail-wrapper {
      display: none;
    }
  }
</style>

<script>
  function initDepthExperience() {
    // Size selection
    const sizeBtns = document.querySelectorAll('.size-ledger-row');

    sizeBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        sizeBtns.forEach(b => b.classList.remove('selected'));
        const target = e.currentTarget as HTMLButtonElement;
        target.classList.add('selected');
      });
    });

    // Add to Basket
    const addBtn = document.getElementById('add-to-ledger-btn');
    if (addBtn) {
      addBtn.addEventListener('click', () => {
        const container = document.querySelector('.depth-experience-container');
        const selectedBtn = document.querySelector('.size-ledger-row.selected') || sizeBtns[0];
        
        const activeSize = selectedBtn?.getAttribute('data-size');
        const activePrice = selectedBtn?.getAttribute('data-price');

        if (!container || !activeSize || !activePrice) return;

        const pId = container.getAttribute('data-product-slug');
        const pName = container.getAttribute('data-product-name');
        const oName = container.getAttribute('data-origin-name');
        const oId = container.getAttribute('data-origin-slug');

        window.dispatchEvent(new CustomEvent('add-to-ledger', {
          detail: {
            id: `${pId}-${activeSize}`,
            productId: pId,
            name: pName,
            origin: oName,
            originId: oId,
            size: activeSize,
            weight: activeSize,
            price: parseInt(activePrice, 10),
            quantity: 1
          }
        }));

        const originalText = addBtn.textContent;
        addBtn.textContent = 'ADDED TO BASKET ✓';
        setTimeout(() => {
          addBtn.textContent = originalText;
        }, 1500);
      });
    }

    // Basket trigger
    const basketBtn = document.getElementById('depth-basket-trigger');
    if (basketBtn) {
      basketBtn.addEventListener('click', () => {
        window.dispatchEvent(new Event('open-cart'));
      });
    }

    // Share action
    const shareBtn = document.getElementById('depth-share-trigger');
    if (shareBtn) {
      shareBtn.addEventListener('click', () => {
        if (navigator.share) {
          navigator.share({
            title: document.title,
            text: 'Explore this harvest from OurOrigin.',
            url: window.location.href
          }).catch(err => console.log('Share failed', err));
        } else {
          navigator.clipboard.writeText(window.location.href).then(() => {
            const originalText = shareBtn.textContent;
            shareBtn.textContent = 'COPIED ✓';
            setTimeout(() => {
              shareBtn.textContent = originalText;
            }, 2000);
          });
        }
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDepthExperience);
  } else {
    initDepthExperience();
  }
  document.addEventListener('astro:page-load', initDepthExperience);
</script>
