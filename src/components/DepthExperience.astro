---
// src/components/DepthExperience.astro
import OriginMark from './OriginMark.astro';
import LiveWeather from './LiveWeather.astro';
import { FSSAI_NUMBER } from '../utils/constants';

export interface Props {
  origin?: any;
  product?: any;
}

const { origin, product } = Astro.props;

const botanicalStates = {
  'nilgiris': 'LEAF FLUSH',
  'idukki': 'POD DEVELOPMENT',
  'wayanad': 'VINE MATURATION',
  'thiruvananthapuram': 'RHIZOME EXPANSION',
  'malabar-coast': 'DORMANT'
};
const botanicalState = origin ? botanicalStates[origin.data.slug] : '';

// Build the content for the 5 strata
const strata = [
  { 
    id: 'canopy', 
    evidence: origin ? `${origin.data.elevation} · ${origin.data.bioregion}`.toUpperCase() : '',
    narrative: origin ? origin.data.narrative.canopy : '',
    image: origin ? origin.data.images.canopy : null, 
    hasWeather: true 
  },
  { 
    id: 'land', 
    evidence: origin ? origin.data.soil.toUpperCase() : '',
    narrative: origin ? origin.data.narrative.land : '',
    image: origin ? origin.data.images.land : null, 
    hasWeather: false 
  },
  { 
    id: 'hand', 
    evidence: origin ? origin.data.method.toUpperCase() : '',
    narrative: origin ? origin.data.narrative.hand : '',
    image: origin ? origin.data.images.hand : null, 
    hasWeather: false 
  },
  { 
    id: 'specimen', 
    evidence: product ? `${product.data.botanicalName} · BATCH ${product.data.batchRef}${product.data.harvestMonth && !['Seasonal', 'Ongoing'].includes(product.data.harvestMonth) ? ' · ' + product.data.harvestMonth : ''}`.toUpperCase() : '',
    narrative: product ? product.data.specimenCopy : '',
    botanicalName: product ? product.data.botanicalName : null,
    sensoryProfile: product ? product.data.sensoryProfile : null,
    chemistry: product ? product.data.chemistry : null,
    image: origin ? origin.data.images.specimen : null, 
    hasWeather: false 
  }
];

// Dynamically fetch the origin mask URL (using clean web-safe filename)
const maskUrl = origin?.data.slug === 'wayanad' ? encodeURI('/maps/wayanad_map_cut_solid.svg') : '';

// Determine sizes for the offering stratum
const sizes = product ? product.data.sizes : [];

// The 7 inline SVG glyphs representing the 7 dimensions
const dimensions = [
  { 
    id: 'geo',
    name: 'Geo', 
    description: 'The exact coordinates and elevation',
    d: 'M 50,20 L 50,40 M 50,60 L 50,80 M 20,50 L 40,50 M 60,50 L 80,50 M 40,50 A 10,10 0 1,0 60,50 A 10,10 0 1,0 40,50' 
  },
  { 
    id: 'bio',
    name: 'Bio', 
    description: 'The soil and ecological system',
    d: 'M 30,50 A 20,20 0 0,1 70,50 M 20,50 A 30,30 0 0,1 80,50 M 40,50 A 10,10 0 0,1 60,50' 
  },
  { 
    id: 'community',
    name: 'Community', 
    description: 'The generational harvesters',
    d: 'M 42,50 A 18,18 0 1,0 78,50 A 18,18 0 1,0 42,50 M 58,50 A 18,18 0 1,0 94,50 A 18,18 0 1,0 58,50' 
  },
  { 
    id: 'method',
    name: 'Method', 
    description: 'The polyculture harvesting practice',
    d: 'M 25,35 L 75,35 M 18,50 L 82,50 M 25,65 L 75,65' 
  },
  { 
    id: 'observation',
    name: 'Observation', 
    description: 'The live atmospheric evidence',
    d: 'M 20,50 C 35,25 40,75 50,50 C 60,25 65,75 80,50' 
  },
  { 
    id: 'time',
    name: 'Time', 
    description: 'The seasonal harvest cycle',
    d: 'M 50,20 L 50,80 M 20,50 L 80,50 M 50,50 L 70,30' 
  },
  { 
    id: 'product',
    name: 'Product', 
    description: 'The finalized packaging and yield',
    d: 'M 50,38 A 12,12 0 1,0 62,50 A 12,12 0 1,0 50,38 M 50,32 L 50,15 M 50,68 L 50,85 M 32,50 L 15,50 M 68,50 L 85,50' 
  }
];
---

<!-- Telemetry Escape Hatch -->
<div class="depth-top-hud">
  <div class="hud-left-group">
    <a href="/" class="depth-escape-hatch" aria-label="Return to Home">
      [ &larr; HOME ]
    </a>
    <button id="depth-yields-trigger" class="depth-hud-btn" aria-label="All Yields">
      [ ALL YIELDS ]
    </button>
    <button id="depth-share-trigger" class="depth-hud-btn" aria-label="Share this harvest">
      [ SHARE ]
    </button>
  </div>
  <button class="depth-basket-trigger" id="depth-basket-trigger" aria-label="Open Basket">
    [ BASKET : <span class="dossier-count">0</span> ]
  </button>
</div>

<!-- The Cipher glyph progress & navigation rail -->
<div class="cipher-rail-wrapper" role="navigation" aria-label="Origin dimensions">
  <div class="cipher-rail">
    {dimensions.map((dim, idx) => (
      <button 
        class="cipher-glyph" 
        data-dim={dim.id}
        aria-label={`${dim.name} — ${dim.description}`}
      >
        <span class="cipher-label">{dim.name}</span>
        <svg class="cipher-icon" viewBox="0 0 100 100" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <circle cx="50" cy="50" r="48" stroke-dasharray="2" opacity="0.3" />
          <path d={dim.d} />
          {idx === 6 && <circle cx="50" cy="50" r="3" fill="currentColor" />}
        </svg>
      </button>
    ))}
  </div>
</div>

<div class="depth-experience-container">
  
  <!-- Interactive Depth Gauge -->
  <div class="depth-gauge-wrapper">
    <OriginMark variant="gold" size={48} id="depth-gauge-mark" />
  </div>

  <div class="pin-container" data-origin-slug={origin?.data.slug} data-product-slug={product?.id} data-origin-name={origin?.data.name} data-product-name={product?.data.name}>
    <div class="depth-topographic-bg"></div>
    
    {strata.map((s, i) => (
      <section 
        class={`stratum stratum-${s.id} ${maskUrl && i === 0 ? 'has-terrain-mask' : ''}`} 
        style={`z-index: ${i + 1}; height: 100dvh; width: 100%; transform: translateY(${i === 0 ? '0' : '100dvh'}); ${maskUrl && i === 0 ? `--mask-url: url('${maskUrl}');` : ''}`}
      >
        <div class="stratum-content">
           {s.image && !origin?.data.images.isPlaceholderImagery && (
            <img 
              src={s.image} 
              alt={`${origin.data.name} — ${s.id}`} 
              class={`stratum-image-el ${s.id === 'hand' ? 'image-preserve-people' : ''}`} 
              loading={i === 0 ? "eager" : "lazy"} 
              width="1920"
              height="1080"
            />
          )}
          <div class="stratum-shadow"></div>
          <div class={`stratum-text-container ${s.id === 'specimen' ? 'specimen-stratum-layout' : ''}`}>
            <div class="stratum-primary-details">
              <h2 class="stratum-evidence">
                {s.evidence}
                {s.hasWeather && origin && <><span class="weather-separator">·</span><LiveWeather coordinates={origin.data.coordinates} originName={origin.data.name} /></>}
              </h2>
              {s.id === 'specimen' && s.botanicalName && (
                <>
                  <p class="specimen-botanical-name">{s.botanicalName}</p>
                  <div class="specimen-telemetry-handoff">
                    <span class="telemetry-label">STATE:</span> <span class="telemetry-value">{botanicalState}</span>
                  </div>
                </>
              )}
              <p class="stratum-narrative">{s.narrative}</p>
            </div>

            {s.id === 'specimen' && (s.sensoryProfile || s.chemistry) && (
              <div class="specimen-sensory-matrix">
                <div class="matrix-header">[ SPECIMEN LAB ANALYSIS ]</div>
                <div class="matrix-grid">
                  {s.sensoryProfile?.aroma && (
                    <div class="matrix-row">
                      <span class="matrix-key">AROMA SIGNATURE</span>
                      <span class="matrix-val">{s.sensoryProfile.aroma}</span>
                    </div>
                  )}
                  {s.sensoryProfile?.flavor && (
                    <div class="matrix-row">
                      <span class="matrix-key">FLAVOR PROFILE</span>
                      <span class="matrix-val">{s.sensoryProfile.flavor}</span>
                    </div>
                  )}
                  {s.sensoryProfile?.appearance && (
                    <div class="matrix-row">
                      <span class="matrix-key">PHYSICAL STATE</span>
                      <span class="matrix-val">{s.sensoryProfile.appearance}</span>
                    </div>
                  )}
                  {s.chemistry?.activeCompound && (
                    <div class="matrix-row">
                      <span class="matrix-key">ACTIVE COMPOUND</span>
                      <span class="matrix-val">{s.chemistry.activeCompound}</span>
                    </div>
                  )}
                  {s.chemistry?.moistureContent && (
                    <div class="matrix-row">
                      <span class="matrix-key">MOISTURE VALUE</span>
                      <span class="matrix-val">{s.chemistry.moistureContent}</span>
                    </div>
                  )}
                </div>
              </div>
            )}
          </div>
        </div>
      </section>
    ))}

    <!-- Offering Stratum (Custom Layout) -->
    <section class={`stratum stratum-offering ${maskUrl ? 'has-terrain-mask' : ''}`} style={`z-index: 10000; height: 100dvh; width: 100%; transform: translateY(100dvh); ${maskUrl ? `--mask-url: url('${maskUrl}');` : ''}`}>
      {product.data.images?.packaging && product.data.images.packaging.trim() !== '' && (
        <img 
          src={product.data.images.packaging} 
          alt={`Packaging of ${product.data.name}`} 
          class="stratum-image-el" 
          loading="lazy" 
          width="800"
          height="800"
        />
      )}
      <div class="stratum-content offering-content">
        <div class="stratum-shadow"></div>
        <h2 class="stratum-evidence">THE HARVEST</h2>
        
        {product.data.offeringCopy && (
          <p class="offering-copy">{product.data.offeringCopy}</p>
        )}
        
        <p class="yield-status">YIELD STATUS: STRICTLY LIMITED (WILD HARVEST)</p>
        
        <div class="size-ledger">
          <div class="size-ledger-header">
            <span class="hdr-size">SIZE</span>
            <span class="hdr-status">COMPLIANCE</span>
            <span class="hdr-val">VALUE</span>
          </div>
          {sizes.map((size, index) => (
            <button 
              class={`size-ledger-row ${index === 0 ? 'selected' : ''}`} 
              data-size={size.label} 
              data-price={size.priceINR}
              aria-label={`Select size ${size.label} for ₹${size.priceINR}`}
            >
              <span class="spec-size">{size.label}</span>
              <span class="spec-status">[ {size.isPriceVerified ? 'PRICE VERIFIED' : 'PENDING'} ]</span>
              <span class="spec-val">₹{size.priceINR}</span>
            </button>
          ))}
        </div>
        
        <div class="offering-actions">
          <button class="add-to-ledger-btn" id="add-to-ledger-btn" aria-label="Add to Ledger">
            [ ADD TO BASKET ]
          </button>
        </div>
        
        <div class="product-fssai">FSSAI Reg. No. {FSSAI_NUMBER}</div>
      </div>
    </section>
  </div>
</div>

<style>
  .depth-experience-container {
    position: relative;
    width: 100%;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
  }

  .depth-topographic-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background-image: url('/topographic_pattern.svg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0.4;
    pointer-events: none;
    z-index: 0;
  }

  .pin-container {
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    position: relative;
  }

  .depth-gauge-wrapper {
    position: fixed;
    right: 24px;
    top: 0; 
    z-index: 9999;
    pointer-events: none;
  }

  .stratum {
    position: absolute;
    top: 0;
    left: 0;
    width: 110vw;
    will-change: transform;
    content-visibility: auto;
    contain-intrinsic-size: 100dvh;
    backface-visibility: hidden;
    transform-style: preserve-3d;
  }

  .stratum.active-in-view {
    content-visibility: visible;
  }

  .stratum-content {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-forest-deep);
    transform-origin: top center;
    will-change: transform;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.4);
    position: relative;
    overflow: hidden;
  }

  .stratum-shadow {
    position: absolute;
    inset: 0;
    background-color: #000;
    opacity: 0;
    pointer-events: none;
    z-index: 5;
  }

  .stratum-image-el {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.8;
    z-index: 1;
    pointer-events: none;
    filter: saturate(0.8) contrast(1.1);
  }

  /* Terrain Cuts / Map Borders */
  .has-terrain-mask {
    -webkit-mask-image: var(--mask-url), linear-gradient(black, black);
    mask-image: var(--mask-url), linear-gradient(black, black);
    -webkit-mask-repeat: no-repeat, no-repeat;
    mask-repeat: no-repeat, no-repeat;
    -webkit-mask-size: auto 100%, calc(100% - 60vh) 100%;
    mask-size: auto 100%, calc(100% - 60vh) 100%;
    -webkit-mask-position: top right, top left;
    mask-position: top right, top left;
  }
  
  .stratum-content {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding-top: 8vh;
    padding-right: 12vw;
  }
  
  @media (max-width: 768px) {
    .stratum-content {
      padding-top: 12vh;
      padding-right: 0;
    }
  }

  .stratum-image-el.image-preserve-people {
    opacity: 0.8;
  }

  /* Basic typographic styling */
  .stratum-text-container,
  .offering-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    z-index: 10;
    position: relative;
    max-width: 480px;
    padding: 0 2rem;
    text-align: center;
    margin: auto;
  }

  .stratum-evidence {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--color-warm-cream);
    margin: 0;
    opacity: 0.8;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .stratum-narrative,
  .offering-copy {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 400;
    color: var(--color-warm-cream);
    line-height: 1.5;
    margin: 0;
  }
  
  .specimen-botanical-name {
    font-family: var(--font-display);
    font-size: 16px;
    font-style: italic;
    color: var(--color-gold);
    margin: -1rem 0 0 0;
  }

  .specimen-telemetry-handoff {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--color-warm-cream);
    margin: -1rem 0 0 0;
    display: flex;
    gap: 0.5rem;
  }
  .specimen-telemetry-handoff .telemetry-label {
    opacity: 0.5;
  }
  .specimen-telemetry-handoff .telemetry-value {
    opacity: 0.9;
  }

  .yield-status {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    text-transform: uppercase;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .weather-separator {
    margin: 0 0.2rem;
  }

  /* === Redesigned Size Ledger === */
  .size-ledger {
    width: 100%;
    max-width: 380px;
    display: flex;
    flex-direction: column;
    margin: 2rem 0 1rem 0;
    border-top: 1px solid rgba(245, 237, 216, 0.15);
    z-index: 10;
  }

  .size-ledger-header {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    align-items: center;
    padding: 0.8rem 0;
    border-bottom: 1px solid rgba(245, 237, 216, 0.15);
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.25em;
    color: rgba(245, 237, 216, 0.4);
    text-transform: uppercase;
    pointer-events: none;
    text-align: left;
  }
  
  .size-ledger-header .hdr-val {
    text-align: right;
  }

  .size-ledger-row {
    background: transparent;
    border: none;
    border-bottom: 1px dashed rgba(245, 237, 216, 0.15);
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    align-items: center;
    padding: 1.2rem 0.5rem;
    cursor: pointer;
    transition: all 0.3s var(--ease-settle);
    color: var(--color-warm-cream);
    text-align: left;
    width: 100%;
    box-sizing: border-box;
  }

  .size-ledger-row:hover {
    background: rgba(245, 237, 216, 0.03);
    color: var(--color-gold);
  }

  .size-ledger-row.selected {
    color: var(--color-gold);
    font-weight: 500;
    border-bottom: 1px solid var(--color-gold);
    background: rgba(166, 124, 60, 0.08);
    padding-left: 0.8rem;
    padding-right: 0.2rem;
  }

  /* Specimen Stratum Split Layout */
  .specimen-stratum-layout {
    max-width: 960px !important;
    display: grid !important;
    grid-template-columns: 1.15fr 1fr;
    gap: 3.5rem;
    align-items: center;
    text-align: left !important;
    padding: 0 4rem !important;
  }

  .specimen-stratum-layout .stratum-primary-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .specimen-stratum-layout .stratum-evidence {
    justify-content: flex-start;
  }

  .specimen-sensory-matrix {
    border: 1px solid rgba(245, 237, 216, 0.15);
    background: rgba(12, 21, 9, 0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 2rem;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
  }

  .matrix-header {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--color-gold);
    border-bottom: 1px solid rgba(245, 237, 216, 0.15);
    padding-bottom: 0.8rem;
  }

  .matrix-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .matrix-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border-bottom: 1px dashed rgba(245, 237, 216, 0.08);
    padding-bottom: 0.8rem;
  }

  .matrix-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .matrix-key {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    opacity: 0.6;
  }

  .matrix-val {
    font-family: var(--font-display);
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-warm-cream);
  }

  @media (max-width: 900px) {
    .specimen-stratum-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 1.5rem !important;
      max-height: 80vh;
      overflow-y: auto;
    }
    .specimen-sensory-matrix {
      padding: 1.5rem;
    }
  }

  .spec-size {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
  }

  .spec-status {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    opacity: 0.5;
  }
  
  .size-ledger-row.selected .spec-status {
    opacity: 0.8;
  }

  .spec-val {
    font-family: var(--font-mono);
    font-size: 13px;
    text-align: right;
  }

  /* Action Styles */
  .offering-actions {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
    width: 100%;
  }

  .add-to-ledger-btn {
    background: transparent;
    color: var(--color-warm-cream);
    border: 1px solid rgba(245, 237, 216, 0.3);
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 1rem 2rem;
    cursor: pointer;
    transition: color 0.3s ease;
    width: 100%;
    max-width: 320px;
  }
  
  .add-to-ledger-btn:hover {
    color: var(--color-gold);
  }

  .product-fssai {
    font-family: var(--font-mono);
    font-size: 9px;
    opacity: 0.3;
    margin-top: 2rem;
    letter-spacing: 0.05em;
  }

  /* Fixed Top HUD Elements */
  .depth-top-hud {
    position: fixed;
    top: 24px;
    left: 24px;
    right: 24px;
    display: flex;
    justify-content: space-between;
    z-index: 9999;
    pointer-events: none;
  }
  
  .hud-left-group {
    display: flex;
    gap: 1.5rem;
    pointer-events: auto;
  }

  .depth-escape-hatch,
  .depth-basket-trigger,
  .depth-hud-btn {
    color: var(--color-warm-cream);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    opacity: 0.8;
    transition: opacity 0.3s ease;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    pointer-events: auto;
  }
  
  .depth-basket-trigger {
    display: none;
  }

  .depth-escape-hatch:hover, .depth-basket-trigger:hover, .depth-hud-btn:hover {
    opacity: 1;
    color: var(--color-gold);
  }

  /* === Cipher Rail Styling === */
  .cipher-rail-wrapper {
    position: fixed;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 9990;
    display: flex;
    align-items: center;
    pointer-events: auto;
  }

  .cipher-rail {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-end;
  }

  .cipher-glyph {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    color: var(--color-warm-cream);
    opacity: 0.35;
    transition: opacity 0.3s ease, color 0.3s ease;
  }

  .cipher-glyph:hover,
  .cipher-glyph.active {
    opacity: 1;
    color: var(--color-gold);
  }

  .cipher-icon {
    width: 24px;
    height: 24px;
    stroke-width: 1.5px;
    transition: transform 0.3s ease;
  }

  .cipher-glyph.active .cipher-icon {
    transform: scale(1.15);
  }

  .cipher-label {
    position: absolute;
    right: 36px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    opacity: 0;
    pointer-events: none;
    transform: translateX(10px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    white-space: nowrap;
    text-transform: uppercase;
  }

  .cipher-glyph:hover .cipher-label,
  .cipher-glyph.show-label .cipher-label,
  .cipher-glyph.show-label-temp .cipher-label {
    opacity: 1;
    transform: translateX(0);
  }

  /* Responsive / Mobile Layout */
  @media (max-width: 768px), (max-height: 600px) {
    .cipher-rail-wrapper {
      right: 24px;
      top: 24px;
      left: 24px;
      bottom: auto;
      transform: none;
      justify-content: center;
      width: auto;
      z-index: 9999;
    }

    .cipher-rail {
      flex-direction: row;
      gap: 3px;
      width: 100%;
      background: none;
      border: none;
      padding: 0;
      border-radius: 0;
    }

    .cipher-glyph {
      flex: 1;
      height: 3px;
      background: rgba(245, 237, 216, 0.2);
      opacity: 1;
      border-radius: 0;
      transition: background-color 0.3s ease;
    }

    .cipher-glyph.active,
    .cipher-glyph.filled-preceding {
      background-color: var(--color-gold);
      opacity: 1;
    }

    .cipher-icon {
      display: none !important;
    }

    .cipher-label {
      display: none !important;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  class DepthExperience {
    constructor() {
      this.initStrata();
      this.initDepthGauge();
      this.initPurchaseAction();
      
      document.fonts.ready.then(() => {
        ScrollTrigger.refresh();
      });
    }

    initPurchaseAction() {
      // 1. Size Selection Logic
      const sizeBtns = document.querySelectorAll('.size-ledger-row');
      let activeSize = sizeBtns[0]?.getAttribute('data-size');
      let activePrice = sizeBtns[0]?.getAttribute('data-price');

      sizeBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          sizeBtns.forEach(b => b.classList.remove('selected'));
          const target = e.currentTarget as HTMLButtonElement;
          target.classList.add('selected');
          activeSize = target.getAttribute('data-size');
          activePrice = target.getAttribute('data-price');
        });
      });

      // 2. Add to Ledger Logic
      const addBtn = document.getElementById('add-to-ledger-btn');
      if (addBtn) {
        addBtn.addEventListener('click', () => {
          const pinContainer = document.querySelector('.pin-container');
          if (!pinContainer || !activeSize || !activePrice) return;

          const pId = pinContainer.getAttribute('data-product-slug');
          const pName = pinContainer.getAttribute('data-product-name');
          const oName = pinContainer.getAttribute('data-origin-name');
          const oId = pinContainer.getAttribute('data-origin-slug');

          window.dispatchEvent(new CustomEvent('add-to-ledger', {
            detail: {
              id: `${pId}-${activeSize}`,
              productId: pId,
              name: pName,
              origin: oName,
              originId: oId,
              size: activeSize,
              weight: activeSize,
              price: parseInt(activePrice, 10),
              quantity: 1
            }
          }));

          // Haptic feedback
          const originalText = addBtn.textContent;
          addBtn.textContent = '[ ADDED ]';
          addBtn.style.color = 'var(--color-gold)';
          setTimeout(() => {
            addBtn.textContent = originalText;
            addBtn.style.color = '';
          }, 1500);
        });
      }

      // 3. Basket Trigger Logic
      const basketBtn = document.getElementById('depth-basket-trigger');
      if (basketBtn) {
        basketBtn.addEventListener('click', () => {
          window.dispatchEvent(new Event('trigger-dossier'));
        });
      }
    }

    initStrata() {
      const strata = document.querySelectorAll('.stratum');
      const pinContainer = document.querySelector('.pin-container');
      const originSlug = pinContainer?.getAttribute('data-origin-slug');
      const productSlug = pinContainer?.getAttribute('data-product-slug');
      
      const exploreKey = `ourorigin_explored_${originSlug}_${productSlug}`;
      const isFirstVisit = localStorage.getItem(exploreKey) !== 'true';

      // Start all strata below viewport except the first one
      gsap.set(strata, { 
        y: (i) => i === 0 ? "0dvh" : "100dvh",
        x: "0vw"
      });

      // Create master pinned timeline
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: ".depth-experience-container",
          start: "top top",
          end: "+=350%", // Matches pin duration
          scrub: true,
          pin: ".pin-container",
          anticipatePin: 1,
          snap: {
            snapTo: "labels",
            duration: { min: 0.2, max: 0.6 },
            delay: 0.1,
            ease: "power1.inOut"
          }
        }
      });
      
      tl.addLabel("step0");

      strata.forEach((stratum, index) => {
        if (index === 0) return;

        const prevStratum = strata[index - 1];
        const prevShadow = prevStratum.querySelector('.stratum-shadow');

        let topOffset = index * 2; // Halved distance
        
        // Offering page sits full screen
        if (stratum.classList.contains('stratum-offering')) {
          topOffset = 0;
        }

        const label = `step${index}`;

        tl.to(stratum, {
          y: `${topOffset}dvh`,
          ease: "none",
          duration: 1
        }, label)
        
        .to(prevShadow, {
          opacity: 0.5,
          ease: "none",
          duration: 1
        }, label)
        
        .to(prevStratum.querySelector('.stratum-text-container'), {
          y: "-30dvh",
          scale: 1.8,
          opacity: 0.08,
          ease: "none",
          duration: 1
        }, label);
      });
      
      tl.addLabel("step" + strata.length);

      // 7 dimensions step mapping configuration
      const STEP_DIMS = [
        ['geo', 'observation'],   // step0 — canopy
        ['bio'],                  // step1 — land
        ['community', 'method'],  // step2 — hand
        ['product', 'time'],      // step3 — specimen
        []                        // step4 — offering
      ];

      function updateCipher(timeline) {
        const t = timeline.time();
        let activeStep = 0;
        for (let i = 0; i <= strata.length; i++) {
          const label = timeline.labels['step' + i];
          if (label !== undefined && t >= label) activeStep = i;
        }
        const activeDims = STEP_DIMS[activeStep] || [];
        document.querySelectorAll('.cipher-glyph').forEach((btn, idx) => {
          const dimKey = btn.getAttribute('data-dim');
          const isActive = activeDims.includes(dimKey);
          btn.classList.toggle('active', isActive);
          
          let isPrecedingFilled = false;
          if (activeStep === 0 && idx <= 1) isPrecedingFilled = true;
          else if (activeStep === 1 && idx <= 2) isPrecedingFilled = true;
          else if (activeStep === 2 && idx <= 4) isPrecedingFilled = true;
          else if (activeStep === 3 && idx <= 5) isPrecedingFilled = true;
          else if (activeStep === 4 && idx <= 6) isPrecedingFilled = true;
          
          btn.classList.toggle('filled-preceding', isPrecedingFilled);

          if (isActive && isFirstVisit) {
            btn.classList.add('show-label');
          } else {
            btn.classList.remove('show-label');
          }
        });
      }

      // Track active stratum and update Cipher rail & explore state
      tl.eventCallback('onUpdate', function() {
        const progress = this.progress();
        
        // Calculate the current active step index
        const t = this.time();
        let activeStep = 0;
        for (let i = 0; i <= strata.length; i++) {
          const label = this.labels['step' + i];
          if (label !== undefined && t >= label) activeStep = i;
        }

        // Toggle active-in-view class to optimize rendering with content-visibility
        strata.forEach((stratum, idx) => {
          stratum.classList.toggle('active-in-view', idx === activeStep || idx === activeStep + 1);
        });
        
        // Mark as explored when reaching offering stratum (last slide)
        if (progress > 0.8 && originSlug && productSlug) {
          localStorage.setItem(exploreKey, 'true');
        }
        
        updateCipher(this);
      });

      // Wire up Cipher rail click events to scroll directly to the target stratum
      document.querySelectorAll('.cipher-glyph').forEach(btn => {
        btn.addEventListener('click', () => {
          const clickedDim = btn.getAttribute('data-dim');
          const stepIdx = STEP_DIMS.findIndex(dims => dims.includes(clickedDim));
          
          const scrollTriggerInstance = tl.scrollTrigger;
          if (scrollTriggerInstance && stepIdx !== -1) {
            const start = scrollTriggerInstance.start;
            const end = scrollTriggerInstance.end;
            const totalScroll = end - start;
            // Snaps directly to the target step in the pinned scroller
            const targetScroll = start + (stepIdx / (strata.length - 1)) * totalScroll;
            
            window.scrollTo({
              top: targetScroll,
              behavior: 'smooth'
            });

            // Briefly show label when clicked
            btn.classList.add('show-label-temp');
            setTimeout(() => {
              btn.classList.remove('show-label-temp');
            }, 1800);
          }
        });
      });
    }

    initDepthGauge() {
      const gauge = document.querySelector('.depth-gauge-wrapper');
      const container = document.querySelector('.depth-experience-container');

      if (gauge && container) {
        gsap.fromTo(gauge, 
          { y: "10dvh" }, 
          { 
            y: "80dvh",
            ease: "none",
            scrollTrigger: {
              trigger: container,
              start: "top top",
              end: "+=350%", // Matches the actual pin duration (Patch 1)
              scrub: true
            }
          }
        );
      }
    }
  }

  // Safe instantiation
  new DepthExperience();
  
  const yieldsBtn = document.getElementById('depth-yields-trigger');
  if (yieldsBtn) {
    yieldsBtn.addEventListener('click', () => {
      window.dispatchEvent(new Event('open-all-yields-panel'));
    });
  }

  const shareBtn = document.getElementById('depth-share-trigger');
  if (shareBtn) {
    shareBtn.addEventListener('click', () => {
      const shareData = {
        title: document.title,
        text: `Explore this harvest from OurOrigin.`,
        url: window.location.href
      };

      if (navigator.share) {
        navigator.share(shareData).catch(err => console.log('Share failed', err));
      } else {
        navigator.clipboard.writeText(window.location.href).then(() => {
          const originalText = shareBtn.textContent;
          shareBtn.textContent = '[ COPIED ]';
          setTimeout(() => {
            shareBtn.textContent = originalText;
          }, 2000);
        });
      }
    });
  }
</script>
