---
import OriginMark from './OriginMark.astro';
import LiveWeather from './LiveWeather.astro';

export interface Props {
  origin?: any;
  product?: any;
}

const { origin, product } = Astro.props;

// Build the content for the first 4 strata
const strata = [
  { id: 'canopy', title: origin ? `CANOPY — ${origin.data.elevation || ''}` : 'CANOPY', image: origin ? origin.data.images.canopy : null, hasWeather: true },
  { id: 'land', title: origin ? `LAND — ${origin.data.soil || 'Rich Soil'}` : 'LAND', image: origin ? origin.data.images.land : null, hasWeather: false },
  { id: 'hand', title: origin && product ? `HAND — ${origin.data.method || 'Artisanal'} / ${product.data.methodDescription || 'Sourced with care'}` : 'HAND', image: origin ? origin.data.images.hand : null, hasWeather: false },
  { id: 'specimen', title: product ? `SPECIMEN — ${product.data.botanicalName || ''}` : 'SPECIMEN', image: origin ? origin.data.images.specimen : null, hasWeather: false }
];

// Dynamically fetch the origin mask URL, but for Wayanad use the new solid SVG based on the uploaded border
const maskUrl = origin?.data.slug === 'wayanad' ? encodeURI('/maps/wayanadu map cut_solid.svg') : '';


// Determine sizes for the offering stratum
const sizes = product ? product.data.sizes : [];
---

<div class="depth-experience-container">
  <!-- Depth Gauge -->
  <div class="depth-gauge-wrapper">
    <OriginMark variant="gold" size={48} id="depth-gauge-mark" />
  </div>

  <div class="pin-container" data-origin-name={origin?.data.name} data-product-name={product?.data.name}>
    {strata.map((s, i) => (
      <section 
        class={`stratum stratum-${s.id}`} 
        style={`z-index: ${i + 1}; height: 100dvh; width: 100vw; transform: translateY(${i === 0 ? '0' : '100dvh'}); ${maskUrl ? `--mask-url: url('${maskUrl}');` : ''}`}
      >
        <div class="stratum-content">
          {s.image && !origin?.data.images.isPlaceholderImagery && (
            <div class={`stratum-image ${s.id === 'hand' ? 'image-preserve-people' : ''}`} style={`background-image: url('${s.image}')`}></div>
          )}
          <div class="stratum-shadow"></div>
          <h2 class="stratum-title">
            {s.title}
            {s.hasWeather && origin && <LiveWeather coordinates={origin.data.coordinates} />}
          </h2>
        </div>
      </section>
    ))}

    <!-- Offering Stratum (Custom Layout) -->
    <section class="stratum stratum-offering" style={`z-index: 5; height: 100dvh; width: 100vw; transform: translateY(100dvh); ${maskUrl ? `--mask-url: url('${maskUrl}');` : ''}`}>
      <div class="stratum-content offering-content">
        <div class="stratum-shadow"></div>
        <h2 class="stratum-title">OFFERING</h2>
        
        {sizes.length > 0 ? (
          <div class="size-selector">
            <div class="size-options">
              {sizes.map((sizeObj: any, idx: number) => (
                <label class="size-option">
                  <input 
                    type="radio" 
                    name="product-size" 
                    value={sizeObj.label} 
                    data-price={sizeObj.priceINR}
                    checked={idx === 0}
                  />
                  <span class="size-label">{sizeObj.label}</span>
                  <span class="size-price">₹{sizeObj.priceINR}</span>
                </label>
              ))}
            </div>
            <button class="source-button checkout-trigger">
        <span class="button-text">Continue to the Source</span>
      </button>
          </div>
        ) : (
          <p>OFFERING — [product.sizes]</p>
        )}
      </div>
    </section>
  </div>
</div>

<style>
  .depth-experience-container {
    position: relative;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    /* GSAP will pin this container */
  }

  .pin-container {
    width: 100vw;
    height: 100dvh;
    overflow: hidden;
    position: relative;
  }

  .depth-gauge-wrapper {
    position: fixed;
    right: 24px;
    top: 0; 
    z-index: 9999;
    cursor: pointer;
  }

  .stratum {
    position: absolute;
    top: 0;
    left: 0;
    width: 100vw;
    will-change: transform;
  }

  .stratum-content {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-forest-deep);
    transform-origin: top center;
    will-change: transform;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.4);
    position: relative;
    overflow: hidden;
  }

  .stratum-shadow {
    position: absolute;
    inset: 0;
    background-color: #000;
    opacity: 0;
    pointer-events: none;
    z-index: 5;
  }

  .stratum-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    /* Blend photography subtly into the Forest Deep brand color */
    opacity: 0.55;
    mix-blend-mode: luminosity;
    z-index: 1;
    pointer-events: none;
  }

  /* Terrain Cuts / Map Borders - Dynamically injected via --mask-url to match the active origin */
  .stratum-canopy, .stratum-land, .stratum-hand, .stratum-specimen, .stratum-offering {
    -webkit-mask-image: var(--mask-url);
    mask-image: var(--mask-url);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    /* Use the map image exactly as provided by the user. 
       The user pre-cropped the map outline so the left and bottom are perfectly straight,
       and the top and right form the jagged cut. We stretch it to fill the screen exactly. */
    -webkit-mask-size: 100vw 100vh;
    mask-size: 100vw 100vh;
    -webkit-mask-position: top left;
    mask-position: top left;
  }
  
  .stratum-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    /* Add padding so content doesn't get clipped by the top/right topographical cuts */
    padding-top: 8vh;
    padding-right: 12vw;
  }
  
  /* Additional layer specific styles can go here if needed */

  .stratum-image.image-preserve-people {
    opacity: 0.55;
    mix-blend-mode: normal;
  }

  /* Basic typographic styling */
  .stratum-title {
    font-family: var(--font-narrative);
    /* Fluid typography prevents long botanical names from wrapping ungracefully on mobile */
    font-size: clamp(1.5rem, 5vw, var(--text-size-stratum-title));
    font-weight: 300;
    letter-spacing: 0.05em;
    margin: 0 0 1rem 0;
    z-index: 10;
    position: relative;
    text-align: center;
    max-width: 75vw;
    padding: 0 2rem;
    line-height: 1.4;
  }

  .offering-content {
    flex-direction: column;
  }

  /* Size Selector Styles */
  .size-selector {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
    z-index: 10;
    position: relative;
  }

  .size-options {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .size-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 1.5rem;
    border: 1px solid rgba(245, 237, 216, 0.2);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .size-option:has(input:checked) {
    border-color: var(--color-gold);
    background-color: rgba(166, 124, 60, 0.1);
  }

  .size-option input {
    display: none;
  }

  .size-label {
    font-family: var(--font-evidence);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .size-price {
    font-family: var(--font-narrative);
    font-size: 1.2rem;
    color: var(--color-gold);
  }

  .primary-btn {
    background-color: var(--color-gold);
    color: var(--color-forest-deep);
    border: none;
    padding: 1rem 3rem;
    font-family: var(--font-institutional);
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .primary-btn:hover {
    background-color: var(--color-warm-cream);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  class DepthExperience {
    constructor() {
      this.initStrata();
      this.initDepthGauge();
      this.initPurchaseAction();
      
      document.fonts.ready.then(() => {
        ScrollTrigger.refresh();
      });
    }

    initPurchaseAction() {
  const checkoutBtn = document.querySelector('.checkout-trigger');
  if (checkoutBtn) {
    checkoutBtn.addEventListener('click', () => {
      // Find the currently selected size and price
      const selected = document.querySelector('input[name="product-size"]:checked') as HTMLInputElement;
      
      let sizeText = selected ? selected.value : 'a selection';
      let priceText = selected ? `₹${selected.dataset.price}` : '₹...';
      
      const pinContainer = document.querySelector('.pin-container') as HTMLElement;
      const originName = pinContainer?.dataset.originName || "OurOrigin";
      const productName = pinContainer?.dataset.productName || "Product";
      
      const message = `Hello, I am interested in sourcing ${originName} ${productName} (${sizeText}) at ${priceText}.`;
      const waNumber = "919645555668";
      const waUrl = `https://wa.me/${waNumber}?text=${encodeURIComponent(message)}`;
      
      window.open(waUrl, '_blank');
    });
  }
}

    initStrata() {
      const strata = document.querySelectorAll('.stratum');
      
      // Start all strata below the viewport EXCEPT the first one
      // We also offset them slightly to the left so they slide in diagonally to form the top/right stacked cascade
      gsap.set(strata, { 
        y: (i) => i === 0 ? "0dvh" : "100dvh",
        x: (i) => i === 0 ? "0vw" : `-${i * 4}vw` 
      });

      // Create a master pinned timeline
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: ".depth-experience-container",
          start: "top top",
          end: "+=350%", // Slowed down from 150% to give a luxurious, deliberate pace
          scrub: true,
          pin: ".pin-container",
          anticipatePin: 1,
          snap: {
            snapTo: "labels",
            duration: { min: 0.2, max: 0.6 },
            delay: 0.1,
            ease: "power1.inOut"
          }
        }
      });
      
      tl.addLabel("step0"); // Base state

      strata.forEach((stratum, index) => {
        if (index === 0) return; // First stratum is already at y:0

        const prevStratum = strata[index - 1];
        const prevContent = prevStratum.querySelector('.stratum-content');
        const prevShadow = prevStratum.querySelector('.stratum-shadow');
        const prevTitle = prevStratum.querySelector('.stratum-title');
        const prevSelector = prevStratum.querySelector('.size-selector'); 

        const topOffset = index * 4; // Uniform distance move to stack (4vh down)
        const leftOffset = index * 4; // Uniform distance move to stack (4vw left)
        const label = `step${index}`;

        // 1. Current stratum slides up to its designated resting offset
        tl.to(stratum, {
          y: `${topOffset}dvh`,
          x: `-${leftOffset}vw`,
          ease: "none",
          duration: 1
        }, label)
        
        // 2. Previous stratum darkens completely so it becomes a receding shadow band
        .to(prevShadow, {
          opacity: 0.5,
          ease: "none",
          duration: 1
        }, label)
        
        // 3. Previous stratum text transforms into a large, faint watermark behind the organic terrain cut
        .to(prevTitle, {
          y: "-30dvh",
          scale: 1.8,
          opacity: 0.08,
          ease: "none",
          duration: 1
        }, label)
        
        .to(prevSelector, {
          opacity: 0,
          ease: "none",
          duration: 0.5
        }, label);
      });
      
      tl.addLabel("step" + strata.length); // Final snap point
    }

    initDepthGauge() {
      const gauge = document.querySelector('.depth-gauge-wrapper');
      const container = document.querySelector('.depth-experience-container');

      if (gauge && container) {
        gsap.fromTo(gauge, 
          { y: "10dvh" }, 
          { 
            y: "80dvh",
            ease: "none",
            scrollTrigger: {
              trigger: container,
              start: "top top",
              end: "+=200%", // Matches the new faster pin duration
              scrub: true
            }
          }
        );

        gauge.addEventListener('click', () => {
          console.log('open spatial overlay - future direction');
        });

        document.dispatchEvent(new CustomEvent('play-origin-mark-entrance'));
      }
    }
  }

  // Ensure initialization happens safely
  new DepthExperience();
</script>
