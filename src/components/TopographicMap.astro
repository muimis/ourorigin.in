---
export interface Props {
  index: number;
}

const { index } = Astro.props;

// Topographic Curves (Left to Right) for bands 1 to 4 (index 1 to 4)
// Using more organic Cubic Beziers (C) to mimic natural map boundaries
const curves = [
  "", // Band 0
  "M0,60 C150,60 200,10 300,20 C400,30 450,90 600,70 C750,50 850,10 1000,40",
  "M0,40 C100,40 150,80 250,70 C350,60 400,20 550,30 C700,40 800,90 1000,60",
  "M0,70 C200,70 250,20 400,30 C550,40 600,80 750,60 C900,40 950,20 1000,50",
  "M0,30 C150,30 200,70 350,60 C500,50 600,10 750,30 C900,50 950,80 1000,40"
];

// Inner contour lines (mimicking an elegant, deliberate, hand-crafted topographic map)
const innerContours = [
  [
    // Band 0 (Nilgiris) - High plateau, elegant sweeping lines
    "M0,20 C300,50 700,0 1000,30",
    "M0,35 C300,65 700,15 1000,45",
    "M0,50 C300,80 700,30 1000,60",
    "M0,65 C300,95 700,45 1000,75",
    "M150,40 C180,20 220,30 240,50 C220,70 180,60 150,40 Z",
    "M750,25 C780,10 820,20 840,40 C820,60 780,50 750,25 Z"
  ],
  [
    // Band 1 - Valleys and subtle peaks
    "M0,75 C150,75 200,25 300,35 C400,45 450,105 600,85 C750,65 850,25 1000,55",
    "M0,90 C150,90 200,40 300,50 C400,60 450,120 600,100 C750,80 850,40 1000,70",
    "M0,105 C150,105 200,55 300,65 C400,75 450,135 600,115 C750,95 850,55 1000,85",
    "M250,90 C280,70 320,70 340,90 C360,110 320,130 290,110 Z",
    "M800,80 C820,60 860,60 880,80 C900,100 860,120 830,100 Z"
  ],
  [
    // Band 2 - Wide expanses
    "M0,55 C100,55 150,95 250,85 C350,75 400,35 550,45 C700,55 800,105 1000,75",
    "M0,70 C100,70 150,110 250,100 C350,90 400,50 550,60 C700,70 800,120 1000,90",
    "M0,85 C100,85 150,125 250,115 C350,105 400,65 550,75 C700,85 800,135 1000,105",
    "M450,90 C480,70 520,70 540,90 C560,110 520,130 490,110 Z",
    "M100,100 C130,80 170,80 190,100 C210,120 170,140 140,120 Z"
  ],
  [
    // Band 3 - Sharp ascents
    "M0,85 C200,85 250,35 400,45 C550,55 600,95 750,75 C900,55 950,35 1000,65",
    "M0,100 C200,100 250,50 400,60 C550,70 600,110 750,90 C900,70 950,50 1000,80",
    "M0,115 C200,115 250,65 400,75 C550,85 600,125 750,105 C900,85 950,65 1000,95",
    "M650,110 C680,90 720,90 740,110 C760,130 720,150 690,130 Z",
    "M300,80 C330,60 370,60 390,80 C410,100 370,120 340,100 Z"
  ],
  [
    // Band 4 - Deep ravines
    "M0,45 C150,45 200,85 350,75 C500,65 600,25 750,45 C900,65 950,95 1000,55",
    "M0,60 C150,60 200,100 350,90 C500,80 600,40 750,60 C900,80 950,110 1000,70",
    "M0,75 C150,75 200,115 350,105 C500,95 600,55 750,75 C900,95 950,125 1000,85",
    "M550,100 C580,80 620,80 640,100 C660,120 620,140 590,120 Z",
    "M150,90 C180,70 220,70 240,90 C260,110 220,130 190,110 Z"
  ]
];

const curve = curves[index];
const inners = innerContours[index];
---

<svg 
  class="topographic-map" 
  viewBox="0 0 1000 150" 
  preserveAspectRatio="none" 
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Main Topographic Plate Boundary -->
  {curve && (
    <path 
      class="plate-border" 
      d={curve} 
    />
  )}

  <!-- Inner Topographic Contours (Map details) -->
  {inners.map(p => (
    <path class="inner-contour" d={p} />
  ))}
</svg>

<style>
  .topographic-map {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    /* Fixed 150px height matching the mask size so curves never stretch vertically! */
    height: 150px; 
    z-index: 10;
    pointer-events: none;
  }

  .plate-border {
    fill: none;
    stroke: rgba(245, 237, 216, 0.4); /* Visible edge of the plate */
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
  }

  .inner-contour {
    fill: none;
    stroke: rgba(245, 237, 216, 0.04); /* Extremely faint map lines, organic reality feel */
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  /* Only transitions opacity/visibility to prevent GSAP distortion */
  .topographic-map {
    transition: opacity var(--duration-standard) ease;
  }
</style>
