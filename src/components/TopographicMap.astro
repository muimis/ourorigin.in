---
export interface Props {
  index: number;
}

const { index } = Astro.props;

// Topographic Curves (Left to Right) for bands 1 to 4 (index 1 to 4)
// Using more organic Cubic Beziers (C) to mimic natural map boundaries
const curves = [
  "", // Band 0
  "M0,60 C150,60 200,10 300,20 C400,30 450,90 600,70 C750,50 850,10 1000,40",
  "M0,40 C100,40 150,80 250,70 C350,60 400,20 550,30 C700,40 800,90 1000,60",
  "M0,70 C200,70 250,20 400,30 C550,40 600,80 750,60 C900,40 950,20 1000,50",
  "M0,30 C150,30 200,70 350,60 C500,50 600,10 750,30 C900,50 950,80 1000,40"
];

const curve = curves[index];

// Distinct visual sections of the topographic map for each plate
const patternOffsetY = index * 25; // Shifts the background vertically 0%, 25%, 50%, etc.
const patternOffsetX = index * 10;
---

<div class="topographic-map-container">
  <div class="topographic-pattern" style={`background-position: ${patternOffsetX}% ${patternOffsetY}%;`}></div>
  
  {curve && (
    <svg 
      class="topographic-border" 
      viewBox="0 0 1000 150" 
      preserveAspectRatio="none" 
      xmlns="http://www.w3.org/2000/svg"
    >
      <path class="plate-border" d={curve} />
    </svg>
  )}
</div>

<style>
  .topographic-map-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10;
    pointer-events: none;
    overflow: hidden;
  }

  .topographic-pattern {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url('/topographic_pattern.svg');
    background-size: cover;
    opacity: 0.6; /* Slightly fade the pattern so text remains readable */
  }

  @media (max-width: 768px) {
    .topographic-pattern {
      opacity: 0.25; /* Severely reduce on mobile to prevent text clash */
    }
  }

  .topographic-border {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 150px;
  }

  .plate-border {
    fill: none;
    stroke: rgba(245, 237, 216, 0.4); /* Visible edge of the plate */
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
  }

  @media (max-width: 768px) {
    .plate-border {
      stroke: rgba(245, 237, 216, 0.15);
    }
  }
</style>
