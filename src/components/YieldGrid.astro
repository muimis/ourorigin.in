---
// src/components/YieldGrid.astro
import { getCollection } from 'astro:content';

const products = await getCollection('products');
const origins = await getCollection('origins');

// Helper to format currency
const formatPrice = (price) => {
  return new Intl.NumberFormat('en-IN', {
    style: 'currency',
    currency: 'INR',
    minimumFractionDigits: 0
  }).format(price);
};
---

<section id="yields" class="yield-grid-section">
  <div class="section-header">
    <h2 class="section-title">The Harvest</h2>
    <p class="section-subtitle">Boundless Origins. Singular Quality.</p>
  </div>

  <div class="product-grid">
    {products.map((product) => {
      // Find origin name for the pill
      const originId = typeof product.data.originSlug === 'object' ? product.data.originSlug.id : product.data.originSlug;
      const origin = origins.find(o => o.id === originId);
      
      // Resolve map image
      let mapSvg = '/maps/topographic.svg';
      if (originId === 'wayanad') mapSvg = '/maps/wayanad.svg';
      if (originId === 'idukki') mapSvg = '/maps/idukki.svg';
      if (originId === 'thiruvananthapuram') mapSvg = '/maps/trivandrum.svg';
      
      const packagingImg = product.data.images?.packaging || null;
      
      return (
        <div class="product-card">
          <div class="card-watermark">
            <img src={mapSvg} alt="" aria-hidden="true" />
          </div>
          <div class="product-image-placeholder">
            {packagingImg ? (
              <img src={packagingImg} alt={`${product.data.name} Packaging`} class="product-img-actual" />
            ) : (
              <span class="image-text">No Image</span>
            )}
          </div>
          <div class="product-info">
            <div class="product-meta">
              <span class="origin-pill">{origin?.data.name || 'Unknown Origin'}</span>
            </div>
            <h3 class="product-name">{product.data.name}</h3>
            <p class="product-price">{formatPrice(product.data.sizes[0].priceINR)} / {product.data.sizes[0].label}</p>
            <button 
              class="add-to-basket-btn" 
              data-id={product.id}
              data-name={product.data.name}
              data-origin={origin?.data.name || 'Unknown Origin'}
              data-price={product.data.sizes[0].priceINR}
              data-weight={product.data.sizes[0].label}
              aria-label={`Add ${product.data.name} to basket`}
            >
              Add to Basket
            </button>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .yield-grid-section {
    padding: var(--space-4xl) var(--space-xl);
    background-color: var(--color-warm-cream);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-forest-deep);
    font-weight: 400;
  }

  .section-subtitle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-forest-deep);
    opacity: 0.6;
    margin-top: var(--space-sm);
  }

  .product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    max-width: 1400px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1440px) {
    .product-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .product-card {
    display: flex;
    flex-direction: column;
    position: relative;
    background: rgba(245, 237, 216, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(12, 21, 9, 0.05);
    border-radius: 8px;
    padding: var(--space-md);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
    overflow: hidden;
  }

  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(12, 21, 9, 0.08);
  }

  .card-watermark {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.03;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .card-watermark img {
    width: 150%;
    height: 150%;
    object-fit: contain;
    transform: rotate(-15deg);
    transition: transform 1s ease;
  }

  .product-card:hover .card-watermark img {
    transform: rotate(0deg) scale(1.1);
  }

  .product-image-placeholder {
    width: 100%;
    aspect-ratio: 4/5;
    background-color: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  .product-img-actual {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.1));
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover .product-img-actual {
    transform: scale(1.05);
  }

  .image-text {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-forest-deep);
    opacity: 0.3;
    text-transform: uppercase;
  }

  .product-info {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
  }

  .product-meta {
    margin-bottom: var(--space-xs);
  }

  .origin-pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-forest-deep);
    border: 1px solid rgba(13, 30, 17, 0.2);
    padding: 2px 8px;
    border-radius: 999px;
  }

  .product-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-forest-deep);
    font-weight: 400;
    margin-bottom: var(--space-xs);
    line-height: 1.2;
  }

  .product-price {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-forest-deep);
    opacity: 0.8;
    margin-bottom: var(--space-lg);
  }

  .add-to-basket-btn {
    margin-top: auto;
    width: 100%;
    min-height: 48px;
    background-color: transparent;
    border: 1px solid var(--color-forest-deep);
    color: var(--color-forest-deep);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .add-to-basket-btn:hover {
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
  }

  .add-to-basket-btn:active {
    transform: scale(0.98);
  }

  /* Micro-animation class when clicked */
  .add-to-basket-btn.added {
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    transform: scale(1.02);
  }
</style>

<script>
  import { cartState } from '../scripts/cart.js';

  document.querySelectorAll('.add-to-basket-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const b = e.currentTarget;
      
      // Add to cart state
      cartState.addItem({
        id: b.dataset.id,
        name: b.dataset.name,
        origin: b.dataset.origin,
        price: parseInt(b.dataset.price, 10),
        weight: b.dataset.weight
      });

      // Micro-animation: Change text temporarily to show success
      const originalText = b.textContent;
      b.textContent = "Added to Basket";
      b.classList.add("added");

      setTimeout(() => {
        b.textContent = originalText;
        b.classList.remove("added");
      }, 1000);
      
      // Optionally open the cart automatically
      window.dispatchEvent(new Event('open-cart'));
    });
  });
</script>
