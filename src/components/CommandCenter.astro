---
import OriginMark from './OriginMark.astro';
---

<button id="trigger-yields" class="hud-telemetry-btn" aria-label="All Yields">
  [ ALL YIELDS ]
</button>

<div id="command-center-trigger" aria-label="Open Navigation">
  <OriginMark variant="gold" size={32} animate={false} />
</div>

<button id="trigger-dossier" class="hud-telemetry-btn" aria-label="Open Dossier">
  [ DOSSIER : <span class="dossier-count">0</span> ]
</button>

<div id="command-center-overlay" aria-hidden="true">
  <div class="cc-close" aria-label="Close Navigation">
    <OriginMark variant="gold" size={32} animate={false} />
  </div>
  
  <nav class="cc-nav">
    <a href="/observations">Observations</a>
    <a href="/why">Why this exists.</a>
    <a href="/contact">Contact</a>
    <button id="cc-all-yields-btn" class="cc-button">All Yields</button>
  </nav>

  <div class="cc-legal">
    OURORIGIN — FSSAI Reg. No. 21326135000354
  </div>
</div>

<style>
  #command-center-trigger {
    position: fixed;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 8000;
    cursor: pointer;
    transition: top 0.6s cubic-bezier(0.16, 1, 0.3, 1), left 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
    opacity: 1;
  }
  #command-center-trigger:hover {
    transform: translateX(-50%) scale(1.1);
  }
  
  .hud-telemetry-btn {
    position: fixed;
    bottom: 18px;
    z-index: 8000;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: rgba(245, 237, 216, 0.6);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: color 0.3s ease, opacity 0.4s ease;
    white-space: nowrap;
  }
  .hud-telemetry-btn:hover {
    color: var(--color-gold);
  }
  #trigger-yields {
    right: calc(50% + 30px);
  }
  #trigger-dossier {
    left: calc(50% + 30px);
  }
  
  /* Force the inner SVG elements to at least 80% opacity for this specific mark */
  #command-center-trigger :global(.origin-mark *) {
    opacity: 0.8 !important;
  }
  
  /* When a matrix plate is expanded, move the trigger to the top left */
  :global(body.matrix-expanded) #command-center-trigger {
    bottom: auto;
    top: 40px; /* 10mm */
    left: 40px; /* 10mm */
    transform: none;
  }
  :global(body.matrix-expanded) #command-center-trigger:hover {
    transform: scale(1.1);
  }
  :global(body.matrix-expanded) .hud-telemetry-btn {
    opacity: 0;
    pointer-events: none;
  }
  
  @media (max-width: 768px) {
    :global(body.matrix-expanded) #command-center-trigger {
      top: 24px;
      left: 24px;
    }
  }

  #command-center-overlay {
    position: fixed;
    inset: 0;
    z-index: 9000;
    background: rgba(12, 21, 9, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #command-center-overlay.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .cc-close {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    cursor: pointer;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cc-close:hover {
    transform: translateX(-50%) scale(0.9);
  }

  .cc-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.5rem;
    transform: translateY(20px);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #command-center-overlay.is-active .cc-nav {
    transform: translateY(0);
  }

  .cc-nav a, .cc-button {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.5rem;
    font-weight: 300;
    color: var(--color-warm-cream);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.4s ease, opacity 0.4s ease;
    opacity: 0.6;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    line-height: 1;
  }

  .cc-nav a:hover, .cc-button:hover {
    color: var(--color-gold);
    opacity: 1;
  }

  .cc-legal {
    position: absolute;
    bottom: 2.5rem;
    right: 3rem;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: rgba(245, 237, 216, 0.4);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  
  @media (max-width: 768px) {
    .cc-nav a, .cc-button { 
      font-size: 2.5rem; 
    }
    .cc-nav {
      gap: 2.5rem;
    }
    .cc-legal { 
      bottom: auto;
      top: 2rem; 
      right: auto; 
      left: 50%; 
      transform: translateX(-50%); 
      width: 100%; 
      text-align: center;
    }
  }
</style>

<script>
  const trigger = document.getElementById('command-center-trigger');
  const close = document.querySelector('.cc-close');
  const overlay = document.getElementById('command-center-overlay');

  if (trigger && close && overlay) {
    trigger.addEventListener('click', () => {
      overlay.classList.add('is-active');
      trigger.style.opacity = '0';
      trigger.style.pointerEvents = 'none';
      document.body.style.overflow = 'hidden'; // Lock scroll if applicable
    });
    
    close.addEventListener('click', () => {
      overlay.classList.remove('is-active');
      trigger.style.opacity = '0.8';
      trigger.style.pointerEvents = 'auto';
      document.body.style.overflow = '';
    });
    
    const ccYieldsBtn = document.getElementById('cc-all-yields-btn');
    if (ccYieldsBtn) {
      ccYieldsBtn.addEventListener('click', () => {
        overlay.classList.remove('is-active');
        trigger.style.opacity = '0.8';
        trigger.style.pointerEvents = 'auto';
        document.body.style.overflow = '';
        window.dispatchEvent(new Event('open-all-yields-panel'));
      });
    }

    const triggerYields = document.getElementById('trigger-yields');
    if (triggerYields) {
      triggerYields.addEventListener('click', () => {
        window.dispatchEvent(new Event('open-all-yields-panel'));
      });
    }
  }
</script>
