---
import OriginMark from './OriginMark.astro';

export interface Props {
  variant?: 'dark' | 'light';
}

const { variant = 'dark' } = Astro.props;
---

<header class={`global-header header-${variant}`}>
  <a href="/" class="header-logo" aria-label="OurOrigin Home">
    <OriginMark variant={variant === 'light' ? 'reversed' : 'gold'} size={32} animate={false} />
  </a>

  <div class="header-actions">
    <a href="/catalog" class="hud-btn" aria-label="Shop All">
      Shop
    </a>

    <button id="command-center-trigger" class="hud-btn" aria-label="Open Navigation">
      Menu
    </button>

    <button id="trigger-dossier" class="hud-btn" aria-label="Open Basket" onclick="window.dispatchEvent(new Event('open-cart'))">
      Basket (<span class="dossier-count" id="header-basket-count">0</span>)
    </button>
  </div>
</header>

<div id="command-center-overlay" aria-hidden="true">
  <nav class="cc-nav">
    <a href="/">Home</a>
    <a href="/horizon">Horizon</a>
    <a href="/catalog">Index</a>
    <a href="/why">Why This Exists</a>
    <a href="/observations">Observations</a>
    <a href="/contact">Contact</a>
  </nav>

  <button class="cc-close" aria-label="Close Navigation">
    <OriginMark variant="gold" size={28} animate={false} />
    <span class="cc-close-label">Close</span>
  </button>
</div>

<style>
  .global-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    padding: 16px clamp(1.5rem, 5vw, 3.5rem);
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 8000;
    box-sizing: border-box;
    pointer-events: none;
    background: linear-gradient(to bottom, rgba(3, 5, 3, 0.9) 0%, rgba(3, 5, 3, 0) 100%);
  }

  .header-logo {
    pointer-events: auto;
    cursor: pointer;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
  }
  .header-logo:hover {
    transform: scale(1.05);
  }

  .header-actions {
    display: flex;
    gap: 1.6rem;
    align-items: center;
    pointer-events: auto;
    background: rgba(8, 16, 6, 0.65);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding: 8px 20px;
    border-radius: 30px;
    border: 1px solid rgba(247, 242, 230, 0.12);
  }

  .hud-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: color 0.3s ease, opacity 0.3s ease;
    white-space: nowrap;
  }

  /* Dark variant: dark text for light backgrounds */
  .header-dark .hud-btn {
    color: var(--color-forest-deep);
  }
  .header-dark .hud-btn:hover {
    color: var(--color-gold);
  }

  /* Light variant: light text for dark backgrounds */
  .header-light .hud-btn {
    color: rgba(245, 237, 216, 0.6);
  }
  .header-light .hud-btn:hover {
    color: var(--color-warm-cream);
  }

  @media (max-width: 768px) {
    .global-header {
      padding: 16px 1.5rem;
    }
    .header-actions {
      gap: 1rem;
    }
    .hud-btn {
      font-size: 10px;
    }
  }

  /* Force the inner SVG elements to full opacity */
  #command-center-trigger :global(.origin-mark *) {
    opacity: 1 !important;
  }

  /* === Overlay === */
  #command-center-overlay {
    position: fixed;
    inset: 0;
    z-index: 9000;
    background: rgba(12, 21, 9, 0.97);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #command-center-overlay.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .cc-close {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    cursor: pointer;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    background: none;
    border: none;
    padding: 0;
  }
  .cc-close:hover {
    transform: translateX(-50%) scale(0.9);
  }
  .cc-close-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(245, 237, 216, 0.3);
  }

  .cc-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    transform: translateY(15px);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #command-center-overlay.is-active .cc-nav {
    transform: translateY(0);
  }

  .cc-nav a, .cc-button {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    color: var(--color-warm-cream);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.3s ease, opacity 0.3s ease;
    opacity: 0.5;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    line-height: 1.1;
  }

  .cc-nav a:hover, .cc-button:hover {
    color: var(--color-gold);
    opacity: 1;
  }

  @media (max-width: 768px) {
    .cc-nav a, .cc-button {
      font-size: 2rem;
    }
    .cc-nav {
      gap: 2rem;
    }
  }
</style>

<script>
  import { cartState } from '../scripts/cart.js';

  const trigger = document.getElementById('command-center-trigger');
  const close = document.querySelector('.cc-close');
  const overlay = document.getElementById('command-center-overlay');

  if (trigger && close && overlay) {
    trigger.addEventListener('click', () => {
      overlay.classList.add('is-active');
      trigger.style.opacity = '0';
      trigger.style.pointerEvents = 'none';
      document.body.style.overflow = 'hidden';
    });

    close.addEventListener('click', () => {
      overlay.classList.remove('is-active');
      trigger.style.opacity = '1';
      trigger.style.pointerEvents = 'auto';
      document.body.style.overflow = '';
    });

    const ccYieldsBtn = document.getElementById('cc-all-yields-btn');
    if (ccYieldsBtn) {
      ccYieldsBtn.addEventListener('click', () => {
        overlay.classList.remove('is-active');
        trigger.style.opacity = '1';
        trigger.style.pointerEvents = 'auto';
        document.body.style.overflow = '';
        window.dispatchEvent(new Event('open-all-yields-panel'));
      });
    }

    // Basket count
    const basketCountEl = document.getElementById('header-basket-count');
    if (basketCountEl) {
      basketCountEl.textContent = cartState.getTotalItems();
    }

    window.addEventListener('cart-updated', (e) => {
      const { totalItems } = e.detail;
      if (basketCountEl) {
        basketCountEl.textContent = totalItems;
      }
    });



    // Escape key to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('is-active')) {
        overlay.classList.remove('is-active');
        trigger.style.opacity = '1';
        trigger.style.pointerEvents = 'auto';
        document.body.style.overflow = '';
      }
    });
  }
</script>
