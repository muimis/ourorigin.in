---
// src/components/TheCore.astro
import { getCollection } from 'astro:content';
import LiveWeather from './LiveWeather.astro';

const products = await getCollection('products');
const origins = await getCollection('origins');

function parseElevation(elevStr: string) {
  const match = String(elevStr || '').match(/[\d,]+/);
  return match ? parseInt(match[0].replace(/,/g, ''), 10) : 0;
}

const originsBySlug = Object.fromEntries(origins.map(o => [o.data.slug, o]));

// Map each product with its origin data
const productList = products.map(p => {
  const oSlug = typeof p.data.originSlug === 'object' ? p.data.originSlug?.id : p.data.originSlug;
  const originObj = originsBySlug[oSlug];
  return {
    ...p,
    originData: originObj ? originObj.data : null
  };
}).sort((a, b) => {
  const elevA = a.originData ? parseElevation(a.originData.elevation) : 0;
  const elevB = b.originData ? parseElevation(b.originData.elevation) : 0;
  if (elevB !== elevA) return elevB - elevA;
  return (a.data.name || '').localeCompare(b.data.name || '');
});

const sortedOrigins = [...origins].sort((a, b) => {
  return parseElevation(b.data.elevation) - parseElevation(a.data.elevation);
});
---

<section id="the-core" class="the-core-section">
  <!-- Cinematic Ambient Backgrounds -->
  <div class="core-cinematic-bg">
    {sortedOrigins.map(origin => (
      <div 
        class="core-bg-layer" 
        id={`bg-${origin.data.slug}`} 
        style={`background-image: url('${origin.data.images?.canopy || ''}');`}
        aria-hidden="true"
      ></div>
    ))}
  </div>

  <div class="core-content-wrapper">
    <!-- Hero Banner -->
    <div class="core-hero" data-reveal>
      <span class="hero-tag">SOIL &middot; COMMUNITY &middot; HARVEST</span>
      <h1 class="hero-title">OurOrigin</h1>
      <p class="hero-subtitle">Pure natural ingredients, community-harvested directly from their soil of origin.</p>
    </div>

    <!-- Origin Filter Pills -->
    <div class="origin-filter-bar" data-reveal data-delay="100">
      <button class="filter-btn active" data-filter="all">All Provenances</button>
      {sortedOrigins.map(o => (
        <button class="filter-btn" data-filter={o.data.slug}>
          {o.data.name} ({o.data.elevation})
        </button>
      ))}
    </div>

    <!-- Direct Product Gallery Grid (Zero Mazes) -->
    <div class="product-gallery-grid" data-reveal="stagger">
      {productList.map((p) => {
        const oSlug = typeof p.data.originSlug === 'object' ? p.data.originSlug?.id : p.data.originSlug;
        const originObj = originsBySlug[oSlug];
        const priceRange = p.data.sizes.length > 1
          ? `₹${Math.min(...p.data.sizes.map(s => s.priceINR))} - ₹${Math.max(...p.data.sizes.map(s => s.priceINR))}`
          : `₹${p.data.sizes[0].priceINR}`;
        
        const firstSize = p.data.sizes[0];
        const productDataString = JSON.stringify({
          id: p.id + '-' + firstSize.label,
          productId: p.id,
          name: p.data.name,
          origin: originObj ? originObj.data.name : oSlug,
          originId: oSlug,
          price: firstSize.priceINR,
          size: firstSize.label,
          weight: firstSize.label,
          quantity: 1
        });

        const hasRealPackaging = !!(p.data.images?.packaging && p.data.images.packaging.trim() !== '');

        return (
          <article class="gallery-card" data-origin={oSlug}>
            <div class="card-image-wrap">
              {hasRealPackaging ? (
                <img src={p.data.images.packaging} alt={`Packaging of ${p.data.name}`} class="card-img" loading="lazy" />
              ) : (
                <div class="card-img-pending" role="img" aria-label={`Photography pending for ${p.data.name}`}>
                  <svg viewBox="0 0 100 100" width="48" height="48" aria-hidden="true">
                    <circle cx="50" cy="50" r="49" stroke="currentColor" stroke-width="1.5" fill="none"/>
                    <circle cx="50" cy="50" r="4" fill="currentColor"/>
                  </svg>
                </div>
              )}
              <span class="card-origin-pill">{originObj ? `Community Harvest · ${originObj.data.name}` : oSlug}</span>
            </div>

            <div class="card-content">
              <div class="card-meta">
                <h3 class="card-title">{p.data.name}</h3>
                <span class="card-botanical">{p.data.botanicalName}</span>
              </div>

              <div class="card-price-row">
                <span class="card-price">{priceRange}</span>
              </div>

              <div class="card-actions">
                <button class="add-basket-btn" data-product={productDataString}>
                  Add to basket
                </button>
                <a href={`/origins/${oSlug}/${p.id}`} class="explore-story-link">
                  Story &rarr;
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .the-core-section {
    position: relative;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    min-height: 100vh;
  }

  .core-cinematic-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .core-bg-layer {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.25, 1, 0.5, 1), transform 1.2s ease-out;
    filter: saturate(0.2) contrast(1.1) brightness(0.35);
    transform: scale(1.04);
  }

  .core-bg-layer.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .core-content-wrapper {
    position: relative;
    z-index: 2;
    padding: 18vh clamp(1.5rem, 5vw, 6rem) 12vh;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Hero Banner */
  .core-hero {
    margin-bottom: 4rem;
    text-align: left;
  }

  .hero-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.25em;
    color: var(--color-gold);
    text-transform: uppercase;
  }

  .hero-title {
    font-family: var(--font-institutional);
    font-size: clamp(3.5rem, 9vw, 8.5rem);
    font-weight: 300;
    margin: 1rem 0 1.5rem 0;
    line-height: 0.95;
    letter-spacing: -0.01em;
  }

  .hero-subtitle {
    font-family: var(--font-narrative);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    font-weight: 300;
    color: rgba(245, 237, 216, 0.75);
    max-width: 680px;
    margin: 0;
    line-height: 1.4;
  }

  /* Filter Bar */
  .origin-filter-bar {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 4rem;
    border-bottom: 1px solid rgba(245, 237, 216, 0.1);
    padding-bottom: 1.5rem;
  }

  .filter-btn {
    background: transparent;
    border: none;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: rgba(245, 237, 216, 0.45);
    cursor: pointer;
    padding: 6px 12px;
    transition: all 0.3s ease;
    text-transform: uppercase;
  }

  .filter-btn:hover,
  .filter-btn.active {
    color: var(--color-gold);
    background: rgba(166, 124, 60, 0.08);
  }

  /* Direct Product Gallery Grid */
  .product-gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  .gallery-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .gallery-card.is-filtered-out {
    display: none;
  }

  .gallery-card:hover {
    transform: translateY(-6px);
  }

  .card-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background: rgba(0, 0, 0, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .card-img {
    max-width: 75%;
    max-height: 75%;
    object-fit: contain;
    filter: brightness(0.92) contrast(1.05);
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .gallery-card:hover .card-img {
    transform: scale(1.06);
  }

  .card-img-pending {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-warm-cream);
    opacity: 0.3;
    width: 100%;
    height: 100%;
  }

  .card-origin-pill {
    position: absolute;
    bottom: 12px;
    left: 12px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    background: rgba(12, 21, 9, 0.85);
    backdrop-filter: blur(8px);
    padding: 4px 10px;
    text-transform: uppercase;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
  }

  .card-title {
    font-family: var(--font-institutional);
    font-size: 1.6rem;
    font-weight: 300;
    color: var(--color-warm-cream);
    margin: 0 0 0.2rem 0;
    line-height: 1.1;
  }

  .card-botanical {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem;
    color: rgba(245, 237, 216, 0.5);
  }

  .card-price-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-price {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-gold);
    letter-spacing: 0.05em;
  }

  .card-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-top: 0.5rem;
  }

  .add-basket-btn {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-gold);
    background: transparent;
    border: 1px solid rgba(166, 124, 60, 0.4);
    padding: 10px 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
  }

  .add-basket-btn:hover,
  .add-basket-btn.is-added {
    background: var(--color-gold);
    color: var(--color-forest-deep);
    border-color: var(--color-gold);
  }

  .explore-story-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: rgba(245, 237, 216, 0.6);
    text-decoration: none;
    padding: 10px 14px;
    transition: color 0.3s ease;
  }

  .explore-story-link:hover {
    color: var(--color-warm-cream);
  }

  /* Responsive Grid */
  @media (max-width: 1024px) {
    .product-gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }
  }

  @media (max-width: 640px) {
    .product-gallery-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>

<script>
  function initTheCore() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.gallery-card');
    const bgLayers = document.querySelectorAll('.core-bg-layer');

    // Origin Filter Logic
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const filter = btn.getAttribute('data-filter');

        // Background highlight
        bgLayers.forEach(layer => {
          if (filter !== 'all' && layer.id === `bg-${filter}`) {
            layer.classList.add('is-active');
          } else {
            layer.classList.remove('is-active');
          }
        });

        // Filter cards
        cards.forEach(card => {
          const origin = card.getAttribute('data-origin');
          if (filter === 'all' || origin === filter) {
            card.classList.remove('is-filtered-out');
          } else {
            card.classList.add('is-filtered-out');
          }
        });
      });
    });

    // Card Hover Ambient Effect
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        const origin = card.getAttribute('data-origin');
        bgLayers.forEach(layer => {
          if (layer.id === `bg-${origin}`) {
            layer.classList.add('is-active');
          } else {
            layer.classList.remove('is-active');
          }
        });
      });
    });

    const grid = document.querySelector('.product-gallery-grid');
    if (grid) {
      grid.addEventListener('mouseleave', () => {
        const activeFilter = document.querySelector('.filter-btn.active')?.getAttribute('data-filter');
        bgLayers.forEach(layer => {
          if (activeFilter !== 'all' && layer.id === `bg-${activeFilter}`) {
            layer.classList.add('is-active');
          } else {
            layer.classList.remove('is-active');
          }
        });
      });
    }

    // Add to Basket Event Trigger
    document.querySelectorAll('.add-basket-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const data = JSON.parse(btn.getAttribute('data-product') || '{}');
        window.dispatchEvent(new CustomEvent('add-to-ledger', { detail: data }));

        const original = btn.textContent;
        btn.textContent = 'Added ✓';
        btn.classList.add('is-added');
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove('is-added');
        }, 1200);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTheCore);
  } else {
    initTheCore();
  }
  document.addEventListener('astro:page-load', initTheCore);
</script>
