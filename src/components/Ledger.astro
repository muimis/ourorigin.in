    flex-direction: column;
    gap: 0.8rem;
    margin-bottom: 2rem;
  }
  .shipping-form input {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(245, 237, 216, 0.2);
    color: var(--color-warm-cream);
    font-family: 'DM Mono', monospace;
