---
import { getCollection } from 'astro:content';
import { WHATSAPP_NUMBER, FSSAI_NUMBER } from '../utils/constants';

const products = await getCollection('products');

// Build a map of originId -> companion product names
const companionProductsMap = {};
products.forEach(product => {
  if (!product.data.isAnchorProduct) {
    const originId = typeof product.data.originSlug === 'object' ? product.data.originSlug.id : product.data.originSlug;
    if (!companionProductsMap[originId]) {
      companionProductsMap[originId] = [];
    }
    companionProductsMap[originId].push({
      id: product.id,
      name: product.data.name
    });
  }
});

const companionsJson = JSON.stringify(companionProductsMap);
---

<!-- Global Toast -->
<div id="ledger-toast" class="ledger-toast hidden" role="status" aria-live="polite" aria-atomic="true">
  Added to your Ledger.
</div>

<!-- Persistent Trigger -->
<div id="ledger-trigger" class="ledger-trigger hidden" aria-live="polite" role="button" tabindex="0">
  <span id="ledger-count"></span> held
</div>

<!-- Slide-up Panel -->
<div id="ledger-overlay" class="ledger-overlay hidden">
  <div class="ledger-backdrop" id="ledger-close-backdrop"></div>
  <div class="ledger-panel" role="complementary" aria-label="Your Ledger">
    <div class="ledger-header">
      <h2 class="ledger-title">Your Ledger</h2>
      <button id="ledger-close-btn" class="ledger-close" aria-label="Close Ledger">Close</button>
    </div>
    
    <div class="ledger-content">
      <div id="ledger-items-container" class="ledger-items">
        <!-- JS will populate items here -->
      </div>
      
      <div id="ledger-empty-state" class="ledger-empty hidden">
        The ledger is empty.<br>Explore the origins.
      </div>
      
      <div id="ledger-footer" class="ledger-footer hidden">
        <div class="ledger-total">
          <span>Subtotal</span>
          <span id="ledger-subtotal-price" class="price-font">₹0</span>
        </div>
        
        <!-- Order Summary (Gap 2) -->
        <div id="ledger-order-summary" class="ledger-order-summary">
          <p class="summary-heading">YOUR ORDER</p>
          <div id="summary-items" class="summary-items"></div>
          <hr class="summary-divider" />
          <div class="summary-row">
            <span>Subtotal</span>
            <span id="summary-subtotal">₹0</span>
          </div>
          <div class="summary-row">
            <span>Shipping</span>
            <span id="summary-shipping">Free</span>
          </div>
          <div id="shipping-prompt-note" class="shipping-prompt-note hidden"></div>
          <hr class="summary-divider-solid" />
          <div class="summary-row total-row">
            <span>Total</span>
            <span id="summary-total">₹0</span>
          </div>
          <p class="dispatch-timeline">DISPATCH WITHIN 2–3 WORKING DAYS · THIRUVANANTHAPURAM</p>
        </div>
        <div class="ledger-observation-guide">
          <p class="observation-title">OBSERVATION LOG: THE REALITY</p>
          <p class="observation-text">
            This ledger reflects a journey deep into the forest. It reflects a community leaving the unripened—and whatever the wild animals claim—to nature with joy, not compromise. Their dignity is inherent. By proceeding, you are not a consumer. You are taking your place as the final link in this origin system.
          </p>
        </div>

        <p class="summary-heading">WHERE TO SEND THIS</p>        
        <!-- Shipping Form -->
        <form id="shipping-form" class="shipping-form">
          <input type="text" id="ship-name" name="name" placeholder="Full name" required />
          <input type="text" id="ship-house" name="house" placeholder="House/Flat number" required />
          <input type="text" id="ship-street" name="street" placeholder="Street/Locality" required />
          <div class="form-row">
            <input type="text" id="ship-city" name="city" placeholder="City" required />
            <input type="text" id="ship-state" name="state" placeholder="State" required />
          </div>
          <div class="form-row">
            <input type="text" id="ship-pin" name="pin" placeholder="PIN Code (6 digits)" pattern="[0-9]{6}" required />
            <input type="tel" id="ship-phone" name="phone" placeholder="Phone (for delivery updates)" pattern="[0-9]{10,12}" required />
          </div>
          <div class="shipping-actions">
            <p id="shipping-saved-note" class="shipping-saved-note hidden">Saved from your last order. Tap any field to change.</p>
            <button type="button" id="clear-shipping-btn" class="clear-shipping-btn hidden">Clear saved details</button>
          </div>
        </form>

        <!-- What happens next (Gap 3) -->
        <p class="human-note">We'll confirm your order on WhatsApp, usually within a few hours.</p>

        <!-- UPI Option -->
        <div class="ledger-upi-section">
          <p class="upi-prompt">Prefer to pay directly?</p>
          <p class="upi-id">UPI: <span id="upi-text">ourorigin@ybl</span> <button type="button" id="copy-upi-btn" class="copy-upi-btn" aria-label="Copy UPI ID">Copy</button></p>
          <p class="upi-note human-note-small">Paid via UPI? Include your payment reference in the message and we'll confirm immediately.</p>
        </div>

        <button id="ledger-connect-btn" class="ledger-connect" aria-label="Initialize transfer via WhatsApp">INITIALIZE TRANSFER (WHATSAPP)</button>
        
        <div class="ledger-fssai">FSSAI Reg. No. {FSSAI_NUMBER}</div>
      </div>
      
      <!-- Post-checkout state (Gap 4) -->
      <div id="ledger-post-checkout" class="ledger-post-checkout hidden">
        <p class="post-title">Your order is on its way to us.</p>
        <p class="post-subtitle">We'll reply on WhatsApp.</p>
        <div class="post-copy-fallback">
          <p class="fallback-note">If WhatsApp did not open, you can copy the order details manually to paste:</p>
          <button type="button" id="copy-order-details-btn" class="copy-order-details-btn">[ COPY ORDER TEXT ]</button>
        </div>
        <p id="post-reinvite" class="post-reinvite hidden">Four other origins are still waiting.</p>
      </div>
      
      <!-- Secondary Discovery -->
      <div id="ledger-discovery" class="ledger-discovery hidden">
        <p id="discovery-text" class="discovery-text"></p>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ companionsJson, WHATSAPP_NUMBER }}>
  const companionsMap = JSON.parse(companionsJson);
  
  document.addEventListener('DOMContentLoaded', () => {
    const trigger = document.getElementById('ledger-trigger');
    const countDisplay = document.getElementById('ledger-count');
    const overlay = document.getElementById('ledger-overlay');
    const closeBtn = document.getElementById('ledger-close-btn');
    const backdrop = document.getElementById('ledger-close-backdrop');
    const itemsContainer = document.getElementById('ledger-items-container');
    const emptyState = document.getElementById('ledger-empty-state');
    const footer = document.getElementById('ledger-footer');
    const totalPriceDisplay = document.getElementById('ledger-total-price');
    const discoverySection = document.getElementById('ledger-discovery');
    const discoveryText = document.getElementById('discovery-text');
    const connectBtn = document.getElementById('ledger-connect-btn');
    const toast = document.getElementById('ledger-toast');
    const shippingForm = document.getElementById('shipping-form');
    const savedNote = document.getElementById('shipping-saved-note');
    const clearBtn = document.getElementById('clear-shipping-btn');
    const copyUpiBtn = document.getElementById('copy-upi-btn');
    
    let ledgerItems = JSON.parse(localStorage.getItem('ourorigin_cart') || '[]');
    
    // Load shipping details
    const savedShipping = localStorage.getItem('ourorigin_shipping_v1');
    if (savedShipping) {
      try {
        const data = JSON.parse(savedShipping);
        Object.keys(data).forEach(key => {
          const el = shippingForm.elements[key];
          if (el) el.value = data[key];
        });
        savedNote.classList.remove('hidden');
        clearBtn.classList.remove('hidden');
      } catch (e) {}
    }
    
    clearBtn.addEventListener('click', () => {
      shippingForm.reset();
      localStorage.removeItem('ourorigin_shipping_v1');
      savedNote.classList.add('hidden');
      clearBtn.classList.add('hidden');
    });

    copyUpiBtn.addEventListener('click', () => {
      const upiText = document.getElementById('upi-text').textContent;
      navigator.clipboard.writeText(upiText).then(() => {
        const originalText = copyUpiBtn.textContent;
        copyUpiBtn.textContent = 'Copied.';
        setTimeout(() => copyUpiBtn.textContent = originalText, 1500);
      });
    });
    
    function updateTrigger() {
      const count = ledgerItems.reduce((acc, item) => acc + item.quantity, 0);
      
      // Update the Ledger trigger
      if (count > 0) {
        countDisplay.textContent = count;
        trigger.classList.remove('hidden');
        trigger.setAttribute('aria-label', `Open Ledger — ${count} items held`);
      } else {
        trigger.classList.add('hidden');
        trigger.removeAttribute('aria-label');
      }
      
      // Update global Dossier counts and toggle depth basket visibility
      document.querySelectorAll('.dossier-count').forEach(el => {
        el.textContent = count;
      });
      
      const depthBasket = document.getElementById('depth-basket-trigger');
      if (depthBasket) {
        if (count > 0) {
          depthBasket.style.display = 'block';
        } else {
          depthBasket.style.display = 'none';
        }
      }
      
      // Update the yields triggers to act as invitations when basket is empty
      const depthYields = document.getElementById('depth-yields-trigger');
      if (depthYields) {
        depthYields.textContent = count > 0 ? '[ ALL YIELDS ]' : '[ EXPLORE YIELDS ]';
      }
      const ccYields = document.getElementById('trigger-yields');
      if (ccYields) {
        ccYields.textContent = count > 0 ? '[ ALL YIELDS ]' : '[ EXPLORE YIELDS ]';
      }
    }
    
    function saveAndRender() {
      localStorage.setItem('ourorigin_cart', JSON.stringify(ledgerItems));
      updateTrigger();
      renderItems();

      // Broadcast cart update to CommandCenter & other components
      const event = new CustomEvent('cart-updated', {
        detail: {
          items: ledgerItems,
          totalItems: ledgerItems.reduce((sum, item) => sum + item.quantity, 0),
          totalPrice: ledgerItems.reduce((sum, item) => sum + (item.price * item.quantity), 0)
        }
      });
      window.dispatchEvent(event);
    }
    
    function renderItems() {
      itemsContainer.innerHTML = '';
      
      if (ledgerItems.length === 0) {
        emptyState.classList.remove('hidden');
        footer.classList.add('hidden');
        discoverySection.classList.add('hidden');
        return;
      }
      
      emptyState.classList.add('hidden');
      footer.classList.remove('hidden');
      
      let total = 0;
      let originsInLedger = new Set();
      let summaryHtml = '';
      
      ledgerItems.forEach(item => {
        const lineTotal = item.price * item.quantity;
        total += lineTotal;
        originsInLedger.add({id: item.originId, name: item.origin});
        
        const el = document.createElement('div');
        el.className = 'ledger-item';
        el.innerHTML = `
          <div class="item-info">
            <span class="item-name">${item.name}</span>
            <div class="qty-controls">
              <button class="qty-btn dec" data-id="${item.id}" aria-label="Decrease quantity of ${item.name}">-</button>
              <span class="qty-val price-font">${item.quantity}</span>
              <button class="qty-btn inc" data-id="${item.id}" aria-label="Increase quantity of ${item.name}">+</button>
            </div>
            <span class="item-size">${item.size} · ₹${item.price}</span>
            <span class="item-line-total price-font">${item.quantity} &times; ₹${item.price} = ₹${lineTotal}</span>
          </div>
        `;
        itemsContainer.appendChild(el);
        
        summaryHtml += `
          <div class="summary-item-row">
            <span>${item.name} (${item.size}) &times; ${item.quantity}</span>
            <span>₹${lineTotal}</span>
          </div>
        `;
      });
      
      document.getElementById('ledger-subtotal-price').textContent = `₹${total}`;
      
      // Update Invoice Summary
      const summaryItems = document.getElementById('summary-items');
      const summarySub = document.getElementById('summary-subtotal');
      const summaryShip = document.getElementById('summary-shipping');
      const summaryTot = document.getElementById('summary-total');
      const shipNote = document.getElementById('shipping-prompt-note');
      
      summaryItems.innerHTML = summaryHtml;
      summarySub.textContent = `₹${total}`;
      
      const cityVal = (shippingForm.elements['city']?.value || '').toLowerCase();
      const isLocal = cityVal.includes('thiruvananthapuram') || cityVal.includes('trivandrum');
      
      let shippingCost = 0;
      let shippingText = '';
      
      if (isLocal) {
        shippingText = 'Free — local delivery';
        shipNote.classList.add('hidden');
      } else if (total < 399) {
        shippingCost = 60;
        shippingText = `₹${shippingCost}`;
        shipNote.textContent = `Add ₹${399 - total} more for free shipping.`;
        shipNote.classList.remove('hidden');
      } else {
        shippingText = 'Free';
        shipNote.classList.add('hidden');
      }
      
      summaryShip.textContent = shippingText;
      summaryTot.textContent = `₹${total + shippingCost}`;
      
      // We attach shipping cost to the form element so checkout logic can read it
      shippingForm.setAttribute('data-shipping-cost', shippingCost.toString());
      shippingForm.setAttribute('data-shipping-text', shippingText);
      shippingForm.setAttribute('data-total', (total + shippingCost).toString());
      
      // Wire up qty buttons
      document.querySelectorAll('.qty-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const id = e.target.getAttribute('data-id');
          const isInc = e.target.classList.contains('inc');
          
          const index = ledgerItems.findIndex(i => i.id === id);
          if (index !== -1) {
            if (isInc) {
              ledgerItems[index].quantity++;
            } else {
              ledgerItems[index].quantity--;
              if (ledgerItems[index].quantity <= 0) {
                ledgerItems.splice(index, 1);
              }
            }
            saveAndRender();
          }
        });
      });
      
      // Handle Secondary Discovery
      let discoveryHtmlChunks = [];
      const uniqueOriginsMap = new Map();
      Array.from(originsInLedger).forEach(o => uniqueOriginsMap.set(o.id, o.name));
      
      uniqueOriginsMap.forEach((originName, originId) => {
        const companions = companionsMap[originId];
        if (companions && companions.length > 0) {
          // Filter out companions that are already in the ledger
          const availableCompanions = companions.filter(c => !ledgerItems.some(i => i.productId === c.id));
          
          if (availableCompanions.length > 0) {
            const linksHtml = availableCompanions.map(c => 
              `<a href="#" class="discovery-link" data-origin="${originId}" data-product="${c.id}" aria-label="Browse more yields from ${originName}">${c.name}</a>`
            ).join(', ');
            
            discoveryHtmlChunks.push(`Also from ${originName}: ${linksHtml}`);
          }
        }
      });
      
      if (discoveryHtmlChunks.length > 0) {
        discoveryText.innerHTML = discoveryHtmlChunks.join('<br>');
        discoverySection.classList.remove('hidden');
        
        // Wire up discovery links
        document.querySelectorAll('.discovery-link').forEach(link => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const originId = e.target.getAttribute('data-origin');
            closeLedger();
            window.dispatchEvent(new CustomEvent('open-carousel', { detail: { originId: originId, excludeAnchor: true } }));
          });
        });
      } else {
        discoverySection.classList.add('hidden');
      }
    }
    
    // Re-render when shipping city changes to update shipping logic instantly
    const cityInput = document.getElementById('ship-city');
    if (cityInput) {
      cityInput.addEventListener('input', renderItems);
    }
    
    // Connection logic
    connectBtn.addEventListener('click', (e) => {
      e.preventDefault();
      
      if (ledgerItems.length === 0) return;
      
      // Native HTML5 Validation
      if (!shippingForm.checkValidity()) {
        shippingForm.reportValidity();
        return;
      }
      
      const formData = new FormData(shippingForm);
      const data = Object.fromEntries(formData.entries());
      localStorage.setItem('ourorigin_shipping_v1', JSON.stringify(data));
      savedNote.classList.remove('hidden');
      clearBtn.classList.remove('hidden');

      const shippingCost = parseInt(shippingForm.getAttribute('data-shipping-cost') || '0', 10);
      const shippingText = shippingForm.getAttribute('data-shipping-text') || 'Free';
      const orderTotal = shippingForm.getAttribute('data-total') || '0';

      let currentOrderMessage = '';

      if (ledgerItems.length === 1 && ledgerItems[0].quantity === 1) {
        const item = ledgerItems[0];
        currentOrderMessage = `Hi — I'd like to order ${item.name} (${item.size}) from OurOrigin.\nTotal: ₹${orderTotal}. Shipping: ${shippingText}.\n\nName: ${data.name}\nAddress: ${data.house}, ${data.street}, ${data.city}, ${data.state} – ${data.pin}\nPhone: ${data.phone}\n\nFound you at ourorigin.in.`;
      } else {
        currentOrderMessage = `Hi — I'd like to order the following from OurOrigin.\n\n`;
        ledgerItems.forEach(item => {
          currentOrderMessage += `– ${item.name} (${item.size}) × ${item.quantity} · ₹${item.price * item.quantity}\n`;
        });
        currentOrderMessage += `\nTotal: ₹${orderTotal}\nShipping: ${shippingText}\n\nName: ${data.name}\nAddress: ${data.house}, ${data.street}, ${data.city}, ${data.state} – ${data.pin}\nPhone: ${data.phone}\n\nFound you at ourorigin.in.`;
      }
      
      const encodedMessage = encodeURIComponent(currentOrderMessage);
      window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${encodedMessage}`, '_blank');
      
      // Post-checkout state (Gap 4)
      itemsContainer.classList.add('hidden');
      footer.classList.add('hidden');
      discoverySection.classList.add('hidden');
      const postCheckout = document.getElementById('ledger-post-checkout');
      postCheckout.classList.remove('hidden');
      
      setTimeout(() => {
        document.getElementById('post-reinvite').classList.remove('hidden');
      }, 1500);

      // Wire up copy button click
      const copyOrderBtn = document.getElementById('copy-order-details-btn');
      if (copyOrderBtn) {
        copyOrderBtn.addEventListener('click', () => {
          navigator.clipboard.writeText(currentOrderMessage).then(() => {
            const originalText = copyOrderBtn.textContent;
            copyOrderBtn.textContent = '[ COPIED TO CLIPBOARD ]';
            setTimeout(() => {
              copyOrderBtn.textContent = originalText;
            }, 1500);
          });
        });
      }
      
      // Clear cart
      localStorage.removeItem('ourorigin_cart');
      ledgerItems = [];
      updateTrigger();
      
      // Close after 15s to give the user enough time to copy order details manually if needed
      setTimeout(() => {
        closeLedger();
        // Reset DOM for future opens
        setTimeout(() => {
          postCheckout.classList.add('hidden');
          itemsContainer.classList.remove('hidden');
          document.getElementById('post-reinvite').classList.add('hidden');
        }, 500);
      }, 15000);
    });
    
    // Listen to add events
    window.addEventListener('add-to-ledger', (e) => {
      const item = e.detail;
      const existingItem = ledgerItems.find(i => i.id === item.id);
      
      if (existingItem) {
        existingItem.quantity += item.quantity;
      } else {
        ledgerItems.push(item);
      }
      
      saveAndRender();

      // Show toast
      toast.classList.remove('hidden');
      toast.classList.add('visible');
      setTimeout(() => {
        toast.classList.remove('visible');
        setTimeout(() => toast.classList.add('hidden'), 300);
      }, 2500);

      // Pulse trigger
      trigger.classList.add('pulse-anim');
      setTimeout(() => {
        trigger.classList.remove('pulse-anim');
      }, 500);
    });
    
    const openLedger = () => {
      renderItems();
      overlay.classList.remove('hidden');
    };
    
    const closeLedger = () => {
      overlay.classList.add('hidden');
    };
    
    trigger.addEventListener('click', openLedger);
    closeBtn.addEventListener('click', closeLedger);
    backdrop.addEventListener('click', closeLedger);
    
    const triggerDossier = document.getElementById('trigger-dossier');
    if (triggerDossier) {
      triggerDossier.addEventListener('click', openLedger);
    }
    
    // Initial render
    updateTrigger();
  });
</script>

<style>
  .ledger-toast {
    position: fixed;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(-10px);
    z-index: 10000;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    padding: 0.6rem 1.2rem;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
    border: 1px solid rgba(245, 237, 216, 0.4);
    border-radius: 40px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .ledger-toast.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @keyframes pulse {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(245, 237, 216, 0.4); }
    70% { transform: scale(1.05); box-shadow: 0 0 0 10px rgba(245, 237, 216, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(245, 237, 216, 0); }
  }

  .pulse-anim {
    animation: pulse 0.5s ease-out;
  }

  .ledger-trigger {
    position: fixed;
    bottom: 2rem;
    left: 2rem;
    z-index: 900;
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    color: var(--color-warm-cream);
    cursor: pointer;
    background: transparent;
    border: none;
    padding: 0;
    transition: opacity 0.3s ease;
  }
  .ledger-trigger.hidden {
    opacity: 0;
    pointer-events: none;
  }
  
  .ledger-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 8500;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    pointer-events: auto;
    opacity: 1;
    transition: opacity 0.4s ease;
  }
  .ledger-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }
  
  .ledger-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(12, 21, 9, 0.6);
    backdrop-filter: blur(4px);
    transition: opacity 0.4s ease;
  }
  
  .ledger-panel {
    position: relative;
    width: 100%;
    height: 75dvh;
    background: var(--color-forest-deep);
    border-top: 1px solid rgba(244, 241, 235, 0.2);
    border-radius: 20px 20px 0 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    transform: translateY(0);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    padding-bottom: env(safe-area-inset-bottom);
  }
  .ledger-overlay.hidden .ledger-panel {
    transform: translateY(100%);
  }
  
  .ledger-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 5vw 1.5rem;
    border-bottom: 1px solid rgba(244, 241, 235, 0.1);
  }
  .ledger-title {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    margin: 0;
  }
  .ledger-close {
    background: none;
    border: none;
    color: var(--color-warm-cream);
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  
  .ledger-content {
    flex-grow: 1;
    overflow-y: auto;
    padding: 2rem 5vw;
    display: flex;
    flex-direction: column;
  }
  
  .ledger-empty {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    color: rgba(244, 241, 235, 0.6);
    text-align: center;
    margin-top: 2rem;
  }
  
  .ledger-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(244, 241, 235, 0.1);
  }
  .item-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .item-name {
    font-family: 'Cinzel', serif;
