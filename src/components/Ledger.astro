---
import { getCollection } from 'astro:content';

const products = await getCollection('products');

// Build a map of originId -> companion product names
const companionProductsMap = {};
products.forEach(product => {
  if (!product.data.isAnchorProduct) {
    const originId = typeof product.data.originSlug === 'object' ? product.data.originSlug.id : product.data.originSlug;
    if (!companionProductsMap[originId]) {
      companionProductsMap[originId] = [];
    }
    companionProductsMap[originId].push({
      id: product.id,
      name: product.data.name
    });
  }
});

const companionsJson = JSON.stringify(companionProductsMap);
---

<!-- Global Toast -->
<div id="ledger-toast" class="ledger-toast hidden" role="status" aria-live="polite" aria-atomic="true">
  Added to your Ledger.
</div>

<!-- Persistent Trigger -->
<div id="ledger-trigger" class="ledger-trigger hidden" aria-live="polite" role="button" tabindex="0">
  <span id="ledger-count"></span> held
</div>

<!-- Slide-up Panel -->
<div id="ledger-overlay" class="ledger-overlay hidden">
  <div class="ledger-backdrop" id="ledger-close-backdrop"></div>
  <div class="ledger-panel" role="complementary" aria-label="Your Ledger">
    <div class="ledger-header">
      <h2 class="ledger-title">Your Ledger</h2>
      <button id="ledger-close-btn" class="ledger-close" aria-label="Close Ledger">Close</button>
    </div>
    
    <div class="ledger-content">
      <div id="ledger-items-container" class="ledger-items">
        <!-- JS will populate items here -->
      </div>
      
      <div id="ledger-empty-state" class="ledger-empty hidden">
        The ledger is empty.<br>Explore the origins.
      </div>
      
      <div id="ledger-footer" class="ledger-footer hidden">
        <div class="ledger-total">
          <span>Total</span>
          <span id="ledger-total-price" class="price-font">₹0</span>
        </div>
        
        <!-- Shipping Form -->
        <form id="shipping-form" class="shipping-form">
          <input type="text" id="ship-name" name="name" placeholder="Full name" required />
          <input type="text" id="ship-house" name="house" placeholder="House/Flat number" required />
          <input type="text" id="ship-street" name="street" placeholder="Street/Locality" required />
          <div class="form-row">
            <input type="text" id="ship-city" name="city" placeholder="City" required />
            <input type="text" id="ship-state" name="state" placeholder="State" required />
          </div>
          <div class="form-row">
            <input type="text" id="ship-pin" name="pin" placeholder="PIN Code" required />
            <input type="tel" id="ship-phone" name="phone" placeholder="Phone (for delivery updates)" required />
          </div>
          <div class="shipping-actions">
            <p id="shipping-saved-note" class="shipping-saved-note hidden">Saved from your last order. Tap any field to change.</p>
            <button type="button" id="clear-shipping-btn" class="clear-shipping-btn hidden">Clear saved details</button>
          </div>
        </form>

        <!-- UPI Option -->
        <div class="ledger-upi-section">
          <p class="upi-prompt">Prefer to pay directly?</p>
          <p class="upi-id">UPI: <span id="upi-text">ourorigin@ybl</span> <button type="button" id="copy-upi-btn" class="copy-upi-btn" aria-label="Copy UPI ID">Copy</button></p>
          <p class="upi-note">After payment, send your order details via WhatsApp.</p>
        </div>

        <button id="ledger-connect-btn" class="ledger-connect" aria-label="Continue to checkout via WhatsApp">Connect via WhatsApp</button>
      </div>
      
      <!-- Secondary Discovery -->
      <div id="ledger-discovery" class="ledger-discovery hidden">
        <p id="discovery-text" class="discovery-text"></p>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ companionsJson }}>
  const companionsMap = JSON.parse(companionsJson);
  
  document.addEventListener('DOMContentLoaded', () => {
    const trigger = document.getElementById('ledger-trigger');
    const countDisplay = document.getElementById('ledger-count');
    const overlay = document.getElementById('ledger-overlay');
    const closeBtn = document.getElementById('ledger-close-btn');
    const backdrop = document.getElementById('ledger-close-backdrop');
    const itemsContainer = document.getElementById('ledger-items-container');
    const emptyState = document.getElementById('ledger-empty-state');
    const footer = document.getElementById('ledger-footer');
    const totalPriceDisplay = document.getElementById('ledger-total-price');
    const discoverySection = document.getElementById('ledger-discovery');
    const discoveryText = document.getElementById('discovery-text');
    const connectBtn = document.getElementById('ledger-connect-btn');
    const toast = document.getElementById('ledger-toast');
    const shippingForm = document.getElementById('shipping-form');
    const savedNote = document.getElementById('shipping-saved-note');
    const clearBtn = document.getElementById('clear-shipping-btn');
    const copyUpiBtn = document.getElementById('copy-upi-btn');
    
    let ledgerItems = JSON.parse(localStorage.getItem('ourorigin_ledger') || '[]');
    
    // Load shipping details
    const savedShipping = localStorage.getItem('ourorigin_shipping_v1');
    if (savedShipping) {
      try {
        const data = JSON.parse(savedShipping);
        Object.keys(data).forEach(key => {
          const el = shippingForm.elements[key];
          if (el) el.value = data[key];
        });
        savedNote.classList.remove('hidden');
        clearBtn.classList.remove('hidden');
      } catch (e) {}
    }
    
    clearBtn.addEventListener('click', () => {
      shippingForm.reset();
      localStorage.removeItem('ourorigin_shipping_v1');
      savedNote.classList.add('hidden');
      clearBtn.classList.add('hidden');
    });

    copyUpiBtn.addEventListener('click', () => {
      const upiText = document.getElementById('upi-text').textContent;
      navigator.clipboard.writeText(upiText).then(() => {
        const originalText = copyUpiBtn.textContent;
        copyUpiBtn.textContent = 'Copied.';
        setTimeout(() => copyUpiBtn.textContent = originalText, 1500);
      });
    });
    
    function updateTrigger() {
      const count = ledgerItems.reduce((acc, item) => acc + item.quantity, 0);
      if (count > 0) {
        countDisplay.textContent = count;
        trigger.classList.remove('hidden');
        trigger.setAttribute('aria-label', `Open Ledger — ${count} items held`);
      } else {
        trigger.classList.add('hidden');
        trigger.removeAttribute('aria-label');
      }
    }
    
    function saveAndRender() {
      localStorage.setItem('ourorigin_ledger', JSON.stringify(ledgerItems));
      updateTrigger();
      renderItems();
    }
    
    function renderItems() {
      itemsContainer.innerHTML = '';
      
      if (ledgerItems.length === 0) {
        emptyState.classList.remove('hidden');
        footer.classList.add('hidden');
        discoverySection.classList.add('hidden');
        return;
      }
      
      emptyState.classList.add('hidden');
      footer.classList.remove('hidden');
      
      let total = 0;
      let originsInLedger = new Set();
      
      ledgerItems.forEach(item => {
        total += item.price * item.quantity;
        originsInLedger.add({id: item.originId, name: item.origin});
        
        const el = document.createElement('div');
        el.className = 'ledger-item';
        el.innerHTML = `
          <div class="item-info">
            <span class="item-name">${item.name}</span>
            <span class="item-size">${item.size}</span>
          </div>
          <div class="item-controls">
            <span class="price-font">₹${item.price}</span>
            <div class="qty-controls">
              <button class="qty-btn dec" data-id="${item.id}" aria-label="Decrease quantity of ${item.name}">-</button>
              <span class="qty-val price-font">${item.quantity}</span>
              <button class="qty-btn inc" data-id="${item.id}" aria-label="Increase quantity of ${item.name}">+</button>
            </div>
          </div>
        `;
        itemsContainer.appendChild(el);
      });
      
      totalPriceDisplay.textContent = `₹${total}`;
      
      // Wire up qty buttons
      document.querySelectorAll('.qty-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const id = e.target.getAttribute('data-id');
          const isInc = e.target.classList.contains('inc');
          
          const index = ledgerItems.findIndex(i => i.id === id);
          if (index !== -1) {
            if (isInc) {
              ledgerItems[index].quantity++;
            } else {
              ledgerItems[index].quantity--;
              if (ledgerItems[index].quantity <= 0) {
                ledgerItems.splice(index, 1);
              }
            }
            saveAndRender();
          }
        });
      });
      
      // Handle Secondary Discovery
      let discoveryHtmlChunks = [];
      const uniqueOriginsMap = new Map();
      Array.from(originsInLedger).forEach(o => uniqueOriginsMap.set(o.id, o.name));
      
      uniqueOriginsMap.forEach((originName, originId) => {
        const companions = companionsMap[originId];
        if (companions && companions.length > 0) {
          // Filter out companions that are already in the ledger
          const availableCompanions = companions.filter(c => !ledgerItems.some(i => i.productId === c.id));
          
          if (availableCompanions.length > 0) {
            const linksHtml = availableCompanions.map(c => 
              `<a href="#" class="discovery-link" data-origin="${originId}" data-product="${c.id}" aria-label="Browse more yields from ${originName}">${c.name}</a>`
            ).join(', ');
            
            discoveryHtmlChunks.push(`Also from ${originName}: ${linksHtml}`);
          }
        }
      });
      
      if (discoveryHtmlChunks.length > 0) {
        discoveryText.innerHTML = discoveryHtmlChunks.join('<br>');
        discoverySection.classList.remove('hidden');
        
        // Wire up discovery links
        document.querySelectorAll('.discovery-link').forEach(link => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const originId = e.target.getAttribute('data-origin');
            closeLedger();
            window.dispatchEvent(new CustomEvent('open-carousel', { detail: { originId: originId, excludeAnchor: true } }));
          });
        });
      } else {
        discoverySection.classList.add('hidden');
      }
    }
    
    // Connection logic
    connectBtn.addEventListener('click', (e) => {
      if (!shippingForm.checkValidity()) {
        shippingForm.reportValidity();
        return;
      }
      
      // Save shipping details
      const formData = new FormData(shippingForm);
      const data = Object.fromEntries(formData.entries());
      localStorage.setItem('ourorigin_shipping_v1', JSON.stringify(data));
      savedNote.classList.remove('hidden');
      clearBtn.classList.remove('hidden');

      let message = `Hi — I'd like to order:\n`;
      ledgerItems.forEach(item => {
        message += `- ${item.quantity}x ${item.name} (${item.size})\n`;
      });
      message += `\nShipping Details:\n${data.name}\n${data.house}, ${data.street}\n${data.city}, ${data.state} ${data.pin}\n${data.phone}\n\nI am ready to pay via UPI upon confirmation.`;
      
      const encodedMessage = encodeURIComponent(message);
      const phone = '919645555668'; // The contact number
      window.open(`https://wa.me/${phone}?text=${encodedMessage}`, '_blank');
    });
    
    // Listen to add events
    window.addEventListener('add-to-ledger', (e) => {
      const item = e.detail;
      const existingItem = ledgerItems.find(i => i.id === item.id);
      
      if (existingItem) {
        existingItem.quantity += item.quantity;
      } else {
        ledgerItems.push(item);
      }
      
      saveAndRender();

      // Show toast
      toast.classList.remove('hidden');
      toast.classList.add('visible');
      setTimeout(() => {
        toast.classList.remove('visible');
        setTimeout(() => toast.classList.add('hidden'), 300);
      }, 2500);

      // Pulse trigger
      trigger.classList.add('pulse-anim');
      setTimeout(() => {
        trigger.classList.remove('pulse-anim');
      }, 500);
    });
    
    const openLedger = () => {
      renderItems();
      overlay.classList.remove('hidden');
    };
    
    const closeLedger = () => {
      overlay.classList.add('hidden');
    };
    
    trigger.addEventListener('click', openLedger);
    closeBtn.addEventListener('click', closeLedger);
    backdrop.addEventListener('click', closeLedger);
    
    // Initial render
    updateTrigger();
  });
</script>

<style>
  .ledger-toast {
    position: fixed;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(-10px);
    z-index: 10000;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    padding: 0.6rem 1.2rem;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
    border: 1px solid rgba(245, 237, 216, 0.4);
    border-radius: 40px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .ledger-toast.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @keyframes pulse {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(245, 237, 216, 0.4); }
    70% { transform: scale(1.05); box-shadow: 0 0 0 10px rgba(245, 237, 216, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(245, 237, 216, 0); }
  }

  .pulse-anim {
    animation: pulse 0.5s ease-out;
  }

  .ledger-trigger {
    position: fixed;
    bottom: 2rem;
    left: 2rem;
    z-index: 900;
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    color: var(--color-warm-cream);
    cursor: pointer;
    background: transparent;
    border: none;
    padding: 0;
    transition: opacity 0.3s ease;
  }
  .ledger-trigger.hidden {
    opacity: 0;
    pointer-events: none;
  }
  
  .ledger-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 1100;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    pointer-events: auto;
    opacity: 1;
    transition: opacity 0.4s ease;
  }
  .ledger-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }
  
  .ledger-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(12, 21, 9, 0.6);
    backdrop-filter: blur(4px);
    transition: opacity 0.4s ease;
