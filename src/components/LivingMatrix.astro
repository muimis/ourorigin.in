---
import { getCollection } from 'astro:content';
import OriginMark from './OriginMark.astro';
import TopographicMap from './TopographicMap.astro';

const origins = await getCollection('origins');

// Order by elevation (highest to lowest)
const orderedSlugs = ['nilgiris', 'idukki', 'wayanad', 'malabar-coast', 'thiruvananthapuram'];
const orderedOrigins = orderedSlugs.map(slug => origins.find(o => o.data.slug === slug)).filter(Boolean);

// Helper to get highest elevation from string like "100m - 1500m"
function getHighestElevation(elevationString) {
  if (!elevationString) return '';
  const cleanStr = elevationString.replace(/,/g, '');
  const matches = cleanStr.match(/\d+/g);
  if (matches) {
    return Math.max(...matches.map(Number));
  }
  return cleanStr.replace(/[^0-9]/g, '');
}

const matrixCopy = {
  'nilgiris': { fragment: 'This high, India has frost.', subLine: 'Western Ghats · Forest Polyculture', cta: 'Enter this origin →' },
  'idukki': { fragment: 'Named for what grows here.', subLine: 'Western Ghats · Shade-Grown Wild Harvest', cta: 'Enter this origin →' },
  'wayanad': { fragment: 'The vine doesn\'t stand. It climbs.', subLine: 'Western Ghats · Traditional Agrarian', cta: 'Enter this origin →' },
  'thiruvananthapuram': { fragment: 'The root is dug up, not picked.', subLine: 'Western Ghats · Lowland Homesteading', cta: 'Enter this origin →' },
  'malabar-coast': { fragment: 'This coastline named the trade routes.', subLine: 'Western Ghats · Smallholder Hand Harvest', cta: 'This origin is still being documented.' }
};

const products = await getCollection('products');

const anchorMap: Record<string, string> = {};
orderedOrigins.forEach(origin => {
  if (origin.data.slug === 'malabar-coast') {
    anchorMap[origin.data.slug] = '#';
  } else {
    const anchorProduct = products.find(p => {
      const pOriginId = typeof p.data.originSlug === 'object' ? p.data.originSlug.id : p.data.originSlug;
      return pOriginId === origin.id && p.data.isAnchorProduct;
    });
    const firstProduct = anchorProduct || products.find(p => {
      const pOriginId = typeof p.data.originSlug === 'object' ? p.data.originSlug.id : p.data.originSlug;
      return pOriginId === origin.id;
    });
    anchorMap[origin.data.slug] = firstProduct ? `/origins/${origin.id}/${firstProduct.id}` : '#';
  }
});
const originMarks = {
  'wayanad': 'gold',
  'idukki': 'ruby',
  'thiruvananthapuram': 'copper',
  'nilgiris': 'forest',
  'kollam': 'silver',
  'malabar-coast': 'primary'
};
---

<div class="living-matrix-container" id="living-matrix">
  <!-- Nav removed per request -->

  <div class="matrix-bands">
    {orderedOrigins.map((origin, index) => {
      const linkHref = anchorMap[origin.data.slug];
      const copy = matrixCopy[origin.data.slug];
      const clipPaths = [
        "", // Band 0 (Nilgiris) has no top curve, so no clip-path needed
        "polygon(0.0% 24.0px, 4.2% 23.6px, 7.9% 22.0px, 11.2% 19.6px, 14.2% 17.2px, 16.9% 14.4px, 19.4% 12.0px, 21.9% 9.6px, 24.5% 8.0px, 27.1% 7.6px, 30.0% 8.0px, 32.9% 9.6px, 35.5% 12.4px, 38.1% 15.6px, 40.6% 19.2px, 43.1% 22.4px, 45.8% 25.6px, 48.8% 28.0px, 52.1% 29.2px, 55.8% 29.6px, 60.0% 28.0px, 64.4% 25.2px, 68.5% 22.4px, 72.4% 19.6px, 76.2% 16.8px, 80.0% 14.4px, 83.8% 12.8px, 87.6% 11.6px, 91.5% 12.0px, 95.6% 13.2px, 100.0% 16.0px, 100% 100%, 0% 100%)",
        "polygon(0.0% 16.0px, 2.9% 16.4px, 5.5% 17.6px, 7.9% 19.2px, 10.2% 21.2px, 12.5% 23.6px, 14.8% 25.6px, 17.1% 27.2px, 19.5% 28.4px, 22.1% 28.8px, 25.0% 28.0px, 27.9% 26.4px, 30.5% 24.4px, 33.1% 22.0px, 35.6% 19.6px, 38.1% 17.2px, 40.8% 14.8px, 43.8% 12.8px, 47.1% 11.6px, 50.8% 11.2px, 55.0% 12.0px, 59.4% 13.6px, 63.5% 16.0px, 67.6% 18.8px, 71.6% 21.6px, 75.6% 24.0px, 79.8% 26.0px, 84.3% 27.6px, 89.1% 27.6px, 94.3% 26.8px, 100.0% 24.0px, 100% 100%, 0% 100%)",
        "polygon(0.0% 28.0px, 5.6% 27.6px, 10.4% 26.0px, 14.6% 23.6px, 18.4% 21.2px, 21.9% 18.4px, 25.2% 16.0px, 28.5% 13.6px, 32.0% 12.0px, 35.8% 11.6px, 40.0% 12.0px, 44.2% 13.6px, 48.0% 15.6px, 51.3% 18.0px, 54.5% 20.4px, 57.5% 22.4px, 60.5% 24.4px, 63.7% 25.6px, 67.0% 26.4px, 70.8% 25.6px, 75.0% 24.0px, 79.2% 21.6px, 82.9% 19.2px, 86.1% 17.2px, 88.8% 15.6px, 91.3% 14.4px, 93.4% 14.0px, 95.2% 14.0px, 96.9% 15.2px, 98.5% 16.8px, 100.0% 20.0px, 100% 100%, 0% 100%)",
        "polygon(0.0% 12.0px, 4.2% 12.4px, 8.0% 13.6px, 11.3% 15.2px, 14.5% 17.2px, 17.5% 19.6px, 20.5% 21.6px, 23.7% 23.2px, 27.0% 24.4px, 30.8% 24.8px, 35.0% 24.0px, 39.4% 22.4px, 43.5% 20.4px, 47.4% 18.0px, 51.2% 15.6px, 55.0% 13.6px, 58.8% 11.6px, 62.6% 10.4px, 66.5% 9.6px, 70.6% 10.4px, 75.0% 12.0px, 79.2% 14.4px, 82.9% 17.2px, 86.1% 19.6px, 88.8% 21.6px, 91.3% 23.2px, 93.4% 24.0px, 95.2% 23.6px, 96.9% 22.4px, 98.5% 20.0px, 100.0% 16.0px, 100% 100%, 0% 100%)"
      ];
      const clipPath = clipPaths[index];
      let bandStyle = `--index: ${index};`;
      if (clipPath) {
        bandStyle += `clip-path: ${clipPath}; -webkit-clip-path: ${clipPath};`;
      }
      
      return (
        <div 
          data-href={linkHref} 
          class={`matrix-band ${origin.data.slug === 'malabar-coast' ? 'empty-state' : ''} ${index === 0 ? 'expanded' : ''}`} 
          style={bandStyle}
          data-index={index}
          data-slug={origin.data.slug}
          tabindex="0"
          role="button"
          aria-expanded="false"
          aria-label={`${origin.data.name}, ${getHighestElevation(origin.data.elevation)}M. Tap to expand.`}
        >
          <TopographicMap index={index} />

          <div class="plate-origin-mark" style="opacity: 0;" data-target-opacity={origin.data.slug === 'malabar-coast' ? '0.3' : '0.9'}>
            <OriginMark variant="gold" size={24} animate={false} />
          </div>
          <div class="tap-pulse-indicator"></div>
          
          <!-- Mobile Hold Indicator -->
          <div class="mobile-hold-indicator">
            <svg viewBox="0 0 100 100" class="hold-svg">
              <circle cx="50" cy="50" r="4" class="hold-dot" />
              <circle cx="50" cy="50" r="15" class="hold-circle" />
            </svg>
          </div>

          <div class="band-content">
            <div class="title-group">
              <h2 class="origin-name">
                {origin.data.name.toUpperCase()}
                <sup class="elevation-sup">{getHighestElevation(origin.data.elevation)}M</sup>
              </h2>
            </div>
            <div class="band-reveal">
              <p class="origin-meta">{copy.fragment}</p>
              <p class="origin-subline">{copy.subLine}</p>
              {origin.data.slug !== 'malabar-coast' && <p class="band-partner-note">The people who grow this are partners, not suppliers.</p>}
              {origin.data.slug === 'wayanad' && <p class="commerce-signal">From ₹109</p>}
              <div class="origin-live-telemetry"></div>
              
              {origin.data.slug === 'malabar-coast' ? (
                <p class="origin-action malabar-documented">{copy.cta}</p>
              ) : (
                <>
                  <a href={linkHref} class="origin-action" aria-label={`Enter ${origin.data.name} — descend through ${origin.data.method || 'the origin'}`}>{copy.cta}</a>
                  <p class="carousel-trigger" data-origin={origin.id} aria-label={`Browse all yields from ${origin.data.name}`} role="button" tabindex="0">Browse all yields</p>
                </>
              )}
            </div>
          </div>
        </div>
      )
    })}
</div>

<script>
  import gsap from 'gsap';

  class LivingMatrixOrchestrator {
    constructor() {
      this.init();
    }

    init() {
      const bands = document.querySelectorAll('.matrix-band');
      const originNames = document.querySelectorAll('.title-group');
      
      // Load instantly instead of a 2 second fade to remove green screen delay
      gsap.set(bands, { opacity: 1 });
      gsap.set(originNames, { y: 0, opacity: 1 });
    }
  }

  // Add an event listener to reveal the marks when the launch animation completes
  window.addEventListener('origin-marks-arrived', () => {
    const marks = document.querySelectorAll('.plate-origin-mark');
    marks.forEach((mark) => {
      const targetOp = mark.getAttribute('data-target-opacity') || '0.9';
      // All 5 plates fade in with a live golden fade-in simultaneously
      gsap.to(mark, { opacity: parseFloat(targetOp), duration: 0.8, ease: 'power2.out' });
    });
  });

  document.addEventListener('DOMContentLoaded', () => {
    const hasVisited = sessionStorage.getItem('ourorigin_visited');
    if (hasVisited === 'true') {
      new LivingMatrixOrchestrator();
    } else {
      window.addEventListener('launch-sequence-complete', () => {
        new LivingMatrixOrchestrator();
      });
    }
    
    document.querySelectorAll('.carousel-trigger').forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const originId = trigger.getAttribute('data-origin');
        window.dispatchEvent(new CustomEvent('open-carousel', { detail: { originId } }));
      });
    });

    document.querySelectorAll('.matrix-band').forEach(band => {
      band.addEventListener('click', (e) => {
        if (e.target.closest('.carousel-trigger')) return;
        if (e.target.closest('.origin-action')) return;

        const hasHover = window.matchMedia('(hover: hover)').matches;
        
        if (!hasHover) {
          if (band.classList.contains('empty-state')) return;
          e.preventDefault();
          const bandsContainer = document.querySelector('.matrix-bands');
          
          if (!band.classList.contains('expanded')) {
            // Pulse animation centered on tap coordinates
            const pulse = band.querySelector('.tap-pulse-indicator');
            if (pulse) {
              const rect = band.getBoundingClientRect();
              const clientX = e.touches ? e.touches[0].clientX : e.clientX;
              const clientY = e.touches ? e.touches[0].clientY : e.clientY;
              const x = clientX - rect.left;
              const y = clientY - rect.top;
              pulse.style.left = `${x}px`;
              pulse.style.top = `${y}px`;
              
              pulse.classList.add('pulse-active');
              setTimeout(() => {
                pulse.classList.remove('pulse-active');
              }, 300);
            }

            document.querySelectorAll('.matrix-band.expanded').forEach(b => {
              b.classList.remove('expanded');
              b.setAttribute('aria-expanded', 'false');
            });
            bandsContainer.classList.add('has-expanded');
            
            band.classList.add('expanded');
            band.setAttribute('aria-expanded', 'true');
          } else {
            band.classList.remove('expanded');
            band.setAttribute('aria-expanded', 'false');
          }
        } else {
          const href = band.getAttribute('data-href');
          if (href && href !== '#') {
            window.location.href = href;
          }
        }
      });
    });
  });
</script>

<style>
  .living-matrix-container {
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background-color: var(--color-forest-deep);
    position: relative;
    overflow: hidden;
    padding: 3.5vh 0 6.5vh 0; 
    box-sizing: border-box;
  }
  
  .matrix-bands {
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
  }
  
  @keyframes subtleBreathe {
    0% { background-color: rgba(245, 237, 216, 0); transform: translateY(0); }
    50% { background-color: rgba(245, 237, 216, 0.015); transform: translateY(-4px); }
    100% { background-color: rgba(245, 237, 216, 0); transform: translateY(0); }
  }

  .matrix-band {
    position: relative;
    width: 100%;
    background-color: rgba(12, 21, 9, 0.4);
    flex: 1; /* evenly distributes space => roughly 20dvh */
    transition: flex 700ms cubic-bezier(0.22, 1, 0.36, 1), background-color var(--duration-standard) ease, color var(--duration-standard) ease, opacity var(--duration-standard) ease, transform var(--duration-standard) ease;
    animation: subtleBreathe 10s ease-in-out infinite;
    animation-delay: calc(var(--index, 0) * -2s);
    color: var(--color-warm-cream);
    text-decoration: none;
    opacity: 0;
    /* Reversing Z-index so bottom plates overlap top plates, allowing negative margin overlap to work */
    z-index: var(--index);
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    padding-bottom: 0;
    cursor: pointer;
  }
  
  .matrix-band:not(:first-child) {
    margin-top: -60px; /* Pulls the plate up to overlap the one above it */
    padding-top: 60px; /* Offsets content so it remains visually centered */
  }
  
  .plate-origin-mark {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    right: 1rem;
    z-index: 5;
    pointer-events: none;
  }
  
  @media (min-width: 768px) {
    .plate-origin-mark {
      top: 2rem;
      right: 2rem;
      transform: none;
    }
  }
  
  @media (min-width: 768px) {
    .matrix-band {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  .matrix-band:last-child {
    border-bottom: none;
  }
  
  .matrix-band.expanded {
    flex: 4 !important; /* 45dvh out of 90dvh available (100dvh - 10dvh padding) */
    background-color: #121d0e;
    color: var(--color-pure-white);
    outline: none;
    animation-play-state: paused;
  }
  
  @media (hover: hover) {
    .matrix-band:not(.empty-state):hover, .matrix-band:not(.empty-state):focus-visible {
      flex: 4 !important;
      background-color: #121d0e;
      color: var(--color-pure-white);
      outline: none;
      animation-play-state: paused;
    }
  }
  
  .band-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    height: 100%;
    width: 100%;
    overflow: hidden;
    padding: 2vh 0;
    box-sizing: border-box;
  }
  
  .title-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    transform: translateY(10px);
    opacity: 0;
  }
  
  .origin-name {
    font-family: var(--font-institutional);
    font-size: clamp(12px, 3.8vw, var(--text-size-stratum-title));
    line-height: 1.1;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
    font-weight: 400;
    text-align: center;
    word-break: break-word;
    transition: transform 0.6s var(--ease-settle), opacity 0.6s ease;
    transform-origin: center;
  }
  
  @media (max-width: 768px) {
    .origin-name {
      font-size: 16px !important; /* Bumped to 16px to be definitively readable and larger than clamp */
    }
    .matrix-bands.has-expanded .matrix-band:not(.expanded) .origin-name {
      transform: none !important;
      opacity: 0.5;
    }
    .matrix-bands:hover .matrix-band:not(:hover) .origin-name {
      transform: none !important;
    }
  }
  
  .matrix-bands.has-expanded .matrix-band:not(.expanded) .origin-name {
    transform: scale(0.65);
    opacity: 0.4;
  }
  
  .matrix-bands:hover .matrix-band:not(:hover) .origin-name {
    @media (hover: hover) {
      transform: scale(0.65);
      opacity: 0.4;
    }
  }
  
  .elevation-sup {
    vertical-align: super;
    font-size: 0.35em;
    margin-left: 0.2rem;
    font-family: var(--font-evidence);
    letter-spacing: 0.1em;
    opacity: 0.7;
    display: inline-block;
  }
  
  .band-reveal {
    height: 0;
    opacity: 0;
    overflow: hidden;
    transition: height var(--duration-slow) var(--ease-settle), opacity var(--duration-slow) var(--ease-settle), margin var(--duration-slow) var(--ease-settle);
  }
  
  .matrix-band.expanded .band-reveal {
    height: auto;
    opacity: 1;
    margin-top: clamp(0.3rem, 1vh, 1.5rem);
  }
  
  @media (hover: hover) {
    .matrix-band:hover .band-reveal, .matrix-band:focus-visible .band-reveal {
      height: auto;
      opacity: 1;
      margin-top: 1.5rem;
    }
  }
  
  .origin-meta {
    font-family: var(--font-narrative);
    font-size: clamp(14px, 2.8vw, 1.1rem);
    line-height: 1.3;
    margin: 0 0 0.3rem 0;
    max-width: 100%;
  }
  
  @media (max-width: 768px) {
    .origin-meta {
      font-size: 14px;
    }
    .band-reveal {
      width: 100%;
      padding: 0 1rem;
      box-sizing: border-box;
    }
  }
  
  .origin-subline {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.05em;
    opacity: 0.55;
    margin: 0 0 0.6rem 0;
  }
  
  .band-partner-note {
    font-family: var(--font-narrative);
    font-style: italic;
    font-size: 13px;
    color: var(--color-warm-cream);
    opacity: 0.5;
    margin-top: 0.5rem;
    letter-spacing: 0.02em;
  }
  
  .commerce-signal {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: rgba(166, 124, 60, 0.75); /* gold at 75% */
    margin: -0.2rem 0 0.6rem 0;
    opacity: 0;
    transition: opacity var(--duration-standard) ease;
  }
  
  .matrix-band.expanded .commerce-signal {
    opacity: 1;
  }
  
  .origin-action {
    display: inline-block;
    font-family: var(--font-narrative);
    font-size: 12px;
    color: rgba(245, 237, 216, 0.55);
    text-decoration: none;
    margin: 0;
    opacity: 0;
    transform: translateY(5px);
    transition: opacity 0.3s ease;
  }
  
  .origin-action.malabar-documented {
    color: rgba(245, 237, 216, 0.35);
  }

  .carousel-trigger {
    font-family: var(--font-narrative);
    font-size: 12px;
    color: rgba(245, 237, 216, 0.40);
    margin: 0.2rem 0 0 0;
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .carousel-trigger:hover {
    color: rgba(245, 237, 216, 0.80);
  }

  @media (max-width: 768px) {
    .origin-subline { font-size: 9px; }
    .origin-action { font-size: 12px; }
    .carousel-trigger { font-size: 12px; }
  }

  /* Plate static Origin Mark (Removed duplicate block from here) */

  .tap-pulse-indicator {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-gold);
    transform: translate(-50%, -50%) scale(0);
    opacity: 0;
    pointer-events: none;
    z-index: 10;
  }

  .tap-pulse-indicator::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 1px solid var(--color-gold);
    transform: translate(-50%, -50%);
  }

  .tap-pulse-indicator.pulse-active {
    animation: dotPulse 300ms ease-out forwards;
  }

  .tap-pulse-indicator.pulse-active::after {
    animation: ringPulse 300ms ease-out forwards;
  }

  @keyframes dotPulse {
    0% { transform: translate(-50%, -50%) scale(0); opacity: 0.6; }
    50% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
    100% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
  }

  @keyframes ringPulse {
    0% { width: 100%; height: 100%; opacity: 0.6; }
    100% { width: 400%; height: 400%; opacity: 0; }
  }
  
  .matrix-band.expanded .origin-action {
    opacity: 1;
    transform: translateY(20px);
  }
  
  @media (hover: hover) {
    .matrix-band:hover .origin-action, .matrix-band:focus-visible .origin-action {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .matrix-band.empty-state .origin-action {
    color: rgba(245, 237, 216, 0.6);
    pointer-events: none;
  }

  .matrix-mark-wrapper {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 5000;
    transition: opacity var(--duration-standard) ease;
  }

  /* Mobile Hold Indicator Styles */
  .mobile-hold-indicator {
    position: absolute;
    left: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    width: 24px;
    height: 24px;
    opacity: 0;
    pointer-events: none;
    z-index: 100;
  }
  
  .matrix-band.expanded.holding .mobile-hold-indicator {
    opacity: 1;
  }
  
  .hold-svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg); /* Start circle draw from top */
  }
  
  .hold-circle {
    fill: none;
    stroke: var(--color-gold);
    stroke-width: 2;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  
  .hold-dot {
    fill: var(--color-gold);
    opacity: 0;
  }
  
  .matrix-band.expanded.holding .hold-circle {
    animation: drawCircle 2.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  
  .matrix-band.expanded.holding .hold-dot {
    animation: pulseDot 2.4s ease-in-out forwards;
  }
  
  @keyframes drawCircle {
    0% { stroke-dashoffset: 100; }
    100% { stroke-dashoffset: 0; }
  }
  
  @keyframes pulseDot {
    0% { opacity: 0; transform: scale(0); }
    20% { opacity: 1; transform: scale(1); }
    80% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(0); }
  }
  
  .matrix-mark-wrapper.initial-center {
    right: 50%;
    transform: translate(50%, -50%) scale(2.5);
  }

  @media (max-width: 768px) {
    .matrix-mark-wrapper:not(.initial-center) {
      right: 1rem;
    }
  }

  /* Nav CSS removed */
</style>
