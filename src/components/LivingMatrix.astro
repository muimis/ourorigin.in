---
import { getCollection } from 'astro:content';
import OriginMark from './OriginMark.astro';
import TopographicMap from './TopographicMap.astro';

const origins = await getCollection('origins');

// Order by elevation (highest to lowest)
const orderedSlugs = ['nilgiris', 'idukki', 'wayanad', 'malabar-coast', 'thiruvananthapuram'];
const orderedOrigins = orderedSlugs.map(slug => origins.find(o => o.data.slug === slug)).filter(Boolean);

// Helper to get highest elevation from string like "100m - 1500m"
function getHighestElevation(elevationString) {
  if (!elevationString) return '';
  const cleanStr = elevationString.replace(/,/g, '');
  const matches = cleanStr.match(/\d+/g);
  if (matches) {
    return Math.max(...matches.map(Number));
  }
  return cleanStr.replace(/[^0-9]/g, '');
}

const matrixCopy = {
  'nilgiris': { fragment: 'This high, India has frost.', subLine: 'Western Ghats · Forest Polyculture', cta: 'Enter this origin' },
  'idukki': { fragment: 'These hills were named for what grows here.', subLine: 'Western Ghats · Shade-Grown Wild Harvest', cta: 'Enter this origin' },
  'wayanad': { fragment: 'The vine doesn\'t stand. It climbs.', subLine: 'Western Ghats · Traditional Agrarian', cta: 'Enter this origin' },
  'thiruvananthapuram': { fragment: 'The root that becomes dry ginger is dug up, not picked.', subLine: 'Western Ghats · Lowland Homesteading', cta: 'Enter this origin' },
  'malabar-coast': { fragment: 'This origin is still being documented.', subLine: 'Western Ghats · Smallholder Hand Harvest', cta: '' }
};

const anchorMap = {
  'nilgiris': '/origins/nilgiris/tea',
  'idukki': '/origins/idukki/cardamom',
  'wayanad': '/origins/wayanad/black-pepper',
  'thiruvananthapuram': '/origins/thiruvananthapuram/dry-ginger',
  'malabar-coast': '#'
};
---

<div class="living-matrix-container" id="living-matrix">
  <!-- Nav removed per request -->

  <div class="matrix-bands">
    {orderedOrigins.map((origin, index) => {
      const linkHref = anchorMap[origin.data.slug];
      const copy = matrixCopy[origin.data.slug];
      // The true visual boundary between plates is the exact middle of the 100px overlapping wavy mask (50px).
      // To create 5 perfectly equal 18vh visual bands inside a 90vh container:
      let heightCalc = 'calc(18vh + 100px)'; // Middle plates: hold top mask + bottom mask
      if (index === 0) {
        heightCalc = 'calc(18vh + 50px)'; // Nilgiris: only has bottom mask
      } else if (index === orderedOrigins.length - 1) {
        heightCalc = 'calc(18vh + 50px)'; // Thiru: only has top mask
      }
      
      let bandStyle = `flex: 0 0 ${heightCalc};`;
      
      // Shift text exactly 25px (via 50px padding) to perfectly align with the visual mask centers
      if (index === 0) {
        bandStyle += ' padding-bottom: 50px;'; // Center text relative to straight top edge & wavy bottom
      } else if (index === orderedOrigins.length - 1) {
        bandStyle += ' padding-top: 50px;'; // Center text relative to wavy top edge & straight bottom edge
      }

      if (index > 0) {
        const maskSvg = [
          "",
          `url("data:image/svg+xml,%3Csvg width='1000' height='100' viewBox='0 0 1000 100' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1000,100 L0,100 L0,60 C150,60 200,10 300,20 C400,30 450,90 600,70 C750,50 850,10 1000,40 Z' fill='black' /%3E%3C/svg%3E")`,
          `url("data:image/svg+xml,%3Csvg width='1000' height='100' viewBox='0 0 1000 100' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1000,100 L0,100 L0,40 C100,40 150,80 250,70 C350,60 400,20 550,30 C700,40 800,90 1000,60 Z' fill='black' /%3E%3C/svg%3E")`,
          `url("data:image/svg+xml,%3Csvg width='1000' height='100' viewBox='0 0 1000 100' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1000,100 L0,100 L0,70 C200,70 250,20 400,30 C550,40 600,80 750,60 C900,40 950,20 1000,50 Z' fill='black' /%3E%3C/svg%3E")`,
          `url("data:image/svg+xml,%3Csvg width='1000' height='100' viewBox='0 0 1000 100' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1000,100 L0,100 L0,30 C150,30 200,70 350,60 C500,50 600,10 750,30 C900,50 950,80 1000,40 Z' fill='black' /%3E%3C/svg%3E")`
        ][index];
        const maskCss = `mask-image: ${maskSvg}, linear-gradient(white, white); mask-position: top center, bottom center; mask-size: 100% 100px, 100% calc(100% - 99px); mask-repeat: no-repeat;`;
        const webkitMaskCss = `-webkit-mask-image: ${maskSvg}, linear-gradient(white, white); -webkit-mask-position: top center, bottom center; -webkit-mask-size: 100% 100px, 100% calc(100% - 99px); -webkit-mask-repeat: no-repeat;`;
        // Removed padding-top so text naturally centers in the flexbox without overlapping boundaries
        bandStyle += ` margin-top: -100px; ${maskCss} ${webkitMaskCss}`;
      }
      
      bandStyle += ` --index: ${index};`;
      
      return (
        <div data-href={linkHref} class={`matrix-band ${origin.data.slug === 'malabar-coast' ? 'empty-state' : ''}`} style={bandStyle} tabindex="0">
          <TopographicMap index={index} />
          
          <!-- Mobile Hold Indicator -->
          <div class="mobile-hold-indicator">
            <svg viewBox="0 0 100 100" class="hold-svg">
              <circle cx="50" cy="50" r="4" class="hold-dot" />
              <circle cx="50" cy="50" r="15" class="hold-circle" />
            </svg>
          </div>

          <div class="band-content">
            <div class="title-group">
              <h2 class="origin-name">
                {origin.data.name.toUpperCase()}
                <sup class="elevation-sup">{getHighestElevation(origin.data.elevation)}M</sup>
              </h2>
            </div>
            <div class="band-reveal">
              <p class="origin-meta">{copy.fragment}</p>
              <p class="origin-subline">{copy.subLine}</p>
              <div class="origin-live-telemetry"></div>
              
              <a href={linkHref} class="origin-action">{copy.cta}</a>
              <p class="carousel-trigger" data-origin={origin.id}>Browse all yields from this origin</p>
            </div>
          </div>
        </div>
      )
    })}
  </div>
  
  <div class="matrix-mark-wrapper initial-center">
    <OriginMark animate={true} size="var(--origin-mark-gauge-size)" />
  </div>
</div>

<script>
  import gsap from 'gsap';

  class LivingMatrixOrchestrator {
    constructor() {
      this.init();
    }

    init() {
      // The half-second of nothing, then the mark, then the bands.
      const bands = document.querySelectorAll('.matrix-band');
      const originNames = document.querySelectorAll('.title-group');
      const markWrapper = document.querySelector('.matrix-mark-wrapper');
      
      // Hide initially
      gsap.set(bands, { opacity: 0 });
      gsap.set(originNames, { y: 10, opacity: 0 });

      // Orchestrate the arrival
      const tl = gsap.timeline({ delay: 0.5 });

      tl.call(() => {
        // Fire the origin mark entrance animation
        const event = new Event('play-origin-mark-entrance');
        document.dispatchEvent(event);
      })
      .to(markWrapper, {
        scale: 1,
        x: '0%',
        right: window.innerWidth <= 768 ? '1rem' : '2rem',
        duration: 1.5,
        ease: 'power3.inOut'
      }, "+=1.5") // Wait for the draw to finish before moving to the side
      .to(bands, {
        opacity: 1,
        duration: 2,
        stagger: 0.15,
        ease: 'power2.inOut'
      }, "-=0.8") // Fade in bands as the mark slides over
      .to(originNames, {
        y: 0,
        opacity: 1,
        duration: 1.5,
        stagger: 0.1,
        ease: 'power3.out'
      }, "-=1.5");
    }
  }

  // Run orchestrator on load
  document.addEventListener('DOMContentLoaded', () => {
    const hasVisited = sessionStorage.getItem('ourorigin_visited');
    if (hasVisited === 'true') {
      new LivingMatrixOrchestrator();
    } else {
      window.addEventListener('launch-sequence-complete', () => {
        new LivingMatrixOrchestrator();
      });
    }
    
    // Wire up carousel triggers
    document.querySelectorAll('.carousel-trigger').forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault(); // Stop navigation!
        e.stopPropagation(); // Don't collapse the band
        const originId = trigger.getAttribute('data-origin');
        window.dispatchEvent(new CustomEvent('open-carousel', { detail: { originId } }));
      });
    });

    // Mobile tap-to-expand & Desktop click-to-navigate logic
    document.querySelectorAll('.matrix-band').forEach(band => {
      band.addEventListener('click', (e) => {
        // Prevent triggering if clicking carousel
        if (e.target.closest('.carousel-trigger')) return;
        
        // Let the origin-action anchor act naturally
        if (e.target.closest('.origin-action')) return;

        const hasHover = window.matchMedia('(hover: hover)').matches;
        
        if (!hasHover) {
          e.preventDefault();
          // Mobile: Tap to expand, hold, and navigate
          const bandsContainer = document.querySelector('.matrix-bands');
          
          if (!band.classList.contains('expanded')) {
            // Collapse others
            document.querySelectorAll('.matrix-band.expanded').forEach(b => {
              b.classList.remove('expanded');
              b.classList.remove('holding');
            });
            bandsContainer.classList.add('has-expanded');
            
            // Expand and hold this one
            band.classList.add('expanded');
            band.classList.add('holding');
            
            // Navigate after 2.5s hold animation
            setTimeout(() => {
              const href = band.getAttribute('data-href');
              if (href && href !== '#') {
                window.location.href = href;
              }
            }, 2500);
          }
        } else {
          // Desktop: Click anywhere on band to navigate
          const href = band.getAttribute('data-href');
          if (href && href !== '#') {
            window.location.href = href;
          }
        }
      });
    });
  });
</script>

<style>
  .living-matrix-container {
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background-color: var(--color-forest-deep);
    position: relative;
    overflow: hidden;
    /* Shifted up slightly (~3mm / 1.5vh) while keeping total 10vh padding to maintain the 90vh internal plate math */
    padding: 3.5vh 0 6.5vh 0; 
    box-sizing: border-box; /* Crucial so padding doesn't overflow 100vh */
  }
  
  .matrix-bands {
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
  }
  
  @keyframes subtleBreathe {
    0% { background-color: rgba(245, 237, 216, 0); transform: translateY(0); }
    50% { background-color: rgba(245, 237, 216, 0.015); transform: translateY(-4px); }
    100% { background-color: rgba(245, 237, 216, 0); transform: translateY(0); }
  }

  .matrix-band {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box; /* Crucial so inline padding doesn't break perfect vh math! */
    /* padding-top is dynamic via inline styles */
    padding-left: 1.5rem; /* Reduced for mobile */
    padding-right: 1.5rem; /* Reduced for mobile */
    padding-bottom: 0;
    cursor: pointer;
    background-color: var(--color-forest-deep);
    transition: flex var(--duration-deep) var(--ease-settle), 
                background-color var(--duration-standard) ease;
    position: relative;
    /* Static background, add subtleBreathe idle animation */
    animation: subtleBreathe 10s ease-in-out infinite;
    animation-delay: calc(var(--index, 0) * -2s); /* Stagger the breathing */
    color: var(--color-warm-cream);
    text-decoration: none;
    opacity: 0; /* The masks carve the rect into topographic shapes. No ::after needed! */
    /* Add 3D feel with drop shadow that respects the SVG mask! */
    filter: drop-shadow(0px -8px 15px rgba(0, 0, 0, 0.7));
    z-index: calc(10 - var(--index)); /* Ensure upper plates cast shadow onto lower plates properly if needed, though default stacking handles it */
  }
  
  @media (min-width: 768px) {
    .matrix-band {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  .matrix-band:last-child {
    border-bottom: none;
  }
  
  .matrix-band {
    /* Base configuration for hover expansion */
    flex: var(--base-flex);
  }
  
  /* Universal expanded class (triggered by JS tap on mobile) */
  .matrix-band.expanded {
    flex-grow: 1.5 !important; /* Huge expansion on mobile removed, restore to original 1.5 to prevent squishing others into lines */
    background-color: #121d0e;
    color: var(--color-pure-white);
    outline: none;
    animation-play-state: paused;
  }

  @media (hover: hover) {
    .matrix-band:hover, .matrix-band:focus-visible {
      /* Gentle expansion to prevent overlapping text while maintaining focus */
      flex-grow: 1.5 !important;
      background-color: #121d0e; /* Solid background to prevent seeing layers underneath! */
      color: var(--color-pure-white);
      outline: none;
      animation-play-state: paused;
    }
  }
  
  .band-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    height: 100%;
    width: 100%;
    overflow: hidden; /* Guarantee internal text cannot spill out past the 18vh vertical space */
    padding: 2vh 0; /* buffer to keep text away from absolute wavy edges */
    box-sizing: border-box;
  }
  
  .title-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    transform: translateY(10px);
    opacity: 0;
  }
  
  .origin-name {
    font-family: var(--font-institutional);
    /* Scale down perfectly for thiruvananthapuram */
    font-size: clamp(0.7rem, 3.8vw, var(--text-size-stratum-title));
    line-height: 1.1;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
    font-weight: 400;
    text-align: center;
    word-break: break-word;
    transition: transform 0.6s var(--ease-settle), opacity 0.6s ease;
    transform-origin: center;
  }
  
  /* When a plate expands, shrink and dim the text of the COMPRESSED plates so they never bleed */
  .matrix-bands.has-expanded .matrix-band:not(.expanded) .origin-name {
    transform: scale(0.65);
    opacity: 0.4;
  }
  
  .matrix-bands:hover .matrix-band:not(:hover) .origin-name {
    @media (hover: hover) {
      transform: scale(0.65);
      opacity: 0.4;
    }
  }
  
  .elevation-sup {
    vertical-align: super;
    font-size: 0.35em; /* True superscript sizing */
    margin-left: 0.2rem;
    font-family: var(--font-evidence);
    letter-spacing: 0.1em;
    opacity: 0.7;
    display: inline-block; /* Prevent separation from word */
  }
  
  .band-reveal {
    height: 0;
    opacity: 0;
    overflow: hidden;
    /* Use slower, more deliberate timing for the reveal to match the "opening" feel */
    transition: height var(--duration-slow) var(--ease-settle), opacity var(--duration-slow) var(--ease-settle), margin var(--duration-slow) var(--ease-settle);
  }
  
  .matrix-band.expanded .band-reveal {
    height: auto;
    opacity: 1;
    margin-top: clamp(0.3rem, 1vh, 1.5rem);
  }
  
  @media (hover: hover) {
    .matrix-band:hover .band-reveal, .matrix-band:focus-visible .band-reveal {
      height: auto;
      opacity: 1;
      margin-top: 1.5rem;
    }
  }
  
  .origin-meta {
    font-family: var(--font-narrative);
    font-size: clamp(0.75rem, 2.8vw, 1.1rem);
    line-height: 1.3;
    margin: 0 0 0.3rem 0;
  }
  
  .origin-subline {
    font-family: var(--font-evidence);
    font-size: clamp(0.6rem, 2.2vw, 0.85rem);
    letter-spacing: 0.05em;
    opacity: 0.6;
    margin: 0 0 0.6rem 0;
  }
  
  .origin-action {
    display: inline-block;
    font-family: var(--font-narrative);
    font-size: clamp(0.8rem, 3vw, 1rem);
    font-style: italic;
    color: var(--color-gold);
    text-decoration: none;
    margin: 0;
    opacity: 0;
    transform: translateY(5px);
    transition: opacity 0.3s ease;
  }

  .carousel-trigger {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(0.8rem, 3vw, 1.1rem);
    color: var(--color-warm-cream);
    margin: 0.8rem 0 0 0;
    text-decoration: underline;
    text-underline-offset: 4px;
    cursor: pointer;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }
  .carousel-trigger:hover {
    opacity: 1;
  }
  
  .matrix-band.expanded .origin-action {
    opacity: 1;
    transform: translateY(0);
  }
  
  @media (hover: hover) {
    .matrix-band:hover .origin-action, .matrix-band:focus-visible .origin-action {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .matrix-band.empty-state .origin-action {
    color: rgba(245, 237, 216, 0.6);
    pointer-events: none;
  }

  .matrix-mark-wrapper {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 5000;
    transition: opacity var(--duration-standard) ease;
  }

  /* Mobile Hold Indicator Styles */
  .mobile-hold-indicator {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 30px;
    height: 30px;
    opacity: 0;
    pointer-events: none;
    z-index: 100;
  }
  
  .matrix-band.expanded.holding .mobile-hold-indicator {
    opacity: 1;
  }
  
  .hold-svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg); /* Start circle draw from top */
  }
  
  .hold-circle {
    fill: none;
    stroke: var(--color-gold);
    stroke-width: 2;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  
  .hold-dot {
    fill: var(--color-gold);
    opacity: 0;
  }
  
  .matrix-band.expanded.holding .hold-circle {
    animation: drawCircle 2.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  
  .matrix-band.expanded.holding .hold-dot {
    animation: pulseDot 2.4s ease-in-out forwards;
  }
  
  @keyframes drawCircle {
    0% { stroke-dashoffset: 100; }
    100% { stroke-dashoffset: 0; }
  }
  
  @keyframes pulseDot {
    0% { opacity: 0; transform: scale(0); }
    20% { opacity: 1; transform: scale(1); }
    80% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(0); }
  }
  
  .matrix-mark-wrapper.initial-center {
    right: 50%;
    transform: translate(50%, -50%) scale(2.5);
  }

  @media (max-width: 768px) {
    .matrix-mark-wrapper:not(.initial-center) {
      right: 1rem;
    }
  }

  /* Nav CSS removed */
</style>
