---
import { getCollection } from 'astro:content';
import OriginMark from './OriginMark.astro';
import TopographicMap from './TopographicMap.astro';

const origins = await getCollection('origins');

// Order by elevation (highest to lowest)
const orderedSlugs = ['nilgiris', 'idukki', 'wayanad', 'malabar-coast', 'thiruvananthapuram'];
const orderedOrigins = orderedSlugs.map(slug => origins.find(o => o.data.slug === slug)).filter(Boolean);
---

<div class="living-matrix-container" id="living-matrix">
  <div class="matrix-bands">
    {orderedOrigins.map((origin, index) => {
      const isWayanad = origin.data.slug === 'wayanad';
      const linkHref = isWayanad ? '/origins/wayanad/black-pepper' : '#';
      // Elevation felt visually: higher elevation gets slightly more natural space
      const baseFlex = 1 + ((orderedOrigins.length - index) * 0.15);
      
      let bandStyle = `--base-flex: ${baseFlex}; flex: ${baseFlex};`;
      if (index > 0) {
        const maskSvg = [
          "",
          `url("data:image/svg+xml,%3Csvg width='1000' height='100' viewBox='0 0 1000 100' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1000,100 L0,100 L0,60 C150,60 200,10 300,20 C400,30 450,90 600,70 C750,50 850,10 1000,40 Z' fill='black' /%3E%3C/svg%3E")`,
          `url("data:image/svg+xml,%3Csvg width='1000' height='100' viewBox='0 0 1000 100' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1000,100 L0,100 L0,40 C100,40 150,80 250,70 C350,60 400,20 550,30 C700,40 800,90 1000,60 Z' fill='black' /%3E%3C/svg%3E")`,
          `url("data:image/svg+xml,%3Csvg width='1000' height='100' viewBox='0 0 1000 100' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1000,100 L0,100 L0,70 C200,70 250,20 400,30 C550,40 600,80 750,60 C900,40 950,20 1000,50 Z' fill='black' /%3E%3C/svg%3E")`,
          `url("data:image/svg+xml,%3Csvg width='1000' height='100' viewBox='0 0 1000 100' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1000,100 L0,100 L0,30 C150,30 200,70 350,60 C500,50 600,10 750,30 C900,50 950,80 1000,40 Z' fill='black' /%3E%3C/svg%3E")`
        ][index];
        const maskCss = `mask-image: ${maskSvg}, linear-gradient(white, white); mask-position: top center, bottom center; mask-size: 100% 100px, 100% calc(100% - 99px); mask-repeat: no-repeat;`;
        const webkitMaskCss = `-webkit-mask-image: ${maskSvg}, linear-gradient(white, white); -webkit-mask-position: top center, bottom center; -webkit-mask-size: 100% 100px, 100% calc(100% - 99px); -webkit-mask-repeat: no-repeat;`;
        // Removed padding-top so text naturally centers in the flexbox without overlapping boundaries
        bandStyle += ` margin-top: -100px; ${maskCss} ${webkitMaskCss}`;
      }
      
      return (
        <a href={linkHref} class={`matrix-band ${isWayanad ? '' : 'empty-state'}`} style={bandStyle}>
          <TopographicMap index={index} />
          <div class="band-content">
            <h2 class="origin-name">{origin.data.name}</h2>
            <div class="band-reveal">
              <p class="origin-meta">{origin.data.elevation} · {origin.data.bioregion}</p>
              {isWayanad ? (
                <p class="origin-action">Descend</p>
              ) : (
                <p class="origin-action">This origin is still being documented.</p>
              )}
            </div>
          </div>
        </a>
      )
    })}
  </div>
  
  <div class="matrix-mark-wrapper initial-center">
    <OriginMark animate={true} size="var(--origin-mark-gauge-size)" />
  </div>
</div>

<script>
  import gsap from 'gsap';

  class LivingMatrixOrchestrator {
    constructor() {
      this.init();
    }

    init() {
      // The half-second of nothing, then the mark, then the bands.
      const bands = document.querySelectorAll('.matrix-band');
      const originNames = document.querySelectorAll('.origin-name');
      const markWrapper = document.querySelector('.matrix-mark-wrapper');
      
      // Hide initially
      gsap.set(bands, { opacity: 0 });
      gsap.set(originNames, { y: 10, opacity: 0 });

      // Orchestrate the arrival
      const tl = gsap.timeline({ delay: 0.5 });

      tl.call(() => {
        // Fire the origin mark entrance animation
        const event = new Event('play-origin-mark-entrance');
        document.dispatchEvent(event);
      })
      .to(markWrapper, {
        scale: 1,
        x: '0%',
        right: window.innerWidth <= 768 ? '1rem' : '2rem',
        duration: 1.5,
        ease: 'power3.inOut'
      }, "+=1.5") // Wait for the draw to finish before moving to the side
      .to(bands, {
        opacity: 1,
        duration: 2,
        stagger: 0.15,
        ease: 'power2.inOut'
      }, "-=0.8") // Fade in bands as the mark slides over
      .to(originNames, {
        y: 0,
        opacity: 1,
        duration: 1.5,
        stagger: 0.1,
        ease: 'power3.out'
      }, "-=1.5");
    }
  }

  // Run orchestrator on load
  document.addEventListener('DOMContentLoaded', () => {
    new LivingMatrixOrchestrator();
  });
</script>

<style>
  .living-matrix-container {
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background-color: var(--color-forest-deep);
    position: relative;
    overflow: hidden;
  }
  
  .matrix-bands {
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
  }
  
  @keyframes subtleBreathe {
    0% { background-color: rgba(245, 237, 216, 0); }
    50% { background-color: rgba(245, 237, 216, 0.015); }
    100% { background-color: rgba(245, 237, 216, 0); }
  }

  .matrix-band {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    /* padding-top is dynamic via inline styles */
    padding-left: 4rem;
    padding-right: 4rem;
    padding-bottom: 0;
    cursor: pointer;
    background-color: var(--color-forest-deep);
    transition: flex var(--duration-deep) var(--ease-settle), 
                background-color var(--duration-standard) ease;
    position: relative;
    animation: subtleBreathe 12s infinite ease-in-out;
    color: var(--color-warm-cream);
    text-decoration: none;
    opacity: 0; /* Hidden natively for GSAP entrance */
  }

  /* The masks carve the rect into topographic shapes. No ::after needed! */
  
  /* Stagger the breathe animation so they don't pulse together */
  .matrix-band:nth-child(1) { animation-delay: 0s; }
  .matrix-band:nth-child(2) { animation-delay: -2s; }
  .matrix-band:nth-child(3) { animation-delay: -4s; }
  .matrix-band:nth-child(4) { animation-delay: -6s; }
  .matrix-band:nth-child(5) { animation-delay: -8s; }

  .matrix-band:last-child {
    border-bottom: none;
  }
  
  .matrix-band:hover, .matrix-band:focus {
    /* Significant expansion to feel like "opening" rather than just hovering */
    flex: calc(var(--base-flex) + 2) !important;
    background-color: rgba(245, 237, 216, 0.04);
    outline: none;
    animation-play-state: paused;
  }
  
  .band-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  
  .origin-name {
    font-family: var(--font-institutional);
    font-size: var(--text-size-stratum-title);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
    font-weight: 400;
    opacity: 0; /* Hidden natively for GSAP entrance */
    transform: translateY(10px);
  }
  
  .band-reveal {
    height: 0;
    opacity: 0;
    overflow: hidden;
    /* Use slower, more deliberate timing for the reveal to match the "opening" feel */
    transition: height var(--duration-slow) var(--ease-settle), opacity var(--duration-slow) var(--ease-settle), margin var(--duration-slow) var(--ease-settle);
  }
  
  .matrix-band:hover .band-reveal, .matrix-band:focus .band-reveal {
    height: auto;
    opacity: 1;
    margin-top: 1.5rem;
  }
  
  .origin-meta {
    font-family: var(--font-evidence);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    opacity: 0.8;
    margin: 0 0 0.5rem 0;
  }
  
  .origin-action {
    font-family: var(--font-narrative);
    font-size: 1rem;
    font-style: italic;
    color: var(--color-gold);
    margin: 0;
    opacity: 0;
    transform: translateY(5px);
    transition: opacity var(--duration-standard) ease 0.2s, transform var(--duration-standard) ease 0.2s;
  }
  
  .matrix-band:hover .origin-action, .matrix-band:focus .origin-action {
    opacity: 1;
    transform: translateY(0);
  }

  .matrix-band.empty-state .origin-action {
    color: rgba(245, 237, 216, 0.6);
  }

  .matrix-mark-wrapper {
    position: absolute;
    right: 2rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 10;
  }

  .matrix-mark-wrapper.initial-center {
    right: 50%;
    transform: translate(50%, -50%) scale(2.5);
  }

  @media (max-width: 768px) {
    .matrix-mark-wrapper:not(.initial-center) {
      right: 1rem;
    }
  }
</style>
