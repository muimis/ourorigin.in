<script>
  import gsap from 'gsap';

  class LivingMatrixOrchestrator {
    constructor() {
      this.init();
    }

    init() {
      const bands = document.querySelectorAll('.matrix-band');
      const originNames = document.querySelectorAll('.title-group');
      
      // Load instantly instead of a 2 second fade to remove green screen delay
      gsap.set(bands, { opacity: 1 });
      gsap.set(originNames, { y: 0, opacity: 1 });
    }
  }

  // Add an event listener to reveal the marks when the launch animation completes
  window.addEventListener('origin-marks-arrived', () => {
    const marks = document.querySelectorAll('.plate-origin-mark');
    marks.forEach((mark) => {
      const targetOp = mark.getAttribute('data-target-opacity') || '0.9';
      // All 5 plates fade in with a live golden fade-in simultaneously
      gsap.to(mark, { opacity: parseFloat(targetOp), duration: 0.8, ease: 'power2.out' });
    });
  });

  function renderHUDLines() {
    const bands = document.querySelectorAll('.matrix-band');
    bands.forEach(band => {
      const container = band.querySelector('.hud-dynamic-container');
      if (!container) return;
      
      const slug = container.getAttribute('data-slug');
      const side = container.getAttribute('data-side');
      
      const title = band.querySelector(`#title-${slug} h2`);
      const tag = band.querySelector(`#tag-${slug}`);
      const bandRect = band.getBoundingClientRect();
      
      if (!title || !tag) return;
      
      const titleRect = title.getBoundingClientRect();
      const tagRect = tag.getBoundingClientRect();
      // 5mm is approx 20px
      const inwardOffset = 20;
      const outwardOffset = 20;
      
      const titleStartX = (titleRect.right - bandRect.left) - 20; // inner (under text)
      const titleEndX = (titleRect.right - bandRect.left) + 20;   // outer (past text)
      const startY = (titleRect.bottom - bandRect.top) + 2;
      
      // Telemetry tag positioning (Y axis only, X axis is handled by CSS right)
      const targetTagTop = (titleRect.top - bandRect.top) - 24 - tagRect.height;
      tag.style.top = `${targetTagTop}px`;
      
      // We must re-measure tagRect after moving it vertically
      const updatedTagRect = tag.getBoundingClientRect();
      
      const tagStartX = (updatedTagRect.left - bandRect.left) + 20; // inner (under text)
      const tagEndX = (updatedTagRect.left - bandRect.left) - 20;   // outer (past text)
      const tagUnderlineY = targetTagTop + tagRect.height + 4; 
      
      // Two separate disconnected 10mm lines
      const pathData1 = `M ${titleStartX} ${startY} L ${titleEndX} ${startY}`;
      const pathData2 = `M ${tagStartX} ${tagUnderlineY} L ${tagEndX} ${tagUnderlineY}`;
      
      container.innerHTML = `
        <svg class="hud-dynamic-svg" style="position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; overflow: visible; z-index: 4;">
          <path d="${pathData1}" stroke="rgba(166, 124, 60, 0.4)" stroke-width="1" fill="none" class="hud-tether-path" />
          <path d="${pathData2}" stroke="rgba(166, 124, 60, 0.4)" stroke-width="1" fill="none" class="hud-tether-path" />
          
          <g class="hud-pulse-group" transform="translate(${titleStartX}, ${startY})">
            <circle r="4" stroke="rgba(166, 124, 60, 0.6)" stroke-width="1" fill="none" style="animation: hudPulse 2.5s infinite cubic-bezier(0.2, 0.8, 0.2, 1);" />
            <circle r="1.5" fill="rgba(166, 124, 60, 1)" />
          </g>
          <g class="hud-pulse-group" transform="translate(${tagStartX}, ${tagUnderlineY})">
            <circle r="4" stroke="rgba(166, 124, 60, 0.6)" stroke-width="1" fill="none" style="animation: hudPulse 2.5s infinite cubic-bezier(0.2, 0.8, 0.2, 1);" />
            <circle r="1.5" fill="rgba(166, 124, 60, 1)" />
          </g>
        </svg>
      `;
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const hasVisited = sessionStorage.getItem('ourorigin_visited');
    if (hasVisited === 'true') {
      new LivingMatrixOrchestrator();
    } else {
      window.addEventListener('launch-sequence-complete', () => {
        new LivingMatrixOrchestrator();
      });
    }
    
    // Render HUD and bind resize
    renderHUDLines();
    window.addEventListener('resize', renderHUDLines);
    
    document.querySelectorAll('.carousel-trigger').forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const originId = trigger.getAttribute('data-origin');
        window.dispatchEvent(new CustomEvent('open-carousel', { detail: { originId } }));
      });
    });

    document.querySelectorAll('.matrix-band').forEach(band => {
      band.addEventListener('click', (e) => {
        if (e.target.closest('.carousel-trigger')) return;
        if (e.target.closest('.origin-action')) return;

        const hasHover = window.matchMedia('(hover: hover)').matches;
        
        if (!hasHover) {
          if (band.classList.contains('empty-state')) return;
          e.preventDefault();
          const bandsContainer = document.querySelector('.matrix-bands');
          
          if (!band.classList.contains('expanded')) {
            // Pulse animation centered on tap coordinates
            const pulse = band.querySelector('.tap-pulse-indicator');
            if (pulse) {
              const rect = band.getBoundingClientRect();
              const clientX = e.touches ? e.touches[0].clientX : e.clientX;
              const clientY = e.touches ? e.touches[0].clientY : e.clientY;
              const x = clientX - rect.left;
              const y = clientY - rect.top;
              pulse.style.left = `${x}px`;
              pulse.style.top = `${y}px`;
              
              pulse.classList.add('pulse-active');
              setTimeout(() => {
                pulse.classList.remove('pulse-active');
              }, 300);
            }

            document.querySelectorAll('.matrix-band.expanded').forEach(b => {
              b.classList.remove('expanded');
              b.setAttribute('aria-expanded', 'false');
            });
            bandsContainer.classList.add('has-expanded');
            document.body.classList.add('matrix-expanded');
            
            band.classList.add('expanded');
            band.setAttribute('aria-expanded', 'true');
          } else {
            band.classList.remove('expanded');
            band.setAttribute('aria-expanded', 'false');
            bandsContainer.classList.remove('has-expanded');
            document.body.classList.remove('matrix-expanded');
          }
        } else {
          const href = band.getAttribute('data-href');
          if (href && href !== '#') {
            window.location.href = href;
          }
        }
      });
    });
  });
</script>

