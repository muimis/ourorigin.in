---
// src/components/TheYieldList.astro
import LiveWeather from './LiveWeather.astro';
import { getCollection } from 'astro:content';

const yields = await getCollection('products');
const origins = await getCollection('origins');

// Define Sourcing Metadata (Deliverables & Upcoming Crops) for each origin slug
const originMetadata = {
  wayanad: {
    deliverable: 'High-Heat Volcanic Laterite Loam & Essential Pinene Oils',
    upcoming: {
      badge: 'ROOT CURING',
      name: 'Wild Celery Seed',
      date: 'JAN 2027'
    }
  },
  idukki: {
    deliverable: 'Pristine Cloud Forest Canopy & Mist-Settled Terpenes',
    upcoming: {
      badge: 'WOOL WRAP CURING',
      name: 'Winter Curing Vanilla',
      date: 'OCT 2026'
    }
  },
  nilgiris: {
    deliverable: 'Slow-Growth Acidic Clay & Mountain Frost Tannins',
    upcoming: {
      badge: 'SUN WITHERING',
      name: 'Silver Needle Tea',
      date: 'DEC 2026'
    }
  },
  thiruvananthapuram: {
    deliverable: 'Coastal Sun-Baked Silicified Sand & Zingerone Heat',
    upcoming: {
      badge: 'SHADE DRYING',
      name: 'Sun-Dried Galangal Root',
      date: 'FEB 2027'
    }
  }
};

// We group yields by origin
const groupedYields = {};
origins.forEach(origin => {
  const matchingYields = yields.filter(y => {
    const originId = typeof y.data.originSlug === 'object' ? y.data.originSlug?.id : y.data.originSlug;
    return originId === origin.data.slug;
  });
  
  groupedYields[origin.data.slug] = {
    origin,
    products: matchingYields
  };
});

const originOrder = ['wayanad', 'idukki', 'nilgiris', 'thiruvananthapuram'];
---

<section id="sourcing-matrix" class="sourcing-matrix-section">
  <div class="matrix-grid">
    {originOrder.map((slug, idx) => {
      const group = groupedYields[slug];
      if (!group) return null;
      
      const origin = group.origin;
      const meta = originMetadata[slug];
      const products = group.products.sort((a, b) => a.data.name.localeCompare(b.data.name));
      const quadrantNum = String(idx + 1).padStart(2, '0');

      return (
        <div class="matrix-quadrant" data-origin={slug}>
          <!-- Quadrant Header -->
          <div class="quadrant-header">
            <span class="quadrant-index">[ COLLECTIVE {quadrantNum} ]</span>
            <div class="quadrant-coordinates">
              <span>{origin.data.coordinates}</span>
              <span class="coord-dot">·</span>
              <span>{origin.data.elevation}</span>
            </div>
          </div>

          <!-- Quadrant Identity -->
          <div class="quadrant-identity">
            <h2 class="quadrant-title">{origin.data.name} Collective</h2>
            <div class="quadrant-weather">
              <span class="weather-label">LIVE TELEMETRY:</span>
              <LiveWeather coordinates={origin.data.coordinates} originName={origin.data.name} />
            </div>
          </div>

          <!-- Signature Deliverable Callout -->
          <div class="quadrant-deliverable">
            <span class="section-label">[ SIGNATURE ECOLOGICAL CHARACTER ]</span>
            <p class="deliverable-text">{meta.deliverable}</p>
          </div>

          <!-- Yields Catalog (Active & Upcoming) -->
          <div class="quadrant-yields-wrapper">
            <span class="section-label">[ ACTIVE SPECIMEN YIELDS ]</span>
            <ul class="yield-list">
              {products.map(p => (
                <li class="yield-item">
                  <a href={`/origins/${slug}/${p.id}`} class="yield-link" aria-label={`Descend into ${p.data.name}`}>
                    <div class="yield-info">
                      <span class="yield-name">{p.data.name}</span>
                      <span class="yield-botanical">{p.data.botanicalName}</span>
                    </div>
                    <span class="yield-arrow">[ DESCEND &rarr; ]</span>
                  </a>
                </li>
              ))}

              <!-- Horizon Upcoming Crop -->
              {meta.upcoming && (
                <li class="yield-item yield-item-upcoming">
                  <div class="yield-info">
                    <span class="yield-name upcoming-name">
                      {meta.upcoming.name}
                      <span class="upcoming-tag">[{meta.upcoming.badge}]</span>
                    </span>
                    <span class="yield-botanical">Curing Phase</span>
                  </div>
                  <span class="upcoming-date">EST: {meta.upcoming.date}</span>
                </li>
              )}
            </ul>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .sourcing-matrix-section {
    background-color: var(--color-forest-deep);
    color: var(--color-warm-cream);
    border-top: 1px solid rgba(245, 237, 216, 0.12);
    border-bottom: 1px solid rgba(245, 237, 216, 0.12);
    min-height: 100vh;
    display: flex;
    align-items: stretch;
  }

  .matrix-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    width: 100%;
    align-items: stretch;
  }

  /* Grid dividers mapping equal weightage */
  .matrix-quadrant {
    padding: 6rem 5vw;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    box-sizing: border-box;
    align-items: flex-start;
    text-align: left;
  }

  /* Thin 1px structural lines for brutalist grid blueprint */
  .matrix-quadrant:nth-child(1) {
    border-right: 1px solid rgba(245, 237, 216, 0.12);
    border-bottom: 1px solid rgba(245, 237, 216, 0.12);
  }

  .matrix-quadrant:nth-child(2) {
    border-bottom: 1px solid rgba(245, 237, 216, 0.12);
  }

  .matrix-quadrant:nth-child(3) {
    border-right: 1px solid rgba(245, 237, 216, 0.12);
  }

  /* Header specs */
  .quadrant-header {
    display: flex;
    justify-content: space-between;
    width: 100%;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: rgba(245, 237, 216, 0.45);
    border-bottom: 1px dashed rgba(245, 237, 216, 0.1);
    padding-bottom: 0.8rem;
  }

  .quadrant-index {
    color: var(--color-gold);
  }

  .quadrant-coordinates {
    display: flex;
    gap: 0.5rem;
  }

  .coord-dot {
    color: var(--color-gold);
  }

  /* Identity details */
  .quadrant-identity {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .quadrant-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.2vw, 4rem);
    font-weight: 300;
    line-height: 1;
    margin: 0;
  }

  .quadrant-weather {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    color: rgba(245, 237, 216, 0.5);
  }

  .weather-label {
    color: var(--color-gold);
  }

  /* Deliverable specifications */
  .quadrant-deliverable {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: rgba(245, 237, 216, 0.35);
  }

  .deliverable-text {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.5vw, 1.45rem);
    line-height: 1.5;
    color: var(--color-warm-cream);
    margin: 0;
    font-style: italic;
    opacity: 0.95;
  }

  /* Yield list & Links */
  .quadrant-yields-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    width: 100%;
  }

  .yield-list {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .yield-item {
    border-bottom: 1px solid rgba(245, 237, 216, 0.08);
    width: 100%;
  }

  .yield-item:last-child {
    border-bottom: none;
  }

  .yield-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 0;
    color: var(--color-warm-cream);
    text-decoration: none;
    transition: background-color 0.3s ease;
    width: 100%;
  }

  .yield-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    align-items: flex-start;
  }

  .yield-name {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1.5vw, 1.5rem);
    font-weight: 300;
    transition: color 0.3s ease;
  }

  .yield-botanical {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.85rem;
    color: rgba(245, 237, 216, 0.45);
  }

  .yield-arrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    color: rgba(245, 237, 216, 0.4);
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.4s var(--ease-settle);
  }

  /* Hover transitions mapping high-art feel */
  .yield-link:hover .yield-name {
    color: var(--color-gold);
  }

  .yield-link:hover .yield-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--color-gold);
  }

  /* Upcoming Crop specific styling */
  .yield-item-upcoming {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 0;
    opacity: 0.5;
  }

  .upcoming-name {
    color: rgba(245, 237, 216, 0.8);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .upcoming-tag {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.1em;
    color: var(--color-gold);
  }

  .upcoming-date {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    color: rgba(245, 237, 216, 0.6);
  }

  /* Responsive styling */
  @media (max-width: 1024px) {
    .matrix-grid {
      grid-template-columns: 1fr;
    }
    .matrix-quadrant {
      border-right: none !important;
      border-bottom: 1px solid rgba(245, 237, 216, 0.12) !important;
      padding: 5rem 6vw;
    }
    .matrix-quadrant:last-child {
      border-bottom: none !important;
    }
  }
</style>
