---
export interface Props {
  size?: number;
  variant?: 'primary' | 'reversed' | 'gold';
  id?: string;
}

const { size = 100, variant = 'primary', id = Math.random().toString(36).substring(7) } = Astro.props;

const colorMap = {
  primary: 'var(--color-warm-cream)',
  reversed: 'var(--color-forest-deep)',
  gold: 'var(--color-gold)'
};
const strokeColor = colorMap[variant];
---

<svg 
  id={`origin-mark-${id}`}
  class={`origin-mark variant-${variant}`} 
  width={size} 
  height={size} 
  viewBox="0 0 280 280" 
  xmlns="http://www.w3.org/2000/svg" 
  fill="none" 
  aria-label="OurOrigin — Origin Mark" 
  role="img"
>
  <!-- Outer ring -->
  <circle class="om-outer" cx="140" cy="140" r="108" stroke={strokeColor} stroke-width="1.5" opacity="0.4"/>
  
  <!-- Crosshairs -->
  <g class="om-crosshairs" stroke={strokeColor} stroke-width="1.5" opacity="0.9" stroke-linecap="round">
    <line x1="140" y1="72"  x2="140" y2="104"/>
    <line x1="140" y1="176" x2="140" y2="208"/>
    <line x1="72"  y1="140" x2="104" y2="140"/>
    <line x1="176" y1="140" x2="208" y2="140"/>
  </g>

  <!-- Inner ring -->
  <circle class="om-inner" cx="140" cy="140" r="28" stroke={strokeColor} stroke-width="1.5" opacity="0.75" fill="none"/>
  
  <!-- Center dot -->
  <circle class="om-dot" cx="140" cy="140" r="6" fill={strokeColor} opacity="1"/>
</svg>

<script>
  import gsap from 'gsap';

  class OriginMarkAnimation {
    constructor() {
      this.init();
      document.addEventListener('play-origin-mark-entrance', () => this.play());
    }

    init() {
      document.querySelectorAll('.origin-mark').forEach(svg => {
        const outer = svg.querySelector('.om-outer');
        const lines = svg.querySelectorAll('.om-crosshairs line');
        const inner = svg.querySelector('.om-inner');
        const dot = svg.querySelector('.om-dot');

        // Lengths for draw-on effect
        const outerLen = 2 * Math.PI * 108; // ~678.58
        const innerLen = 2 * Math.PI * 28;  // ~175.93
        const lineLen = 32;

        gsap.set(outer, { strokeDasharray: outerLen, strokeDashoffset: outerLen });
        gsap.set(inner, { strokeDasharray: innerLen, strokeDashoffset: innerLen });
        gsap.set(lines, { strokeDasharray: lineLen, strokeDashoffset: lineLen });
        gsap.set(dot, { scale: 0, transformOrigin: "50% 50%", opacity: 0 });
      });
    }

    play() {
      document.querySelectorAll('.origin-mark').forEach(svg => {
        const outer = svg.querySelector('.om-outer');
        const lines = svg.querySelectorAll('.om-crosshairs line');
        const inner = svg.querySelector('.om-inner');
        const dot = svg.querySelector('.om-dot');

        const outerLen = 2 * Math.PI * 108;
        const innerLen = 2 * Math.PI * 28;
        const lineLen = 32;

        // Reset to beginning
        gsap.set(outer, { strokeDashoffset: outerLen });
        gsap.set(inner, { strokeDashoffset: innerLen });
        gsap.set(lines, { strokeDashoffset: lineLen });
        gsap.set(dot, { scale: 0, opacity: 0 });

        const tl = gsap.timeline();
        
        // duration-deep: 700ms
        const dur = 0.7; 
        // ~30% overlap: start slightly before previous finishes
        const overlap = "-=" + (dur * 0.3); 
        
        // Custom cubic-bezier is hard natively without CustomEase, 
        // using power3.out as closest approximation to the ease-settle (0.22, 1, 0.36, 1)
        const easeSettle = "power3.out";

        tl.to(outer, { strokeDashoffset: 0, duration: dur, ease: easeSettle })
          .to(lines, { strokeDashoffset: 0, duration: dur, ease: easeSettle, stagger: 0 }, overlap)
          .to(inner, { strokeDashoffset: 0, duration: dur, ease: easeSettle }, overlap)
          // For the dot, use a slight back.out for organic settling or just standard ease
          .to(dot, { scale: 1, opacity: 1, duration: 0.32, ease: "back.out(1.5)" }, overlap);
      });
    }
  }

  // Ensure it only initializes once
  // cast to any: custom one-time-init flag on window, not in default Window type
  if (!(window as any).originMarkAnimationInitialized) {
    new OriginMarkAnimation();
    (window as any).originMarkAnimationInitialized = true;
  }
</script>
