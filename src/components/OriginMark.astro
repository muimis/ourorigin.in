---
export interface Props {
  size?: number;
  variant?: 'primary' | 'reversed' | 'gold';
  id?: string;
  animate?: boolean;
}

const { 
  size = 100, 
  variant = 'primary', 
  id = Math.random().toString(36).substring(7),
  animate = false 
} = Astro.props;

const colorMap = {
  primary: 'var(--color-warm-cream)',
  reversed: 'var(--color-forest-deep)',
  gold: 'var(--color-gold)'
};
const strokeColor = colorMap[variant];
---

<svg 
  id={`origin-mark-${id}`}
  class={`origin-mark variant-${variant} ${animate ? 'om-animated' : ''}`} 
  width={size} 
  height={size} 
  viewBox="0 0 100 100" 
  xmlns="http://www.w3.org/2000/svg" 
  fill="none" 
  aria-label="OurOrigin — Origin Mark" 
  role="img"
>
  <!-- Outer ring: 100% width -->
  <circle class="om-outer" cx="50" cy="50" r="49" stroke={strokeColor} stroke-width="0.5" opacity="0.6"/>
  
  <!-- Crosshairs -->
  <g class="om-crosshairs" stroke={strokeColor} stroke-width="0.5" opacity="1" stroke-linecap="round">
    <!-- Main Lines: extend from r=14 to r=37 -->
    <line class="main-line" x1="50" y1="36" x2="50" y2="13"/>
    <line class="main-line" x1="50" y1="64" x2="50" y2="87"/>
    <line class="main-line" x1="36" y1="50" x2="13" y2="50"/>
    <line class="main-line" x1="64" y1="50" x2="87" y2="50"/>
    
    <!-- Optional Corner Ticks: from r=20 to r=25 at 45° -->
    <line class="diag-line" x1="35.86" y1="35.86" x2="32.32" y2="32.32"/>
    <line class="diag-line" x1="64.14" y1="35.86" x2="67.68" y2="32.32"/>
    <line class="diag-line" x1="35.86" y1="64.14" x2="32.32" y2="67.68"/>
    <line class="diag-line" x1="64.14" y1="64.14" x2="67.68" y2="67.68"/>
  </g>

  <!-- Inner ring: 20% of mark width -->
  <circle class="om-inner" cx="50" cy="50" r="10" stroke={strokeColor} stroke-width="0.5" opacity="0.85" fill="none"/>
  
  <!-- Center dot: 4.3% of mark width -->
  <circle class="om-dot" cx="50" cy="50" r="2.15" fill={strokeColor} opacity="1"/>
</svg>

<script>
  import gsap from 'gsap';

  class OriginMarkAnimation {
    constructor() {
      this.init();
      document.addEventListener('play-origin-mark-entrance', () => this.play());
    }

    init() {
      document.querySelectorAll('.om-animated').forEach(svg => {
        const outer = svg.querySelector('.om-outer');
        const mainLines = svg.querySelectorAll('.om-crosshairs .main-line');
        const diagLines = svg.querySelectorAll('.om-crosshairs .diag-line');
        const inner = svg.querySelector('.om-inner');
        const dot = svg.querySelector('.om-dot');

        const outerLen = 2 * Math.PI * 49; 
        const innerLen = 2 * Math.PI * 10;  
        const mainLen = 23; // 37 - 14
        const diagLen = 5;  // 25 - 20

        gsap.set(outer, { strokeDasharray: outerLen, strokeDashoffset: outerLen });
        gsap.set(inner, { strokeDasharray: innerLen, strokeDashoffset: innerLen });
        gsap.set(mainLines, { strokeDasharray: mainLen, strokeDashoffset: mainLen });
        gsap.set(diagLines, { strokeDasharray: diagLen, strokeDashoffset: diagLen });
        gsap.set(dot, { scale: 0, transformOrigin: "50% 50%", opacity: 0 });
      });
    }

    play() {
      document.querySelectorAll('.om-animated').forEach(svg => {
        const outer = svg.querySelector('.om-outer');
        const mainLines = svg.querySelectorAll('.om-crosshairs .main-line');
        const diagLines = svg.querySelectorAll('.om-crosshairs .diag-line');
        const inner = svg.querySelector('.om-inner');
        const dot = svg.querySelector('.om-dot');

        const outerLen = 2 * Math.PI * 49;
        const innerLen = 2 * Math.PI * 10;
        const mainLen = 23;
        const diagLen = 5;

        gsap.set(outer, { strokeDashoffset: outerLen });
        gsap.set(inner, { strokeDashoffset: innerLen });
        gsap.set(mainLines, { strokeDashoffset: mainLen });
        gsap.set(diagLines, { strokeDashoffset: diagLen });
        gsap.set(dot, { scale: 0, opacity: 0 });

        const tl = gsap.timeline();
        const dur = 0.7; 
        const overlap = "-=" + (dur * 0.3); 
        const easeSettle = "power3.out";

        tl.to(outer, { strokeDashoffset: 0, duration: dur, ease: easeSettle })
          .to([mainLines, diagLines], { strokeDashoffset: 0, duration: dur, ease: easeSettle, stagger: 0 }, overlap)
          .to(inner, { strokeDashoffset: 0, duration: dur, ease: easeSettle }, overlap)
          .to(dot, { scale: 1, opacity: 1, duration: 0.32, ease: "back.out(1.5)" }, overlap);
      });
    }
  }

  if (!(window as any).originMarkAnimationInitialized) {
    new OriginMarkAnimation();
    (window as any).originMarkAnimationInitialized = true;
  }
</script>
