---
import OriginMark from './OriginMark.astro';
---

<footer class="global-footer">
  <span class="brand-text">OURORIGIN</span>
  <OriginMark variant="gold" size={24} animate={true} />
  <a class="nav-link" href="/observations">Observations</a>
  <a class="nav-link" href="/why">Why this exists.</a>
  <a class="nav-link" href="/contact">Contact</a>
</footer>

<style>
  .global-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 1.5rem 2rem;
    z-index: 9000;
    background: linear-gradient(to top, rgba(12, 21, 9, 1) 0%, rgba(12, 21, 9, 0) 100%);
    pointer-events: auto; /* Allow clicks */
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .brand-text {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: rgba(245, 237, 216, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .nav-link {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: rgba(245, 237, 216, 0.6);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: color 0.3s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: rgba(245, 237, 216, 1);
  }
  
  @media (max-width: 768px) {
    .global-footer {
      padding: 1rem;
      gap: 1.5rem;
    }
    
    .brand-text, .nav-link {
      font-size: 9px;
    }
  }
</style>
